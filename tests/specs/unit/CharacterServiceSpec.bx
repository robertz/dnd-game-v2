/**
 * Unit tests for app/models/CharacterService.bx — currently just
 * deleteCharacter()'s ownership scoping. There's no separate test
 * datasource (see runtime/boxlang.json — "gameserver" is the only one
 * configured), so this hits the real dev DB directly like the app does;
 * every fixture it creates (a throwaway user + character) is cleaned up
 * in afterAll.
 */
class extends="testbox.system.BaseSpec" {

	function beforeAll(){
		variables.service = new models.CharacterService();

		queryExecute(
			"INSERT INTO users (username, password_hash) VALUES (:username, 'x')",
			{ "username": "ts_owner_#left( createUUID(), 8 )#" },
			{ datasource: "gameserver", result: "variables.ownerResult" }
		);
		variables.ownerUserId = ownerResult.generatedKey;

		queryExecute(
			"INSERT INTO users (username, password_hash) VALUES (:username, 'x')",
			{ "username": "ts_other_#left( createUUID(), 8 )#" },
			{ datasource: "gameserver", result: "variables.otherResult" }
		);
		variables.otherUserId = otherResult.generatedKey;
	}

	function afterAll(){
		queryExecute(
			"DELETE FROM users WHERE id IN (:a, :b)",
			{ "a": variables.ownerUserId, "b": variables.otherUserId },
			{ datasource: "gameserver" }
		);
	}

	private function makeCharacter(){
		return service.createCharacter(
			ownerUserId = variables.ownerUserId,
			name        = "Test Deleteme",
			classId     = 1,
			str = 10, dex = 10, con = 10, intScore = 10, wis = 10, cha = 10
		);
	}

	function run(){
		describe( "deleteCharacter()", () => {
			it( "removes the character from its owner's saved list", () => {
				var charId = makeCharacter();
				service.deleteCharacter( characterId = charId, ownerUserId = variables.ownerUserId );

				var remaining = service.listSavedCharacters( variables.ownerUserId );
				var stillThere = remaining.reduce( ( found, row ) => found || ( row.id == charId ), false );
				expect( stillThere ).toBeFalse();
			} );

			it( "does not delete a character belonging to a different user", () => {
				var charId = makeCharacter();
				service.deleteCharacter( characterId = charId, ownerUserId = variables.otherUserId );

				var remaining = service.listSavedCharacters( variables.ownerUserId );
				var stillThere = remaining.reduce( ( found, row ) => found || ( row.id == charId ), false );
				expect( stillThere ).toBeTrue();

				// Clean up — the mismatched-owner call above was a no-op.
				service.deleteCharacter( characterId = charId, ownerUserId = variables.ownerUserId );
			} );
		} );

		describe( "Weapon and armor proficiency restrictions", () => {
			// classId 12 = Wizard (Simple weapons only, no armor training at
			// all — see db/seed.sql's classes table), the strictest class in
			// the dataset for both checks.
			it( "addWeaponToInventory() omits Proficiency Bonus for a weapon the class isn't trained with", () => {
				var charId = service.createCharacter(
					ownerUserId = variables.ownerUserId, name = "Test Untrained Wizard",
					classId = 12, str = 10, dex = 10, con = 10, intScore = 10, wis = 10, cha = 10
				);
				service.addWeaponToInventory( charId, 22, "melee" ); // Longsword — Martial
				var inv = service.getInventory( charId );
				var longsword = inv.filter( ( i ) => i.weaponName == "Longsword" )[ 1 ];
				expect( longsword.attackBonus ).toBe( 0 ); // 0 (Str mod) + 0 (not proficient)

				service.deleteCharacter( characterId = charId, ownerUserId = variables.ownerUserId );
			} );

			it( "addWeaponToInventory() still includes Proficiency Bonus for a weapon the class IS trained with", () => {
				var charId = service.createCharacter(
					ownerUserId = variables.ownerUserId, name = "Test Trained Wizard",
					classId = 12, str = 10, dex = 10, con = 10, intScore = 10, wis = 10, cha = 10
				);
				service.addWeaponToInventory( charId, 1, "melee" ); // Club — Simple
				var inv = service.getInventory( charId );
				var club = inv.filter( ( i ) => i.weaponName == "Club" )[ 1 ];
				expect( club.attackBonus ).toBe( 2 ); // 0 (Str mod) + 2 (Proficiency Bonus)

				service.deleteCharacter( characterId = charId, ownerUserId = variables.ownerUserId );
			} );

			it( "setArmorEquipped() refuses armor the class has no training in", () => {
				var charId = service.createCharacter(
					ownerUserId = variables.ownerUserId, name = "Test Armorless Wizard",
					classId = 12, str = 10, dex = 10, con = 10, intScore = 10, wis = 10, cha = 10
				);
				service.addArmorToInventory( charId, 13 ); // Shield
				var inv = service.getArmorInventory( charId );

				expect( () => service.setArmorEquipped( charId, inv[ 1 ].id, true ) ).toThrow( "NotProficient" );

				var stillUnequipped = service.getArmorInventory( charId )[ 1 ];
				expect( stillUnequipped.equipped ).toBeFalse();

				service.deleteCharacter( characterId = charId, ownerUserId = variables.ownerUserId );
			} );

			it( "setArmorEquipped() allows armor the class IS trained in", () => {
				var charId = service.createCharacter(
					ownerUserId = variables.ownerUserId, name = "Test Armored Fighter",
					classId = 5, str = 10, dex = 10, con = 10, intScore = 10, wis = 10, cha = 10 // Fighter: all armor + shields
				);
				service.addArmorToInventory( charId, 13 ); // Shield
				var inv = service.getArmorInventory( charId );

				expect( () => service.setArmorEquipped( charId, inv[ 1 ].id, true ) ).notToThrow();

				var nowEquipped = service.getArmorInventory( charId )[ 1 ];
				expect( nowEquipped.equipped ).toBeTrue();

				service.deleteCharacter( characterId = charId, ownerUserId = variables.ownerUserId );
			} );
		} );

		describe( "getParty()/setParty()", () => {
			it( "persists an ordered party and returns it in that order", () => {
				var charA = makeCharacter();
				var charB = makeCharacter();

				service.setParty( variables.ownerUserId, [ charB, charA ] );
				var party = service.getParty( variables.ownerUserId );

				expect( party.recordCount ).toBe( 2 );
				expect( party.id[ 1 ] ).toBe( charB );
				expect( party.id[ 2 ] ).toBe( charA );

				service.deleteCharacter( characterId = charA, ownerUserId = variables.ownerUserId );
				service.deleteCharacter( characterId = charB, ownerUserId = variables.ownerUserId );
			} );

			it( "replaces the whole party rather than merging with the previous one", () => {
				var charA = makeCharacter();
				var charB = makeCharacter();

				service.setParty( variables.ownerUserId, [ charA ] );
				service.setParty( variables.ownerUserId, [ charB ] );
				var party = service.getParty( variables.ownerUserId );

				expect( party.recordCount ).toBe( 1 );
				expect( party.id[ 1 ] ).toBe( charB );

				service.deleteCharacter( characterId = charA, ownerUserId = variables.ownerUserId );
				service.deleteCharacter( characterId = charB, ownerUserId = variables.ownerUserId );
			} );

			it( "silently drops a character id that doesn't belong to the requesting owner", () => {
				var mine    = makeCharacter();
				var notMine = service.createCharacter(
					ownerUserId = variables.otherUserId, name = "Test Not Mine",
					classId = 1, str = 10, dex = 10, con = 10, intScore = 10, wis = 10, cha = 10
				);

				service.setParty( variables.ownerUserId, [ mine, notMine ] );
				var party = service.getParty( variables.ownerUserId );

				expect( party.recordCount ).toBe( 1 );
				expect( party.id[ 1 ] ).toBe( mine );

				service.deleteCharacter( characterId = mine, ownerUserId = variables.ownerUserId );
				service.deleteCharacter( characterId = notMine, ownerUserId = variables.otherUserId );
			} );

			it( "caps the party at 4 members, keeping only the first 4 given", () => {
				var ids = [];
				for ( var i = 1; i <= 5; i++ ) {
					ids.append( makeCharacter() );
				}

				service.setParty( variables.ownerUserId, ids );
				var party = service.getParty( variables.ownerUserId );

				expect( party.recordCount ).toBe( 4 );

				for ( var charId in ids ) {
					service.deleteCharacter( characterId = charId, ownerUserId = variables.ownerUserId );
				}
			} );

			it( "drops a character from the party when it's deleted (party_members cascades)", () => {
				var charA = makeCharacter();
				var charB = makeCharacter();

				service.setParty( variables.ownerUserId, [ charA, charB ] );
				service.deleteCharacter( characterId = charA, ownerUserId = variables.ownerUserId );
				var party = service.getParty( variables.ownerUserId );

				expect( party.recordCount ).toBe( 1 );
				expect( party.id[ 1 ] ).toBe( charB );

				service.deleteCharacter( characterId = charB, ownerUserId = variables.ownerUserId );
			} );
		} );
	}

}
