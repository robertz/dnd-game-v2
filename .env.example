# Copy to .env and adjust for your local setup. CommandBox loads .env
# automatically on `box server start` — see runtime/boxlang.json for how
# these map to the datasource, and README.md's Setup section.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gameserver
DB_USER=root
DB_PASSWORD=
DB_DRIVER=MySQL

# true in production so session cookies require HTTPS — see public/Application.bx
GAME_COOKIE_SECURE=false

# Verbose BoxLang engine debug logging
BOXLANG_DEBUG=false
