/**
 * The combat rules engine: attack/damage resolution, action economy and
 * round flow, conditions, weapons, saves, in-combat spellcasting, death
 * saves, initiative, and class combat resources (rage, Second Wind,
 * consumables). Mutates the encounter state struct in place, same
 * convention as the old monolith. Depends on Dice, Rules, Grid,
 * Spellcasting, Progression, and CharacterState.
 */
class singleton {

	function init( dice, rules, grid, spellcasting, progression, characterState ) {
		variables.dice           = arguments.dice;
		variables.rules          = arguments.rules;
		variables.grid           = arguments.grid;
		variables.spellcasting   = arguments.spellcasting;
		variables.progression    = arguments.progression;
		variables.characterState = arguments.characterState;
		return this;
	}

	/**
	 * Switches which party member `state.player` is aliased to — saves the
	 * outgoing member's per-turn economy (movement/action/bonus action/
	 * attacks) onto their own struct in `state.players`, then restores the
	 * incoming member's saved economy onto the top-level scratch fields every
	 * existing combat function already reads via `state.movementRemaining`
	 * etc. A no-op if `newIndex` is out of range or already active.
	 *
	 * @state The encounter's full mutable game state struct.
	 * @newIndex 1-based index into `state.players` to make active.
	 */
	function switchActivePlayer( state, newIndex ) {
		if ( arguments.newIndex < 1 || arguments.newIndex > arguments.state.players.len() || arguments.newIndex == arguments.state.activePlayerIndex ) {
			return;
		}
		var outgoing = arguments.state.players[ arguments.state.activePlayerIndex ];
		outgoing.movementRemaining   = arguments.state.movementRemaining;
		outgoing.actionUsed          = arguments.state.actionUsed;
		outgoing.bonusActionUsed     = arguments.state.bonusActionUsed;
		outgoing.attacksUsedThisTurn = arguments.state.attacksUsedThisTurn;

		arguments.state.activePlayerIndex = arguments.newIndex;
		var incoming = arguments.state.players[ arguments.newIndex ];
		arguments.state.player = incoming;
		arguments.state.movementRemaining   = incoming.movementRemaining;
		arguments.state.actionUsed          = incoming.actionUsed;
		arguments.state.bonusActionUsed     = incoming.bonusActionUsed;
		arguments.state.attacksUsedThisTurn = incoming.attacksUsedThisTurn;
	}

	/**
	 * Initializes the per-turn economy fields on a freshly loaded party
	 * member so switchActivePlayer()/memberHasActionsLeft() can read them
	 * without existence checks. Called once per member at encounter build.
	 */
	function initMemberEconomy( member ) {
		arguments.member.movementRemaining   = max( 0, int( arguments.member.speed / 5 ) );
		arguments.member.actionUsed          = false;
		arguments.member.bonusActionUsed     = false;
		arguments.member.attacksUsedThisTurn = 0;
	}

	/**
	 * Whether one party member still has action economy to spend this round.
	 * The active member's live economy is the top-level scratch fields, not
	 * their own struct (see switchActivePlayer()) — a downed member has
	 * nothing to spend.
	 */
	function memberHasActionsLeft( state, idx ) {
		var member = arguments.state.players[ arguments.idx ];
		if ( member.hitPoints <= 0 ) {
			return false;
		}
		var isActive    = ( arguments.idx == arguments.state.activePlayerIndex );
		var actionUsed  = isActive ? arguments.state.actionUsed          : member.actionUsed;
		var attacksUsed = isActive ? arguments.state.attacksUsedThisTurn : member.attacksUsedThisTurn;
		return !actionUsed || attacksUsed < attacksPerTurn( member );
	}

	/**
	 * Whether every living party member has spent their action economy this
	 * round — used in place of a single-player exhaustion check to decide
	 * when the party's turn can auto-end. For a solo party this reduces to
	 * exactly the same check as before multi-character support existed.
	 *
	 * @state The encounter's full mutable game state struct.
	 */
	function allPlayersExhausted( state ) {
		for ( var i = 1; i <= arguments.state.players.len(); i++ ) {
			if ( memberHasActionsLeft( arguments.state, i ) ) {
				return false;
			}
		}
		return true;
	}

	/**
	 * Resets everything that recharges at the top of a new round for every
	 * living party member: movement and Action/Bonus Action/Reaction economy,
	 * plus every living combatant's Reaction (used for opportunity attacks —
	 * see checkOpportunityAttacks()). Shared by endPlayerTurn() and the wire
	 * component's auto-battle loop so the reset logic only lives in one place.
	 *
	 * @state The encounter's full mutable game state struct.
	 */
	function startNewRound( state ) {
		for ( var member in arguments.state.players ) {
			// The in-game clock ticks forward by one round (~6 seconds, per the
			// SRD) — this is what Short/Long Rest's hour-sized jumps are
			// measured against (see RulesService.variables.rules.secondsPerRound()/shortRest()/longRest()).
			if ( structKeyExists( member, "gameClockSeconds" ) ) {
				member.gameClockSeconds += variables.rules.secondsPerRound();
			}
			// Weapon Mastery — Slow: a hit reduces the target's Speed by 10 ft.
			// until the start of the attacker's next turn — approximated here as
			// "until the start of the next round," since this app has exactly one
			// party turn per round. Reset (not reapplied) every round.
			member.speedPenalty = 0;
			member.reactionUsed = false;
			// Sneak Attack (Rogue) and Weapon Mastery — Vex are each limited to
			// "once per turn"/"until your next attack lands"; both reset here so a
			// leftover flag from last round can't linger indefinitely if unused.
			member.usedSneakAttackThisTurn = false;
			member.vexAdvantageTarget = "";
			member.usedNickThisTurn = false;
			member.movementRemaining   = max( 0, int( member.speed / 5 ) );
			member.actionUsed          = false;
			member.bonusActionUsed     = false;
			member.attacksUsedThisTurn = 0;
		}
		// state.player is a live alias into state.players, so its fields were
		// just reset by the loop above — refresh the top-level scratch copy
		// every other combat function reads via state.movementRemaining etc.
		var active = arguments.state.players[ arguments.state.activePlayerIndex ];
		arguments.state.movementRemaining   = active.movementRemaining;
		arguments.state.actionUsed          = active.actionUsed;
		arguments.state.bonusActionUsed     = active.bonusActionUsed;
		arguments.state.attacksUsedThisTurn = active.attacksUsedThisTurn;
		// Whether either side actually attacked/cast this round — see
		// autoStep()'s stalemate check, which stops auto-battle rather than
		// polling forever when neither combatant can reach the other (e.g. a
		// monster stranded in water, or a maze pocket the player can't path
		// out of).
		arguments.state.roundHadAction = false;
		for ( var opponent in stateOpponents( arguments.state ) ) {
			opponent.reactionUsed = false;
			opponent.speedPenalty = 0;
		}
	}

	/**
	 * How many weapon attacks the Attack action grants this combatant in one
	 * turn — 1 normally, or more with the Extra Attack class feature line
	 * (Fighter's own progression goes further than other classes': Extra
	 * Attack at 5th grants a 2nd attack, "Two Extra Attacks" at 11th a 3rd,
	 * "Three Extra Attacks" at 20th a 4th — each tier is additive with the
	 * ones before it, matching how class_features accumulates them in
	 * `player.features` as the character levels up).
	 */
	function attacksPerTurn( combatant ) {
		if ( !structKeyExists( arguments.combatant, "features" ) ) {
			return 1;
		}
		var total = 1;
		if ( arrayFindNoCase( arguments.combatant.features, "Extra Attack" ) > 0 ) {
			total += 1;
		}
		if ( arrayFindNoCase( arguments.combatant.features, "Two Extra Attacks" ) > 0 ) {
			total += 1;
		}
		if ( arrayFindNoCase( arguments.combatant.features, "Three Extra Attacks" ) > 0 ) {
			total += 1;
		}
		return total;
	}

	/**
	 * Resolves opportunity attacks triggered by `mover` leaving a hostile
	 * combatant's reach: any living hostile that was adjacent to
	 * `startPosition` and is no longer adjacent to `mover`'s new position gets
	 * one free melee attack against them, using their Reaction (tracked via
	 * `reactionUsed`, reset each round by startNewRound()) — provided they
	 * have an equipped melee weapon. Simplified to only look at the start and
	 * end position (not every square crossed mid-move) and to ignore the
	 * Disengage action and reach weapons, neither of which this app models.
	 *
	 * @state The encounter's full mutable game state struct.
	 * @mover The combatant who just moved.
	 * @moverIsPlayer Whether `mover` is `state.player` — decides which side's living combatants are checked as potential attackers.
	 * @startPosition Where `mover` was standing before this move ({x, y}).
	 */
	function checkOpportunityAttacks( state, mover, moverIsPlayer, startPosition ) {
		var hostiles = arguments.moverIsPlayer ? stateOpponents( arguments.state ) : arguments.state.players;
		var moverAtStart = { "position": arguments.startPosition };

		for ( var hostile in hostiles ) {
			if (
				hostile.hitPoints <= 0 ||
				( structKeyExists( hostile, "reactionUsed" ) && hostile.reactionUsed ) ||
				isIncapacitated( hostile ) ||
				variables.grid.chebyshev( moverAtStart, hostile ) > 1 ||
				variables.grid.chebyshev( arguments.mover, hostile ) <= 1
			) {
				continue;
			}
			var melee = equippedWeapon( hostile, "melee" );
			if ( isNull( melee ) ) {
				continue;
			}
			hostile.reactionUsed = true;
			arguments.state.log.prepend( "#hostile.name# makes an opportunity attack as #arguments.mover.name# moves away!" );
			resolveAttack( arguments.state.log, hostile, arguments.mover, melee, false, false, false, coverBonus( arguments.state, hostile, arguments.mover ), arguments.state );
			checkDefenderDefeated( arguments.state, hostile, arguments.mover, arguments.moverIsPlayer );
			if ( arguments.state.gameOver ) {
				return;
			}
		}
	}

	/**
	 * Aggro/threat tracking: records that `attacker` (a party member) dealt
	 * `amount` damage to `defender` (an opponent), so _selectAggroTarget()
	 * can have opponents fixate on whichever party member has hurt them
	 * most. Identified by shape rather than an explicit flag: a party
	 * member struct always carries `characterId`, an opponent struct always
	 * carries `mobIndex` — so this is a no-op for every other
	 * attacker/defender pairing (a monster damaging the party, healing,
	 * Cleave's damage back onto the same monster's own ally never happens,
	 * etc.), and every damage call site can call it unconditionally.
	 *
	 * @defender The opponent that was just damaged (mutated in place).
	 * @attacker Whoever dealt the damage.
	 * @amount The actual damage dealt, after resistance/vulnerability.
	 */
	function recordThreat( defender, attacker, amount ) {
		if (
			arguments.amount <= 0 ||
			!structKeyExists( arguments.attacker, "characterId" ) ||
			!structKeyExists( arguments.defender, "mobIndex" )
		) {
			return;
		}
		if ( !structKeyExists( arguments.defender, "threat" ) ) {
			arguments.defender.threat = {};
		}
		var key = "p#arguments.attacker.characterId#";
		arguments.defender.threat[ key ] = ( structKeyExists( arguments.defender.threat, key ) ? arguments.defender.threat[ key ] : 0 ) + arguments.amount;
	}

	/**
	 * Returns `state.opponents` (the full mob roster) if present, or a
	 * single-element array wrapping `state.opponent` otherwise — lets every
	 * multi-mob-aware function keep working unchanged for callers (like the
	 * unit tests, and any old state shape) that only ever had one opponent.
	 */
	function stateOpponents( state ) {
		return structKeyExists( arguments.state, "opponents" ) ? arguments.state.opponents : [ arguments.state.opponent ];
	}

	/**
	 * Positions of every living combatant in `state` except `mover` and
	 * `target` themselves — passed to variables.grid.moveToward() as `occupiedPositions` so
	 * a mover's path never lands on a tile another living combatant already
	 * occupies. `mover`/`target` are excluded by identity (their own current
	 * square is obviously not an obstacle to themselves, and the target's
	 * square is handled separately by variables.grid.moveToward()'s own "adjacent to
	 * target" goal, not by blocking it outright).
	 */
	function otherLivingPositions( state, mover, target ) {
		var positions = [];
		var candidates = [];
		for ( var member in arguments.state.players ) {
			candidates.append( member );
		}
		for ( var o in stateOpponents( arguments.state ) ) {
			candidates.append( o );
		}
		for ( var candidate in candidates ) {
			if (
				candidate.hitPoints <= 0 ||
				candidate.name == arguments.mover.name ||
				candidate.name == arguments.target.name
			) {
				continue;
			}
			positions.append( { "x": candidate.position.x, "y": candidate.position.y } );
		}
		return positions;
	}

	/**
	 * True if every opponent in `state.opponents` (or the lone `state.opponent`,
	 * for single-mob state) has been reduced to 0 HP.
	 */
	function allOpponentsDefeated( state ) {
		for ( var o in stateOpponents( arguments.state ) ) {
			if ( o.hitPoints > 0 ) {
				return false;
			}
		}
		return true;
	}

	/**
	 * Picks the closest living opponent to the player (Chebyshev distance) —
	 * used by the auto-battle player AI to decide who to chase/attack. Falls
	 * back to whatever's already in `state.opponent` if every opponent is
	 * somehow already down (shouldn't happen — the encounter should already
	 * be over by then).
	 */
	function nearestLivingOpponent( state ) {
		var player = arguments.state.player;
		var nearest = javaCast( "null", 0 );
		var nearestDistance = 0;
		for ( var o in stateOpponents( arguments.state ) ) {
			if ( o.hitPoints <= 0 ) {
				continue;
			}
			var d = variables.grid.chebyshev( player, o );
			if ( isNull( nearest ) || d < nearestDistance ) {
				nearest = o;
				nearestDistance = d;
			}
		}
		return isNull( nearest ) ? arguments.state.opponent : nearest;
	}

	/**
	 * If `state.opponent` (the player's currently selected target) has been
	 * defeated but others remain, retargets to the next living opponent in
	 * `state.opponents` — so the player isn't stuck "attacking" a corpse.
	 * A no-op for single-mob state or when the current target is still up.
	 */
	function retargetIfCurrentOpponentDefeated( state ) {
		if ( !structKeyExists( arguments.state, "opponents" ) || arguments.state.opponent.hitPoints > 0 ) {
			return;
		}
		for ( var o in arguments.state.opponents ) {
			if ( o.hitPoints > 0 ) {
				arguments.state.opponent = o;
				return;
			}
		}
	}

	/**
	 * General condition tracking (Prone, Restrained, Poisoned, Frightened,
	 * etc.) — a combatant's `conditions` struct maps condition name to true
	 * (or a small data struct, e.g. `{"source": "..."}` for Frightened),
	 * created lazily so nothing needs it initialized up front. Only these
	 * four conditions have mechanical effects wired up elsewhere in this file
	 * (resolveAttack, rollSavingThrow, moveToward); others can still be
	 * tracked here, and addCondition() below honors a combatant's
	 * conditionImmunities for any condition name (not just these four) even
	 * though most have no other mechanical effect yet — same "latent
	 * capability" pattern this file already uses for monster spellcasting.
	 */
	function hasCondition( combatant, name ) {
		return structKeyExists( arguments.combatant, "conditions" ) && structKeyExists( arguments.combatant.conditions, arguments.name );
	}

	function addCondition( combatant, name, data = true ) {
		if (
			structKeyExists( arguments.combatant, "conditionImmunities" ) &&
			arrayFindNoCase( arguments.combatant.conditionImmunities, arguments.name ) > 0
		) {
			return;
		}
		if ( !structKeyExists( arguments.combatant, "conditions" ) ) {
			arguments.combatant.conditions = {};
		}
		arguments.combatant.conditions[ arguments.name ] = arguments.data;
	}

	function removeCondition( combatant, name ) {
		if ( structKeyExists( arguments.combatant, "conditions" ) ) {
			arguments.combatant.conditions.delete( arguments.name );
		}
	}

	/**
	 * True if `combatant` can't take actions or Reactions — Incapacitated
	 * itself, or any condition whose own rules text says "incapacitated"
	 * (Paralyzed, Petrified, Stunned, Unconscious). Gates the player's
	 * manual actions (default.bx), the enemy AI's turn (_runOneOpponentTurn()),
	 * and Reactions (checkOpportunityAttacks()).
	 */
	function isIncapacitated( combatant ) {
		return (
			hasCondition( arguments.combatant, "Incapacitated" ) ||
			isHelpless( arguments.combatant )
		);
	}

	/**
	 * True for Paralyzed, Petrified, Stunned, or Unconscious specifically —
	 * unlike plain Incapacitated, these also grant attackers Advantage,
	 * auto-fail the defender's Strength/Dexterity saves, and (Paralyzed/
	 * Unconscious only, checked separately in resolveAttack()) auto-crit a
	 * melee hit. Plain Incapacitated alone grants none of that.
	 */
	function isHelpless( combatant ) {
		return (
			hasCondition( arguments.combatant, "Paralyzed" ) ||
			hasCondition( arguments.combatant, "Petrified" ) ||
			hasCondition( arguments.combatant, "Stunned" ) ||
			hasCondition( arguments.combatant, "Unconscious" )
		);
	}

	/**
	 * True if `combatant`'s Speed is effectively 0 — Restrained (already
	 * modeled), or Paralyzed/Petrified/Stunned/Unconscious, each of which
	 * separately says "can't move" on top of being incapacitated. Plain
	 * Incapacitated does *not* restrict movement by itself, per its own SRD
	 * definition — only these specific conditions do.
	 */
	function cantMove( combatant ) {
		return hasCondition( arguments.combatant, "Restrained" ) || isHelpless( arguments.combatant );
	}

	/**
	 * The SRD rules text for a condition (e.g. "Prone"), from the
	 * `conditions` table — for a tooltip on the combat log's condition chips,
	 * so a player can see what "Restrained" or "Frightened" actually does
	 * without leaving the encounter. Empty string for a name with no matching
	 * row (there's no source of untrusted/free-text condition names today,
	 * but addCondition() doesn't validate against the table, so this stays
	 * graceful rather than throwing).
	 */
	function conditionDescription( name ) {
		var rows = queryExecute(
			"SELECT description FROM conditions WHERE name = :name",
			{ "name": arguments.name },
			{ datasource: "gameserver" }
		);
		return ( rows.recordCount > 0 && !isNull( rows.description[ 1 ] ) ) ? rows.description[ 1 ] : "";
	}

	/**
	 * Returns `combatant`'s equipped weapon of the given category ("melee" or
	 * "ranged"), or null if they aren't carrying one.
	 */
	function equippedWeapon( combatant, category ) {
		for ( var item in arguments.combatant.inventory ) {
			if ( item.category == arguments.category && item.equipped ) {
				return item;
			}
		}
		return javaCast( "null", 0 );
	}

	/**
	 * Picks the best equipped weapon `combatant` can use against a target at
	 * `distance` squares away: melee if adjacent (better damage, no
	 * Disadvantage), otherwise an equipped ranged weapon if the target is
	 * within its long range. Returns null if nothing is usable at that range.
	 * A ranged attack beyond normal range (but within long range) has
	 * Disadvantage, per the "Ranged Attacks" rules.
	 */
	/**
	 * @grid Optional level grid (`{width, height, tiles}`, from MapService) — if given along with `targetPosition`, a ranged option is only offered when there's a clear line of sight to the target (a wall in the way blocks the shot, per the "Ranged Attacks" rules).
	 * @targetPosition Optional `{x, y}` of the target, required alongside `grid` for the line-of-sight check.
	 */
	function pickWeaponForDistance( combatant, distance, grid = javaCast( "null", 0 ), targetPosition = javaCast( "null", 0 ) ) {
		var melee = equippedWeapon( arguments.combatant, "melee" );
		if ( arguments.distance <= 1 && !isNull( melee ) ) {
			return { "weapon": melee, "disadvantage": false };
		}

		var ranged = equippedWeapon( arguments.combatant, "ranged" );
		if ( !isNull( ranged ) && arguments.distance <= ranged.longRange ) {
			if (
				!isNull( arguments.grid ) && !isNull( arguments.targetPosition ) &&
				!variables.grid.hasLineOfSight( arguments.grid, arguments.combatant.position, arguments.targetPosition )
			) {
				return javaCast( "null", 0 );
			}
			return {
				"weapon": ranged,
				// Also has Disadvantage at Close Combat range (within 5 ft of a foe), per the rules.
				"disadvantage": ( arguments.distance <= 1 || arguments.distance > ranged.normalRange )
			};
		}

		return javaCast( "null", 0 );
	}

	/**
	 * Half Cover bonus (+2 AC and Dexterity saves) for an attack from
	 * `attacker` against `defender`: granted when another living combatant
	 * (not the attacker or defender themselves) occupies a grid square on the
	 * straight line between them, per the "Cover" rules — one creature
	 * providing cover for another. Simplified to this one case: this app
	 * doesn't model terrain/objects as separate obstacles from walls (which
	 * already fully block a shot via variables.grid.hasLineOfSight() instead of granting
	 * partial cover), so Three-Quarters Cover and wall-corner Half Cover
	 * aren't modeled. Returns 0 without a grid (e.g. the unit tests' bare
	 * combatant fixtures) or if attacker/defender aren't at least 2 squares
	 * apart (nothing can stand between adjacent combatants).
	 *
	 * @state The encounter's full mutable game state struct.
	 * @attacker The attacking combatant.
	 * @defender The targeted combatant.
	 */
	function coverBonus( state, attacker, defender ) {
		var grid = variables.grid.stateGrid( arguments.state );
		if ( isNull( grid ) || variables.grid.chebyshev( arguments.attacker, arguments.defender ) < 2 ) {
			return 0;
		}

		var others = [];
		if ( structKeyExists( arguments.state, "players" ) ) {
			for ( var member in arguments.state.players ) {
				others.append( member );
			}
		} else if ( structKeyExists( arguments.state, "player" ) ) {
			others.append( arguments.state.player );
		}
		for ( var o in stateOpponents( arguments.state ) ) {
			others.append( o );
		}

		var x = arguments.attacker.position.x;
		var y = arguments.attacker.position.y;
		var targetX = arguments.defender.position.x;
		var targetY = arguments.defender.position.y;
		var dx = abs( targetX - x );
		var dy = abs( targetY - y );
		var stepX = ( x < targetX ) ? 1 : -1;
		var stepY = ( y < targetY ) ? 1 : -1;
		var err = dx - dy;

		while ( !( x == targetX && y == targetY ) ) {
			var doubledErr = 2 * err;
			if ( doubledErr > -dy ) {
				err -= dy;
				x += stepX;
			}
			if ( doubledErr < dx ) {
				err += dx;
				y += stepY;
			}
			if ( x == targetX && y == targetY ) {
				break;
			}
			for ( var other in others ) {
				if (
					other.hitPoints > 0 && other.position.x == x && other.position.y == y &&
					other.name != arguments.attacker.name && other.name != arguments.defender.name
				) {
					return 2;
				}
			}
		}
		return 0;
	}

	/**
	 * Resolves one attack roll and, on a hit, one damage roll, per the core
	 * rules: d20 + attack bonus vs AC; natural 20 always hits and is a
	 * Critical Hit (roll damage dice twice); natural 1 always misses.
	 * Disadvantage rolls two d20s and keeps the lower result.
	 * Vulnerability/Resistance/Immunity to the weapon's damage type is applied.
	 * A defender with an unused Reaction and a parsed Parry trait
	 * (`defender.parryBonus`, see _structuredParryBonus()) can turn a
	 * non-critical melee hit into a miss.
	 *
	 * `state` is optional (defaults to `{}`, as every existing unit test call
	 * omits it) — it's only used for the Weapon Mastery properties that need
	 * more battlefield context than a single attacker/defender pair (Push's
	 * grid, Cleave's second target from `state.opponents`). Every real
	 * combat call site passes the full encounter state; only Weapon Mastery
	 * is gated behind it (see the "Weapon Mastery" section below), and only
	 * ever for a combatant with the "Weapon Mastery" class feature, which in
	 * this dataset is always the player.
	 *
	 * @log The encounter's combat log array — a new entry is prepended.
	 * @attacker The attacker's stat struct (has a `name`).
	 * @defender The defender's stat struct — mutated in place with the result.
	 * @weapon The weapon item being used for this attack (from inventory).
	 * @disadvantage Whether this attack roll has Disadvantage.
	 */
	function resolveAttack( log, attacker, defender, weapon, disadvantage = false, advantage = false, omitDamageBonus = false, coverBonus = 0, state = {} ) {
		// One attack flows through the stages below as a single mutable `atk`
		// struct (the same in-place convention the encounter `state` uses):
		// advantage state -> to-hit roll -> on a hit, damage roll -> damage
		// application -> Weapon Mastery riders. Each stage reads what earlier
		// stages recorded on `atk`.
		var atk = {
			"log": arguments.log, "attacker": arguments.attacker, "defender": arguments.defender,
			"weapon": arguments.weapon, "disadvantage": arguments.disadvantage, "advantage": arguments.advantage,
			"omitDamageBonus": arguments.omitDamageBonus, "coverBonus": arguments.coverBonus, "state": arguments.state
		};
		_resolveAdvantageState( atk );
		_rollToHit( atk );
		if ( !atk.hits ) {
			_logMissAndGraze( atk );
			return;
		}
		_rollDamage( atk );
		_applyDamage( atk );
		_applyMasteryRiders( atk );
	}

	/**
	 * Stage 1 — net Advantage/Disadvantage for this attack: caller-requested
	 * flags plus every automatic source (Grappler feat vs. a grappled target,
	 * attacker/defender conditions, Weapon Mastery Vex/Sap carry-over flags,
	 * which are consumed here whether or not they end up mattering).
	 * Advantage and Disadvantage on the same roll cancel out, per the rules.
	 */
	private function _resolveAdvantageState( atk ) {
		var attacker = arguments.atk.attacker;
		var defender = arguments.atk.defender;
		// Grappler: attacks against a creature you've grappled have Advantage,
		// even if the caller didn't ask for it explicitly.
		var autoAdvantage = (
			structKeyExists( defender, "grappledBy" ) &&
			defender.grappledBy == attacker.name &&
			structKeyExists( attacker, "hasGrapplerFeat" ) &&
			attacker.hasGrapplerFeat
		);
		// Prone: melee attacks against a Prone target have Advantage, ranged
		// ones have Disadvantage. Restrained: attacks against a Restrained
		// target always have Advantage; being Restrained yourself always gives
		// Disadvantage on your own attacks, same as being Poisoned or
		// Frightened (simplified here to apply regardless of whether the
		// source of the fear is in sight, since this app doesn't track that).
		// Blinded: your own attacks have Disadvantage. Invisible: your own
		// attacks have Advantage (the mirror image of Blinded).
		var autoDisadvantage = (
			hasCondition( attacker, "Restrained" ) ||
			hasCondition( attacker, "Poisoned" ) ||
			hasCondition( attacker, "Frightened" ) ||
			hasCondition( attacker, "Blinded" )
		);
		if ( hasCondition( attacker, "Invisible" ) ) {
			autoAdvantage = true;
		}
		if ( hasCondition( defender, "Prone" ) ) {
			if ( arguments.atk.weapon.category == "melee" ) {
				autoAdvantage = true;
			} else {
				autoDisadvantage = true;
			}
		}
		// Restrained, Blinded (can't see to defend), and Paralyzed/Petrified/
		// Stunned/Unconscious (helpless) all give attacks against the
		// defender Advantage. Invisible is the opposite: attacks against an
		// Invisible defender have Disadvantage.
		if (
			hasCondition( defender, "Restrained" ) ||
			hasCondition( defender, "Blinded" ) ||
			isHelpless( defender )
		) {
			autoAdvantage = true;
		}
		if ( hasCondition( defender, "Invisible" ) ) {
			autoDisadvantage = true;
		}
		// Weapon Mastery — Vex: a prior hit against this same target with a
		// Vex weapon grants Advantage on this attack (consumed either way).
		if (
			structKeyExists( attacker, "vexAdvantageTarget" ) && len( attacker.vexAdvantageTarget ) &&
			attacker.vexAdvantageTarget == defender.name
		) {
			autoAdvantage = true;
			attacker.vexAdvantageTarget = "";
		}
		// Weapon Mastery — Sap: a prior hit against the attacker with a Sap
		// weapon gives Disadvantage on this attack (consumed either way).
		if ( structKeyExists( attacker, "sapped" ) && attacker.sapped ) {
			autoDisadvantage = true;
			attacker.sapped = false;
		}
		arguments.atk.useAdvantage    = ( arguments.atk.advantage || autoAdvantage ) && !( arguments.atk.disadvantage || autoDisadvantage );
		arguments.atk.useDisadvantage = ( arguments.atk.disadvantage || autoDisadvantage ) && !( arguments.atk.advantage || autoAdvantage );
	}

	/**
	 * Stage 2 — the d20: Advantage/Disadvantage pair, Halfling Luck reroll on
	 * a natural 1, Archery style bonus, cover-adjusted AC, crit/fumble,
	 * Heroic Inspiration reroll on a miss, auto-crit against a Paralyzed/
	 * Unconscious melee target, and the defender's Parry reaction. Records
	 * everything later stages and both log lines need (roll/total/notes/
	 * mastery/actionPhrase) on `atk`.
	 */
	private function _rollToHit( atk ) {
		var attacker = arguments.atk.attacker;
		var defender = arguments.atk.defender;
		var weapon   = arguments.atk.weapon;

		var roll = randRange( 1, 20 );
		if ( arguments.atk.useAdvantage ) {
			roll = max( roll, randRange( 1, 20 ) );
		} else if ( arguments.atk.useDisadvantage ) {
			roll = min( roll, randRange( 1, 20 ) );
		}
		// Halfling Luck: a natural 1 can be rerolled, and the new roll must be used.
		var usedLuck = false;
		if ( roll == 1 && structKeyExists( attacker, "hasLuck" ) && attacker.hasLuck ) {
			roll = randRange( 1, 20 );
			usedLuck = true;
		}
		// Archery fighting style: +2 to attack rolls with Ranged weapons.
		var hasArchery = structKeyExists( attacker, "feats" ) && arrayFindNoCase( attacker.feats, "Archery" ) > 0;
		var styleBonus = ( hasArchery && weapon.category == "ranged" ) ? 2 : 0;
		var effectiveAC = defender.armorClass + arguments.atk.coverBonus;
		var total = roll + weapon.attackBonus + styleBonus;
		var isCrit = ( roll == 20 );
		var isFumble = ( roll == 1 );
		var hits = !isFumble && ( isCrit || total >= effectiveAC );

		// Human Heroic Inspiration: once per encounter, reroll a missed attack.
		var usedInspiration = false;
		if (
			!hits && structKeyExists( attacker, "hasHeroicInspiration" ) &&
			attacker.hasHeroicInspiration && !attacker.usedHeroicInspiration
		) {
			attacker.usedHeroicInspiration = true;
			usedInspiration = true;
			roll = randRange( 1, 20 );
			total = roll + weapon.attackBonus + styleBonus;
			isCrit = ( roll == 20 );
			isFumble = ( roll == 1 );
			hits = !isFumble && ( isCrit || total >= effectiveAC );
		}

		// Paralyzed/Unconscious: any melee hit against them is a Critical
		// Hit — simplified from the SRD's "within 5 feet" to "any melee
		// attack", since this app doesn't model reach weapons, so melee
		// already implies adjacency.
		if (
			hits && !isCrit && structKeyExists( weapon, "category" ) && weapon.category == "melee" &&
			( hasCondition( defender, "Paralyzed" ) || hasCondition( defender, "Unconscious" ) )
		) {
			isCrit = true;
		}

		// Parry (e.g. Bandit Captain/Erinyes): if adding the defender's parry
		// bonus to their AC would turn this hit into a miss, they spend their
		// Reaction to do so — can't help against a natural 20, which always
		// hits regardless of AC. Shares the same reactionUsed flag as
		// opportunity attacks (see checkOpportunityAttacks()), since a
		// creature only has one Reaction per round no matter the source.
		var usedParry = false;
		if (
			hits && !isCrit &&
			structKeyExists( weapon, "category" ) && weapon.category == "melee" &&
			structKeyExists( defender, "parryBonus" ) && defender.parryBonus > 0 &&
			!( structKeyExists( defender, "reactionUsed" ) && defender.reactionUsed ) &&
			total < effectiveAC + defender.parryBonus
		) {
			defender.reactionUsed = true;
			usedParry = true;
			hits = false;
		}

		// Weapon Mastery (Barbarian/Fighter/Paladin/Ranger/Rogue 1): only
		// usable with the class feature, and only if the weapon actually has
		// one of the 8 mastery properties (weapons.mastery — see
		// loadCharacter()'s inventory query).
		var hasWeaponMastery = (
			structKeyExists( attacker, "features" ) && arrayFindNoCase( attacker.features, "Weapon Mastery" ) > 0 &&
			structKeyExists( weapon, "mastery" ) && len( weapon.mastery )
		);

		arguments.atk.roll        = roll;
		arguments.atk.total       = total;
		arguments.atk.styleBonus  = styleBonus;
		arguments.atk.effectiveAC = effectiveAC;
		arguments.atk.isCrit      = isCrit;
		arguments.atk.hits        = hits;
		arguments.atk.mastery     = hasWeaponMastery ? weapon.mastery : "";
		arguments.atk.notes = "#arguments.atk.coverBonus > 0 ? ' (+' & arguments.atk.coverBonus & ' Cover)' : ''#" &
			"#arguments.atk.useDisadvantage ? ' (Disadvantage)' : ( arguments.atk.useAdvantage ? ' (Advantage)' : '' )#" &
			"#usedLuck ? ' (Lucky reroll)' : ''#" &
			"#styleBonus > 0 ? ' (Archery)' : ''#" &
			"#usedInspiration ? ' (Heroic Inspiration reroll)' : ''#";
		arguments.atk.parryNote = usedParry ? " (Parried!)" : "";
		// A monster's ranged attack drawn from a Spellcasting/Innate
		// Spellcasting trait (see _buildMonsterStruct()'s isSpell flagging)
		// reads as a cast, not a mundane weapon swing — cosmetic only, the
		// attack roll/damage math underneath is unchanged.
		arguments.atk.actionPhrase = ( structKeyExists( weapon, "isSpell" ) && weapon.isSpell )
			? "#attacker.name# casts #weapon.name# at #defender.name#"
			: "#attacker.name# attacks #defender.name# with #weapon.name#";
	}

	/**
	 * Miss handling — logs the miss and applies Weapon Mastery Graze, which
	 * still deals the attack's raw ability modifier as damage on a miss (not
	 * further modified by resistance/vulnerability nuance beyond immunity,
	 * to keep it the flat chip of damage it's meant to be).
	 */
	private function _logMissAndGraze( atk ) {
		var attacker = arguments.atk.attacker;
		var defender = arguments.atk.defender;
		var weapon   = arguments.atk.weapon;
		arguments.atk.log.prepend(
			"#arguments.atk.actionPhrase#: #arguments.atk.roll# + #weapon.attackBonus + arguments.atk.styleBonus# = #arguments.atk.total# vs AC #arguments.atk.effectiveAC##arguments.atk.notes##arguments.atk.parryNote#. Miss!"
		);
		if ( arguments.atk.mastery == "Graze" ) {
			var grazeDamage = max( 0, _weaponAbilityMod( attacker, weapon ) );
			if ( grazeDamage > 0 && !( structKeyExists( defender, "immunities" ) && arrayFindNoCase( defender.immunities, weapon.damageType ) ) ) {
				defender.hitPoints = max( 0, defender.hitPoints - grazeDamage );
				arguments.atk.log.prepend( "#attacker.name#'s Graze still grazes #defender.name# for #grazeDamage# #weapon.damageType# damage (#defender.hitPoints#/#defender.maxHitPoints# HP)." );
				checkConcentration( arguments.atk.log, defender, grazeDamage, arguments.atk.state );
				recordThreat( defender, attacker, grazeDamage );
			}
		}
	}

	/**
	 * Stage 3 — the damage roll: weapon dice (doubled on a crit), Half-Orc
	 * Savage Attacks' extra crit die, Great Weapon Fighting's minimum die
	 * face, the Savage Attacker feat's roll-twice-take-higher, the off-hand
	 * ability-modifier omission, once-per-turn Sneak Attack, and Rage's
	 * melee damage bonus. Records `atk.damage` plus the log annotations.
	 */
	private function _rollDamage( atk ) {
		var attacker = arguments.atk.attacker;
		var weapon   = arguments.atk.weapon;
		var isCrit   = arguments.atk.isCrit;

		var dice = variables.dice.parseDice( weapon.damageDice );
		var diceCount = dice.count * ( isCrit ? 2 : 1 );
		// Half-Orc Savage Attacks: one extra weapon damage die on a melee crit.
		var usedSavageAttacks = (
			isCrit && structKeyExists( weapon, "category" ) && weapon.category == "melee" &&
			structKeyExists( attacker, "hasSavageAttacks" ) && attacker.hasSavageAttacks
		);
		if ( usedSavageAttacks ) {
			diceCount += 1;
		}
		// Great Weapon Fighting: treat any 1 or 2 rolled on the weapon's damage
		// dice as a 3, for a Two-Handed or Versatile Melee weapon.
		var hasGreatWeaponFighting = structKeyExists( attacker, "feats" ) && arrayFindNoCase( attacker.feats, "Great Weapon Fighting" ) > 0;
		var usesGreatWeaponFighting = (
			hasGreatWeaponFighting && weapon.category == "melee" &&
			structKeyExists( weapon, "properties" ) &&
			( arrayFindNoCase( weapon.properties, "Two-Handed" ) > 0 || arrayFindNoCase( weapon.properties, "Versatile" ) > 0 )
		);
		var damageRoll = usesGreatWeaponFighting ? variables.dice.rollSumMinFace( diceCount, dice.sides, 3 ) : variables.dice.rollSum( diceCount, dice.sides );
		// Savage Attacker: once per turn, roll the weapon's damage dice twice
		// and use either roll — take the higher of the two.
		var usedSavageAttacker = false;
		if ( structKeyExists( attacker, "hasSavageAttacker" ) && attacker.hasSavageAttacker ) {
			var secondRoll = usesGreatWeaponFighting ? variables.dice.rollSumMinFace( diceCount, dice.sides, 3 ) : variables.dice.rollSum( diceCount, dice.sides );
			damageRoll = max( damageRoll, secondRoll );
			usedSavageAttacker = true;
		}
		// Two-Weapon Fighting off-hand attacks omit the ability modifier from
		// damage unless the attacker has the Two-Weapon Fighting feat.
		var damage = damageRoll + ( arguments.atk.omitDamageBonus ? 0 : weapon.damageBonus );
		var damageNotes = "#usedSavageAttacker ? ' (Savage Attacker)' : ''#" &
			"#usedSavageAttacks ? ' (Savage Attacks)' : ''#" &
			"#usesGreatWeaponFighting ? ' (Great Weapon Fighting)' : ''#";

		// Dueling: +2 damage while wielding this one-handed melee weapon
		// with no other weapon equipped (a shield doesn't disqualify it —
		// only a second weapon does). Naturally excludes an off-hand
		// attack, since the main weapon is then "another weapon equipped."
		var hasDueling = structKeyExists( attacker, "feats" ) && arrayFindNoCase( attacker.feats, "Dueling" ) > 0;
		var usesDueling = (
			hasDueling && weapon.category == "melee" &&
			!( structKeyExists( weapon, "properties" ) && arrayFindNoCase( weapon.properties, "Two-Handed" ) > 0 ) &&
			_hasEmptyOffHand( attacker, weapon )
		);
		if ( usesDueling ) {
			damage += 2;
			damageNotes &= " +2 Dueling";
		}

		// Thrown Weapon Fighting: +2 damage on a ranged attack with a
		// weapon that has the Thrown property (stored as one token like
		// "Thrown (Range 20/60)", not a clean "Thrown" entry).
		var hasThrownWeaponFighting = structKeyExists( attacker, "feats" ) && arrayFindNoCase( attacker.feats, "Thrown Weapon Fighting" ) > 0;
		var usesThrownWeaponFighting = (
			hasThrownWeaponFighting && weapon.category == "ranged" &&
			structKeyExists( weapon, "properties" ) && _hasThrownProperty( weapon )
		);
		if ( usesThrownWeaponFighting ) {
			damage += 2;
			damageNotes &= " +2 Thrown Weapon Fighting";
		}

		// Sneak Attack (Rogue 1): once per turn, on a hit with a Finesse or
		// ranged weapon made with Advantage, extra ceil(level/2)d6 damage
		// (doubled on a Critical Hit, same as the weapon's own dice). RAW also
		// allows it without Advantage if another of the target's enemies is
		// within 5 ft. of it — simplified away here (not modeled without
		// giving resolveAttack full battlefield adjacency), so in practice
		// this only triggers via an existing Advantage source (a Restrained/
		// Blinded/helpless/Prone-in-melee target, Pack Tactics, etc.).
		var hasSneakAttack = structKeyExists( attacker, "features" ) && arrayFindNoCase( attacker.features, "Sneak Attack" ) > 0;
		var usedSneakAttack = (
			hasSneakAttack && arguments.atk.useAdvantage &&
			!( structKeyExists( attacker, "usedSneakAttackThisTurn" ) && attacker.usedSneakAttackThisTurn ) &&
			( weapon.category == "ranged" || ( structKeyExists( weapon, "properties" ) && arrayFindNoCase( weapon.properties, "Finesse" ) > 0 ) )
		);
		if ( usedSneakAttack ) {
			var sneakDiceCount = ceiling( attacker.level / 2 ) * ( isCrit ? 2 : 1 );
			var sneakDamage = variables.dice.rollSum( sneakDiceCount, 6 );
			damage += sneakDamage;
			attacker.usedSneakAttackThisTurn = true;
			damageNotes &= " +#sneakDamage# Sneak Attack";
		}

		// Rage (Barbarian): +2/+3/+4 (by level) to melee weapon damage while
		// raging — RAW ties this to Strength-based attacks specifically; this
		// app doesn't track which ability a Finesse weapon attack actually
		// used, so it's simplified to "any melee weapon while raging."
		if ( structKeyExists( attacker, "isRaging" ) && attacker.isRaging && weapon.category == "melee" ) {
			var rageBonus = _rageDamageBonus( attacker.level );
			damage += rageBonus;
			damageNotes &= " +#rageBonus# Rage";
		}

		arguments.atk.damage      = damage;
		arguments.atk.damageNotes = damageNotes;
	}

	/**
	 * Stage 4 — applies `atk.damage` through the defender's Immunity/
	 * Vulnerability/Resistance (and Petrified's resist-everything), subtracts
	 * HP, breaks Concentration, records threat, and writes the hit log line.
	 */
	private function _applyDamage( atk ) {
		var attacker = arguments.atk.attacker;
		var defender = arguments.atk.defender;
		var weapon   = arguments.atk.weapon;
		var damage   = arguments.atk.damage;

		if ( structKeyExists( defender, "immunities" ) && arrayFindNoCase( defender.immunities, weapon.damageType ) ) {
			damage = 0;
		} else {
			if ( structKeyExists( defender, "vulnerabilities" ) && arrayFindNoCase( defender.vulnerabilities, weapon.damageType ) ) {
				damage *= 2;
			}
			if ( structKeyExists( defender, "resistances" ) && arrayFindNoCase( defender.resistances, weapon.damageType ) ) {
				damage = int( damage / 2 );
			}
			// Petrified: resistance to all damage, regardless of type.
			if ( hasCondition( defender, "Petrified" ) ) {
				damage = int( damage / 2 );
			}
		}
		arguments.atk.damage = damage;

		defender.hitPoints = max( 0, defender.hitPoints - damage );
		checkConcentration( arguments.atk.log, defender, damage, arguments.atk.state );
		recordThreat( defender, attacker, damage );

		arguments.atk.log.prepend(
			"#arguments.atk.actionPhrase#: #arguments.atk.roll# + #weapon.attackBonus + arguments.atk.styleBonus# = #arguments.atk.total# vs AC #arguments.atk.effectiveAC##arguments.atk.notes#. " &
			( arguments.atk.isCrit ? "Critical hit! " : "Hit! " ) &
			"#damage# #weapon.damageType# damage#arguments.atk.damageNotes# (#defender.hitPoints#/#defender.maxHitPoints# HP)."
		);
	}

	/**
	 * Stage 5 — post-hit Weapon Mastery riders (Sap/Vex/Slow/Topple/Push/
	 * Cleave); none of them change the damage number already logged.
	 */
	private function _applyMasteryRiders( atk ) {
		var attacker = arguments.atk.attacker;
		var defender = arguments.atk.defender;
		var mastery  = arguments.atk.mastery;
		if ( mastery == "Sap" ) {
			defender.sapped = true;
			arguments.atk.log.prepend( "#defender.name# is Sapped — Disadvantage on their next attack roll." );
		}
		if ( mastery == "Vex" ) {
			attacker.vexAdvantageTarget = defender.name;
			arguments.atk.log.prepend( "#attacker.name# gains Advantage on their next attack against #defender.name# (Vex)." );
		}
		if ( mastery == "Slow" && arguments.atk.damage > 0 ) {
			defender.speedPenalty = ( structKeyExists( defender, "speedPenalty" ) ? defender.speedPenalty : 0 ) + 10;
			arguments.atk.log.prepend( "#defender.name#'s Speed is reduced by 10 ft. (Slow)." );
		}
		if ( mastery == "Topple" ) {
			var toppleDC = 8 + attacker.proficiencyBonus + _weaponAbilityMod( attacker, arguments.atk.weapon );
			var toppleSave = rollSavingThrow( combatant = defender, ability = "con", dc = toppleDC, state = arguments.atk.state );
			if ( !toppleSave.success ) {
				addCondition( defender, "Prone" );
				arguments.atk.log.prepend( "#defender.name# fails a DC #toppleDC# Constitution save and topples Prone!" );
			} else {
				arguments.atk.log.prepend( "#defender.name# succeeds on a DC #toppleDC# Constitution save and stays upright (Topple)." );
			}
		}
		if ( mastery == "Push" && !isNull( variables.grid.stateGrid( arguments.atk.state ) ) ) {
			_applyWeaponMasteryPush( arguments.atk.log, attacker, defender, variables.grid.stateGrid( arguments.atk.state ) );
		}
		if ( mastery == "Cleave" && arguments.atk.weapon.category == "melee" && ( structKeyExists( arguments.atk.state, "opponent" ) || structKeyExists( arguments.atk.state, "opponents" ) ) ) {
			_applyWeaponMasteryCleave( arguments.atk.state, attacker, defender, arguments.atk.weapon, arguments.atk.damage );
		}
	}

	/**
	 * The ability modifier a weapon attack actually uses: Dexterity for a
	 * ranged weapon, the higher of Strength/Dexterity for a Finesse weapon,
	 * Strength otherwise. Used by Weapon Mastery's Graze (miss damage) and
	 * Topple (save DC), which both need the raw modifier rather than the
	 * already-computed `weapon.attackBonus` (which also bakes in Proficiency
	 * Bonus and any magic bonus).
	 */
	private function _weaponAbilityMod( attacker, weapon ) {
		if ( !structKeyExists( arguments.attacker, "modifiers" ) ) {
			return 0;
		}
		var mods = arguments.attacker.modifiers;
		var isFinesse = structKeyExists( arguments.weapon, "properties" ) && arrayFindNoCase( arguments.weapon.properties, "Finesse" ) > 0;
		if ( isFinesse ) {
			return max( mods.str, mods.dex );
		}
		return ( arguments.weapon.category == "ranged" ) ? mods.dex : mods.str;
	}

	/**
	 * Weapon Mastery — Push: shoves `defender` 2 squares (10 ft.) directly
	 * away from `attacker`, stopping early if a wall or another living
	 * combatant blocks the path (RAW's "Large or smaller" size restriction
	 * isn't modeled — this app doesn't track combatant size). A no-op if
	 * attacker and defender occupy the same square (can't compute a direction).
	 */
	private function _applyWeaponMasteryPush( log, attacker, defender, grid ) {
		var dx = arguments.defender.position.x - arguments.attacker.position.x;
		var dy = arguments.defender.position.y - arguments.attacker.position.y;
		if ( dx == 0 && dy == 0 ) {
			return;
		}
		var stepX = ( dx > 0 ) ? 1 : ( dx < 0 ? -1 : 0 );
		var stepY = ( dy > 0 ) ? 1 : ( dy < 0 ? -1 : 0 );
		var pushed = 0;
		for ( var i = 1; i <= 2; i++ ) {
			var nextX = arguments.defender.position.x + stepX;
			var nextY = arguments.defender.position.y + stepY;
			if ( !variables.grid.isWalkable( arguments.grid, nextX, nextY ) ) {
				break;
			}
			arguments.defender.position = { "x": nextX, "y": nextY };
			pushed += 1;
		}
		if ( pushed > 0 ) {
			arguments.log.prepend( "#arguments.defender.name# is pushed #pushed * 5# ft. away (Push)." );
		}
	}

	/**
	 * Weapon Mastery — Cleave: a melee hit also strikes one other living
	 * hostile within reach (1 square) of the original target, using the same
	 * attack roll (no second roll) and the same damage number already dealt
	 * to the first target, adjusted for the second target's own immunity/
	 * vulnerability/resistance (see applyDamageModifiers()).
	 */
	private function _applyWeaponMasteryCleave( state, attacker, defender, weapon, damage ) {
		for ( var other in stateOpponents( arguments.state ) ) {
			if (
				other.hitPoints <= 0 || other.name == arguments.defender.name ||
				variables.grid.chebyshev( arguments.defender, other ) > 1
			) {
				continue;
			}
			var cleaveDamage = applyDamageModifiers( other, arguments.damage, arguments.weapon.damageType );
			other.hitPoints = max( 0, other.hitPoints - cleaveDamage );
			arguments.state.log.prepend(
				"#arguments.attacker.name#'s Cleave also strikes #other.name# for #cleaveDamage# #arguments.weapon.damageType# damage (#other.hitPoints#/#other.maxHitPoints# HP)."
			);
			checkConcentration( arguments.state.log, other, cleaveDamage, arguments.state );
			recordThreat( other, arguments.attacker, cleaveDamage );
			checkDefenderDefeated( arguments.state, arguments.attacker, other, false );
			return;
		}
	}

	/**
	 * Returns `combatant`'s off-hand Light weapon for a Two-Weapon Fighting
	 * off-hand attack — requires the equipped melee weapon to also have the
	 * Light property. The off-hand candidate is either a second copy of that
	 * same weapon (e.g. two Daggers, tracked via inventory `quantity`), or any
	 * other Light-property item carried (e.g. a Dagger filed under "ranged"
	 * for its Thrown use, held in the off hand alongside a Shortsword).
	 * Returns null if no such weapon is available.
	 */
	function offHandWeapon( combatant ) {
		var mainMelee = equippedWeapon( arguments.combatant, "melee" );
		if ( isNull( mainMelee ) || !structKeyExists( mainMelee, "properties" ) || arrayFindNoCase( mainMelee.properties, "Light" ) == 0 ) {
			return javaCast( "null", 0 );
		}

		for ( var item in arguments.combatant.inventory ) {
			if ( !structKeyExists( item, "properties" ) || arrayFindNoCase( item.properties, "Light" ) == 0 ) {
				continue;
			}
			if ( item.id == mainMelee.id ) {
				if ( structKeyExists( item, "quantity" ) && item.quantity >= 2 ) {
					return item;
				}
				continue;
			}
			return item;
		}
		return javaCast( "null", 0 );
	}

	/**
	 * Dueling's "no other weapons" check: true when no equipped melee
	 * inventory item other than `mainWeapon` itself is also wielded. Scoped
	 * to melee only — a stowed ranged weapon (a bow slung on your back, a
	 * javelin quiver) isn't "in your other hand," same implicit model
	 * offHandWeapon() already uses. Deliberately not the same test as
	 * offHandWeapon() (which requires a Light second weapon specifically)
	 * — Dueling cares about a fully empty off-hand, not whether a
	 * Two-Weapon-Fighting-eligible pair happens to be equipped. A shield is
	 * armor, not a weapon, so it never disqualifies Dueling.
	 */
	private function _hasEmptyOffHand( attacker, mainWeapon ) {
		var mainId = structKeyExists( arguments.mainWeapon, "id" ) ? arguments.mainWeapon.id : javaCast( "null", 0 );
		for ( var item in arguments.attacker.inventory ) {
			if ( item.category != "melee" || !( structKeyExists( item, "equipped" ) && item.equipped ) ) {
				continue;
			}
			// Skip the main weapon's own inventory entry (matched by id when
			// both sides have one); anything else equipped counts as "another
			// weapon," including when either side lacks an id to compare —
			// safer to assume it's different than to risk a false Dueling grant.
			if ( !isNull( mainId ) && structKeyExists( item, "id" ) && item.id == mainId ) {
				continue;
			}
			return false;
		}
		return true;
	}

	/**
	 * True if any of `weapon.properties` carries the Thrown property — each
	 * entry is stored with its range baked in (e.g. "Thrown (Range 20/60)"),
	 * not a clean "Thrown" token, so this can't use the usual
	 * arrayFindNoCase() exact-match check the other property flags use.
	 */
	private function _hasThrownProperty( weapon ) {
		for ( var prop in arguments.weapon.properties ) {
			if ( findNoCase( "Thrown", prop ) == 1 ) {
				return true;
			}
		}
		return false;
	}

	/**
	 * Two-Weapon Fighting: makes a bonus-action off-hand attack with a second
	 * Light Melee weapon, once per turn. Requires the attacker's main equipped
	 * melee weapon to also have the Light property, and to be adjacent to the
	 * opponent. Without the Two-Weapon Fighting feat, the off-hand attack
	 * doesn't add the ability modifier to damage, per the core rules.
	 *
	 * @state The encounter's full mutable game state struct.
	 */
	function offHandAttack( state ) {
		var attacker = arguments.state.player;
		var defender = arguments.state.opponent;

		var mainWeapon = equippedWeapon( attacker, "melee" );
		// Weapon Mastery — Nick: once per turn, the off-hand attack doesn't
		// cost the bonus action (still requires the Attack action to have
		// been taken, and a Light off-hand weapon, same as normal).
		var usesNick = (
			!isNull( mainWeapon ) && structKeyExists( mainWeapon, "mastery" ) && mainWeapon.mastery == "Nick" &&
			structKeyExists( attacker, "features" ) && arrayFindNoCase( attacker.features, "Weapon Mastery" ) > 0 &&
			!( structKeyExists( attacker, "usedNickThisTurn" ) && attacker.usedNickThisTurn )
		);
		if ( !usesNick && structKeyExists( arguments.state, "bonusActionUsed" ) && arguments.state.bonusActionUsed ) {
			return;
		}

		var offhand = offHandWeapon( attacker );
		if (
			isNull( mainWeapon ) || isNull( offhand ) ||
			!structKeyExists( mainWeapon, "properties" ) || arrayFindNoCase( mainWeapon.properties, "Light" ) == 0
		) {
			arguments.state.log.prepend( "#attacker.name# needs a second Light weapon to make an off-hand attack." );
			return;
		}
		if ( variables.grid.chebyshev( attacker, defender ) > 1 ) {
			arguments.state.log.prepend( "#attacker.name# is too far away to make an off-hand attack." );
			return;
		}

		if ( usesNick ) {
			attacker.usedNickThisTurn = true;
		} else {
			arguments.state.bonusActionUsed = true;
		}
		var hasTwoWeaponFighting = structKeyExists( attacker, "feats" ) && arrayFindNoCase( attacker.feats, "Two-Weapon Fighting" ) > 0;
		resolveAttack( arguments.state.log, attacker, defender, offhand, false, false, !hasTwoWeaponFighting, 0, arguments.state );

		if ( defender.hitPoints <= 0 ) {
			if ( !structKeyExists( defender, "xpAwarded" ) || !defender.xpAwarded ) {
				defender.xpAwarded = true;
				variables.progression.awardPartyExperience( arguments.state, defender.xp );
				variables.progression.incrementCharacterStat( attacker.characterId, "monsters_killed" );
				attacker.monstersKilled = ( structKeyExists( attacker, "monstersKilled" ) ? attacker.monstersKilled : 0 ) + 1;
				if ( structKeyExists( arguments.state, "round" ) ) {
					defender.defeatedAtRound = arguments.state.round;
				}
			}
			if ( allOpponentsDefeated( arguments.state ) ) {
				arguments.state.gameOver = true;
				arguments.state.outcome = "victory";
				arguments.state.log.prepend( "#defender.name# collapses into a pile of bones. Victory!" );
			} else {
				arguments.state.log.prepend( "#defender.name# collapses into a pile of bones!" );
				retargetIfCurrentOpponentDefeated( arguments.state );
			}
		}
	}

	/**
	 * Paladin's Smite (level 2): makes one melee weapon attack (spending the
	 * Attack action, same as playerAttack()) and, only if it actually hits
	 * (the opponent's Hit Points went down), spends a spell slot at
	 * `slotLevel` to add Divine Smite's bonus Radiant damage — 2d8 for a
	 * 1st-level slot, +1d8 per level above 1st (capped at 5d8), +1 further
	 * d8 if the target is a Fiend or Undead. No slot is spent on a miss.
	 *
	 * Simplified from the real 2024 rule (which lets you decide to smite
	 * *after* seeing the attack roll, even choosing not to on a miss to
	 * save the slot) into "commit to smiting before you know if you'll
	 * hit" — functionally identical in outcome (a miss never costs a slot
	 * either way), just without a separate post-roll prompt this app's
	 * turn structure doesn't have anywhere else either.
	 *
	 * @state The encounter's full mutable game state struct.
	 * @slotLevel The spell slot level to spend if the attack hits.
	 */
	function smiteAttack( state, slotLevel ) {
		var player = arguments.state.player;
		var opponent = arguments.state.opponent;
		if (
			player.hitPoints <= 0 || isIncapacitated( player ) ||
			!structKeyExists( player, "features" ) || arrayFindNoCase( player.features, "Paladin's Smite" ) == 0 ||
			!structKeyExists( player, "spellSlots" ) || !structKeyExists( player.spellSlots, arguments.slotLevel ) ||
			player.spellSlots[ arguments.slotLevel ] <= 0
		) {
			return;
		}
		var weapon = equippedWeapon( player, "melee" );
		if ( isNull( weapon ) ) {
			arguments.state.log.prepend( "#player.name# has no melee weapon to Smite with." );
			return;
		}

		var hpBefore = opponent.hitPoints;
		playerAttack( arguments.state, weapon, false );

		if ( !arguments.state.gameOver && opponent.hitPoints < hpBefore ) {
			player.spellSlots[ arguments.slotLevel ] -= 1;
			if ( !structKeyExists( player, "spentSpellSlots" ) ) {
				player.spentSpellSlots = {};
			}
			var lvlKey = toString( arguments.slotLevel );
			player.spentSpellSlots[ lvlKey ] = ( player.spentSpellSlots.keyExists( lvlKey ) ? player.spentSpellSlots[ lvlKey ] : 0 ) + 1;

			var isFiendOrUndead = structKeyExists( opponent, "creatureType" ) && arrayFindNoCase( [ "Fiend", "Undead" ], opponent.creatureType ) > 0;
			var diceCount = min( arguments.slotLevel + 1, 5 ) + ( isFiendOrUndead ? 1 : 0 );
			var smiteDamage = applyDamageModifiers( opponent, variables.dice.rollSum( diceCount, 8 ), "Radiant" );
			opponent.hitPoints = max( 0, opponent.hitPoints - smiteDamage );
			recordThreat( opponent, player, smiteDamage );
			arguments.state.log.prepend(
				"#player.name# calls down Divine Smite (spends a level-#arguments.slotLevel# slot)#( isFiendOrUndead ? ' against the #opponent.creatureType#' : '' )#: " &
				"#smiteDamage# Radiant damage (#opponent.hitPoints#/#opponent.maxHitPoints# HP)."
			);
			checkDefenderDefeated( arguments.state, player, opponent, false );
		}
	}

	/**
	 * Paladin's Aura of Protection (class_features: "Aura of Protection", level
	 * 6): the highest Charisma modifier (minimum +1) among every conscious,
	 * non-incapacitated Paladin within the aura — 2 squares (10 ft.), or 6
	 * squares (30 ft.) once the Paladin also has "Aura Expansion" (level 18) —
	 * of `target`, including the Paladin's own square (self-buff) and a downed
	 * ally (who still needs the bonus on their death saves). Only ever applies
	 * to a party member (`target` has a characterId) — monsters never benefit.
	 * Multiple qualifying Paladins don't stack; only the best applies, per the
	 * SRD ("a creature can benefit from only one Aura of Protection at a time").
	 */
	private function _auraOfProtectionBonus( state, target ) {
		if ( !structKeyExists( arguments.target, "characterId" ) ) {
			return 0;
		}
		var candidates = structKeyExists( arguments.state, "players" ) ? arguments.state.players
			: ( structKeyExists( arguments.state, "player" ) ? [ arguments.state.player ] : [] );
		var best = 0;
		for ( var member in candidates ) {
			if (
				member.hitPoints <= 0 || isIncapacitated( member ) ||
				!structKeyExists( member, "features" ) || arrayFindNoCase( member.features, "Aura of Protection" ) == 0
			) {
				continue;
			}
			var radiusSquares = ( arrayFindNoCase( member.features, "Aura Expansion" ) > 0 ) ? 6 : 2;
			if ( variables.grid.chebyshev( member, arguments.target ) > radiusSquares ) {
				continue;
			}
			var chaMod = structKeyExists( member, "modifiers" ) ? member.modifiers.cha : 0;
			best = max( best, max( 1, chaMod ) );
		}
		return best;
	}

	/**
	 * General d20-vs-DC saving throw: ability modifier plus Proficiency Bonus
	 * if the combatant is proficient in that save. Grants Advantage for Fey
	 * Ancestry (Elf) against the Charmed condition, for Gnomish Cunning (Gnome)
	 * against magical Intelligence/Wisdom/Charisma saves, for Magic Resistance
	 * against any magical save, and for Rage on Strength saves. Grants
	 * Disadvantage for Restrained specifically on Dexterity saves (Advantage
	 * and Disadvantage cancel if both apply). Paralyzed/Petrified/Stunned/
	 * Unconscious auto-fail any Strength or Dexterity save with no roll. Adds
	 * a nearby Paladin's Aura of Protection bonus, if any — see
	 * _auraOfProtectionBonus().
	 *
	 * @combatant The saving combatant (has `abilityScores` and, ideally, `modifiers`/`proficiencyBonus`/`savingThrowProficiencies`).
	 * @ability One of "str","dex","con","int","wis","cha".
	 * @dc The Difficulty Class to meet or beat.
	 * @condition Optional: the condition being saved against (e.g. "Charmed"), for Fey Ancestry.
	 * @isMagical Optional: whether this save is against a magical effect, for Gnomish Cunning and Magic Resistance.
	 * @coverBonus Optional: Half/Three-Quarters Cover bonus added to a Dexterity save against an area effect.
	 * @state Optional: the encounter's full mutable game state struct, for Aura of Protection lookup.
	 */
	function rollSavingThrow( combatant, ability, dc, condition = "", isMagical = false, coverBonus = 0, state = {} ) {
		// Paralyzed/Petrified/Stunned/Unconscious: automatically fails any
		// Strength or Dexterity saving throw, no roll needed.
		if ( listFindNoCase( "str,dex", arguments.ability ) && isHelpless( arguments.combatant ) ) {
			return { "roll": 1, "total": 1, "success": false, "hadAdvantage": false, "hadDisadvantage": false };
		}
		// Monsters carry their SRD stat block's saving throw bonus pre-computed
		// per ability (modifier + proficiency bonus already summed, straight
		// from the monsters table's str_save/dex_save/etc. columns — see
		// _buildMonsterStruct()) rather than separate proficiency flags like
		// the player has, since that's the shape the source data comes in.
		var abilityMod;
		var proficiencyBonus = 0;
		if ( structKeyExists( arguments.combatant, "savingThrowBonuses" ) ) {
			abilityMod = arguments.combatant.savingThrowBonuses[ arguments.ability ];
		} else {
			abilityMod = structKeyExists( arguments.combatant, "modifiers" )
				? arguments.combatant.modifiers[ arguments.ability ]
				: variables.rules.abilityModifier( arguments.combatant.abilityScores[ arguments.ability ] );

			var proficient = (
				structKeyExists( arguments.combatant, "savingThrowProficiencies" ) &&
				arrayFindNoCase( arguments.combatant.savingThrowProficiencies, variables.rules.abilityFullName( arguments.ability ) ) > 0
			);
			proficiencyBonus = ( proficient && structKeyExists( arguments.combatant, "proficiencyBonus" ) ) ? arguments.combatant.proficiencyBonus : 0;
		}

		var hasAdvantage = false;
		if ( arguments.condition == "Charmed" && structKeyExists( arguments.combatant, "hasFeyAncestry" ) && arguments.combatant.hasFeyAncestry ) {
			hasAdvantage = true;
		}
		if (
			arguments.isMagical && listFindNoCase( "int,wis,cha", arguments.ability ) &&
			structKeyExists( arguments.combatant, "hasGnomishCunning" ) && arguments.combatant.hasGnomishCunning
		) {
			hasAdvantage = true;
		}
		// Magic Resistance (e.g. many demons/devils/dragons): Advantage on
		// saving throws against spells and other magical effects — any
		// ability, not just Int/Wis/Cha like Gnomish Cunning.
		if (
			arguments.isMagical &&
			structKeyExists( arguments.combatant, "hasMagicResistance" ) && arguments.combatant.hasMagicResistance
		) {
			hasAdvantage = true;
		}
		// Rage: Advantage on Strength saving throws while raging.
		if ( arguments.ability == "str" && structKeyExists( arguments.combatant, "isRaging" ) && arguments.combatant.isRaging ) {
			hasAdvantage = true;
		}
		// Restrained: Disadvantage specifically on Dexterity saves.
		var hasDisadvantage = ( arguments.ability == "dex" ) && hasCondition( arguments.combatant, "Restrained" );

		var useAdvantage = hasAdvantage && !hasDisadvantage;
		var useDisadvantage = hasDisadvantage && !hasAdvantage;

		var roll = randRange( 1, 20 );
		if ( useAdvantage ) {
			roll = max( roll, randRange( 1, 20 ) );
		} else if ( useDisadvantage ) {
			roll = min( roll, randRange( 1, 20 ) );
		}
		// Cover (Half/Three-Quarters) also applies to Dexterity saves against
		// area effects, per the "Cover" rules — this app only models Half Cover.
		var coverAdjustment = ( arguments.ability == "dex" ) ? arguments.coverBonus : 0;
		var auraBonus = _auraOfProtectionBonus( arguments.state, arguments.combatant );
		var total = roll + abilityMod + proficiencyBonus + coverAdjustment + auraBonus;
		return { "roll": roll, "total": total, "success": ( total >= arguments.dc ), "hadAdvantage": useAdvantage, "hadDisadvantage": useDisadvantage, "auraBonus": auraBonus };
	}

	/**
	 * Attempts to grapple `defender` (a contested Strength (Athletics) check
	 * vs. the defender's better of Strength (Athletics) or Dexterity
	 * (Acrobatics) — Proficiency Bonus applies on either side only if that
	 * combatant is actually proficient in the relevant skill, per
	 * variables.rules.skillProficiencyBonus()), spending the attacker's action. Requires the
	 * attacker to already be adjacent. On success, marks `defender.
	 * grappledBy` (subsequent attacks by the same attacker get Advantage if
	 * the attacker has the Grappler feat) and applies the Restrained
	 * condition — a grappled creature is Restrained per the core rules,
	 * which also grants Advantage to anyone attacking it, not just the
	 * Grappler-feat attacker, and Disadvantage on the grappled creature's own
	 * attacks and Dexterity saves.
	 *
	 * @state The encounter's full mutable game state struct.
	 * @attacker The grappling combatant.
	 * @defender The combatant being grappled.
	 */
	function attemptGrapple( state, attacker, defender ) {
		if ( variables.grid.chebyshev( arguments.attacker, arguments.defender ) > 1 ) {
			arguments.state.log.prepend( "#arguments.attacker.name# is too far away to grapple #arguments.defender.name#." );
			return;
		}

		var attackerStrMod = structKeyExists( arguments.attacker, "modifiers" ) ? arguments.attacker.modifiers.str : variables.rules.abilityModifier( arguments.attacker.abilityScores.str );
		var defenderStrMod = structKeyExists( arguments.defender, "modifiers" ) ? arguments.defender.modifiers.str : variables.rules.abilityModifier( arguments.defender.abilityScores.str );
		var defenderDexMod = structKeyExists( arguments.defender, "modifiers" ) ? arguments.defender.modifiers.dex : variables.rules.abilityModifier( arguments.defender.abilityScores.dex );

		var attackerRoll = randRange( 1, 20 ) + attackerStrMod + variables.rules.skillProficiencyBonus( arguments.attacker, "Athletics" );
		var defenderAthleticsRoll = defenderStrMod + variables.rules.skillProficiencyBonus( arguments.defender, "Athletics" );
		var defenderAcrobaticsRoll = defenderDexMod + variables.rules.skillProficiencyBonus( arguments.defender, "Acrobatics" );
		var defenderRoll = randRange( 1, 20 ) + max( defenderAthleticsRoll, defenderAcrobaticsRoll );
		var success = attackerRoll >= defenderRoll;

		arguments.state.actionUsed = true;
		if ( success ) {
			arguments.defender.grappledBy = arguments.attacker.name;
			addCondition( arguments.defender, "Restrained" );
		}

		arguments.state.log.prepend(
			"#arguments.attacker.name# attempts to grapple #arguments.defender.name#: #attackerRoll# vs #defenderRoll# — " &
			( success ? "Grappled!" : "#arguments.defender.name# resists." )
		);
	}

	/**
	 * Attempts to shove `defender` prone (a contested Strength (Athletics)
	 * check vs. the defender's better of Strength (Athletics) or Dexterity
	 * (Acrobatics), simplified the same way as attemptGrapple — Proficiency
	 * Bonus only applies where each combatant is actually proficient),
	 * spending the attacker's action. Requires the attacker to already be
	 * adjacent. On success, applies the Prone condition — melee attacks
	 * against a Prone target get Advantage, ranged ones get Disadvantage,
	 * and the Prone creature's own attacks have Disadvantage until it stands
	 * back up (this app has no stand-up action yet, so Prone otherwise
	 * persists for the fight once applied).
	 *
	 * @state The encounter's full mutable game state struct.
	 * @attacker The shoving combatant.
	 * @defender The combatant being shoved.
	 */
	function attemptShove( state, attacker, defender ) {
		if ( variables.grid.chebyshev( arguments.attacker, arguments.defender ) > 1 ) {
			arguments.state.log.prepend( "#arguments.attacker.name# is too far away to shove #arguments.defender.name#." );
			return;
		}

		var attackerStrMod = structKeyExists( arguments.attacker, "modifiers" ) ? arguments.attacker.modifiers.str : variables.rules.abilityModifier( arguments.attacker.abilityScores.str );
		var defenderStrMod = structKeyExists( arguments.defender, "modifiers" ) ? arguments.defender.modifiers.str : variables.rules.abilityModifier( arguments.defender.abilityScores.str );
		var defenderDexMod = structKeyExists( arguments.defender, "modifiers" ) ? arguments.defender.modifiers.dex : variables.rules.abilityModifier( arguments.defender.abilityScores.dex );

		var attackerRoll = randRange( 1, 20 ) + attackerStrMod + variables.rules.skillProficiencyBonus( arguments.attacker, "Athletics" );
		var defenderAthleticsRoll = defenderStrMod + variables.rules.skillProficiencyBonus( arguments.defender, "Athletics" );
		var defenderAcrobaticsRoll = defenderDexMod + variables.rules.skillProficiencyBonus( arguments.defender, "Acrobatics" );
		var defenderRoll = randRange( 1, 20 ) + max( defenderAthleticsRoll, defenderAcrobaticsRoll );
		var success = attackerRoll >= defenderRoll;

		arguments.state.actionUsed = true;
		if ( success ) {
			addCondition( arguments.defender, "Prone" );
		}

		arguments.state.log.prepend(
			"#arguments.attacker.name# attempts to shove #arguments.defender.name#: #attackerRoll# vs #defenderRoll# — " &
			( success ? "Knocked Prone!" : "#arguments.defender.name# resists." )
		);
	}

	/**
	 * Dragonborn Breath Weapon: once per encounter, exhale a blast that deals
	 * 2d6 damage (of the character's draconic ancestry's type — simplified to
	 * Fire here, since ancestry choice isn't tracked) to the opponent, who
	 * makes a Dexterity save (DC 8 + Proficiency Bonus + Constitution modifier)
	 * for half damage. Spends the attacker's action.
	 *
	 * @state The encounter's full mutable game state struct.
	 */
	function useBreathWeapon( state ) {
		var attacker = arguments.state.player;
		var defender = arguments.state.opponent;
		if ( !structKeyExists( attacker, "hasBreathWeapon" ) || !attacker.hasBreathWeapon || attacker.usedBreathWeapon ) {
			return;
		}

		attacker.usedBreathWeapon = true;
		arguments.state.actionUsed = true;

		var dc = 8 + attacker.proficiencyBonus + attacker.modifiers.con;
		var defenderDexMod = structKeyExists( defender, "modifiers" ) ? defender.modifiers.dex : variables.rules.abilityModifier( defender.abilityScores.dex );
		var saveRoll = randRange( 1, 20 ) + defenderDexMod;
		var saved = ( saveRoll >= dc );

		var damage = variables.dice.rollSum( 2, 6 );
		if ( saved ) {
			damage = int( damage / 2 );
		}
		if ( structKeyExists( defender, "immunities" ) && arrayFindNoCase( defender.immunities, "Fire" ) ) {
			damage = 0;
		} else {
			if ( structKeyExists( defender, "vulnerabilities" ) && arrayFindNoCase( defender.vulnerabilities, "Fire" ) ) {
				damage *= 2;
			}
			if ( structKeyExists( defender, "resistances" ) && arrayFindNoCase( defender.resistances, "Fire" ) ) {
				damage = int( damage / 2 );
			}
		}

		defender.hitPoints = max( 0, defender.hitPoints - damage );
		checkConcentration( arguments.state.log, defender, damage, arguments.state );
		recordThreat( defender, attacker, damage );
		arguments.state.log.prepend(
			"#attacker.name# exhales a blast of fire! #defender.name# rolls a DC #dc# Dexterity save: #saveRoll# — " &
			( saved ? "succeeds, takes half damage. " : "fails! " ) &
			"#damage# Fire damage (#defender.hitPoints#/#defender.maxHitPoints# HP)."
		);
		checkDefenderDefeated( arguments.state, attacker, defender, false );
	}

	/**
	 * Spends the lowest available spell slot at or above `minimumLevel`.
	 * Returns the slot level spent, or 0 if none are available.
	 */
	private function _spendSpellSlot( player, minimumLevel ) {
		for ( var level = arguments.minimumLevel; level <= 9; level++ ) {
			if ( structKeyExists( arguments.player.spellSlots, level ) && arguments.player.spellSlots[ level ] > 0 ) {
				arguments.player.spellSlots[ level ] -= 1;
				if ( !structKeyExists( arguments.player, "spentSpellSlots" ) ) {
					arguments.player.spentSpellSlots = {};
				}
				var lvlKey = toString( level );
				arguments.player.spentSpellSlots[ lvlKey ] = ( arguments.player.spentSpellSlots.keyExists( lvlKey ) ? arguments.player.spentSpellSlots[ lvlKey ] : 0 ) + 1;
				return level;
			}
		}
		return 0;
	}

	/**
	 * True if `combatant` could actually cast a spell right now — a slot at
	 * or above `minimumLevel`, or an unused Magic Initiate bonus spell.
	 * Doesn't spend anything; lets the enemy AI decide whether casting is
	 * worth attempting before committing to it via castLeveledSpellFor(),
	 * and lets the combat screen disable a "Cast" button for a leveled
	 * spell it can't actually pay for right now.
	 */
	function hasSpellResource( combatant, minimumLevel ) {
		if ( structKeyExists( arguments.combatant, "spellSlots" ) ) {
			for ( var level = arguments.minimumLevel; level <= 9; level++ ) {
				if ( structKeyExists( arguments.combatant.spellSlots, level ) && arguments.combatant.spellSlots[ level ] > 0 ) {
					return true;
				}
			}
		}
		return (
			structKeyExists( arguments.combatant, "hasMagicInitiate" ) && arguments.combatant.hasMagicInitiate &&
			!arguments.combatant.usedMagicInitiateSpell
		);
	}

	/**
	 * Starts `combatant` concentrating on `spellName`, ending whatever they
	 * were concentrating on before — a creature can only concentrate on one
	 * spell at a time, per the "Concentration" rules. No spell in this
	 * app's data currently has a sustained combat effect (no ongoing
	 * buff/debuff like Bless or Hunter's Mark is modeled), so ending a
	 * prior spell here is bookkeeping and a log line, not an active effect
	 * removal — see checkConcentration() for the other half of this rule.
	 */
	private function _startConcentrating( state, combatant, spellName ) {
		if (
			structKeyExists( arguments.combatant, "concentratingOn" ) && len( arguments.combatant.concentratingOn ) &&
			arguments.combatant.concentratingOn != arguments.spellName
		) {
			arguments.state.log.prepend( "#arguments.combatant.name#'s concentration on #arguments.combatant.concentratingOn# ends." );
		}
		arguments.combatant.concentratingOn = arguments.spellName;
	}

	/**
	 * Rolls a Constitution saving throw (DC = the higher of 10 or half the
	 * damage just taken, per the "Concentration" rules) to maintain
	 * concentration — a no-op if `combatant` isn't concentrating on
	 * anything, or took no damage. Ends concentration (clearing
	 * `concentratingOn` and logging it) on a failed save.
	 */
	function checkConcentration( log, combatant, damageTaken, state = {} ) {
		if (
			!structKeyExists( arguments.combatant, "concentratingOn" ) || !len( arguments.combatant.concentratingOn ) ||
			arguments.damageTaken <= 0
		) {
			return;
		}
		var dc = max( 10, int( arguments.damageTaken / 2 ) );
		var result = rollSavingThrow( combatant = arguments.combatant, ability = "con", dc = dc, state = arguments.state );
		if ( result.success ) {
			arguments.log.prepend( "#arguments.combatant.name# maintains concentration on #arguments.combatant.concentratingOn# (DC #dc# Constitution save)." );
		} else {
			arguments.log.prepend( "#arguments.combatant.name# loses concentration on #arguments.combatant.concentratingOn# (failed a DC #dc# Constitution save)." );
			arguments.combatant.concentratingOn = "";
		}
	}

	/**
	 * True if `attacker` could actually reach `defender` with `spell` right
	 * now — within `spell.rangeSquares` (defaulting to 24/120 ft. if the
	 * struct doesn't carry one — the hardcoded Magic Initiate/monster
	 * fallbacks always do, so this only matters for stray callers), and with
	 * a clear line of sight if a grid is in play. Healing spells always
	 * target the caster, so they're always valid regardless of `defender`.
	 */
	function isSpellTargetValid( state, attacker, defender, spell ) {
		if ( arguments.spell.type == "heal" ) {
			return true;
		}
		var rangeSquares = structKeyExists( arguments.spell, "rangeSquares" ) ? arguments.spell.rangeSquares : 24;
		if ( variables.grid.chebyshev( arguments.attacker, arguments.defender ) > rangeSquares ) {
			return false;
		}
		var grid = variables.grid.stateGrid( arguments.state );
		return isNull( grid ) || variables.grid.hasLineOfSight( grid, arguments.attacker.position, arguments.defender.position );
	}

	/**
	 * Casts one of the player's known cantrips at the opponent, by name — a
	 * thin wrapper around `castCantripFor()`. Defaults to the player's
	 * first known cantrip if `name` is omitted (the common case while a
	 * player only knows one).
	 *
	 * @state The encounter's full mutable game state struct.
	 * @name The exact name of a spell in `state.player.knownCantrips`.
	 */
	function castCantrip( state, name = "" ) {
		var cantrip = _findKnownSpell( arguments.state.player, "knownCantrips", arguments.name );
		if ( !isNull( cantrip ) ) {
			castCantripFor( arguments.state, arguments.state.player, arguments.state.opponent, false, cantrip );
		}
	}

	/**
	 * Casts one of the player's known leveled spells, by name — a thin
	 * wrapper around `castLeveledSpellFor()`. Same defaults-to-first-known
	 * behavior as castCantrip(). For a damage/save spell this always
	 * targets `state.opponent`; for a heal spell it targets `healTarget` if
	 * given (any living party member — see WebSocket.bx's
	 * _handleCastSpell()), or the caster themself otherwise.
	 *
	 * @state The encounter's full mutable game state struct.
	 * @name The exact name of a spell in `state.player.knownLeveledSpells`.
	 * @healTarget Optional: the party member struct to heal, for a heal-type spell.
	 */
	function castLeveledSpell( state, name = "", healTarget = javaCast( "null", 0 ) ) {
		var spell = _findKnownSpell( arguments.state.player, "knownLeveledSpells", arguments.name );
		if ( !isNull( spell ) ) {
			var defender = arguments.state.opponent;
			if ( spell.type == "heal" ) {
				defender = isNull( arguments.healTarget ) ? arguments.state.player : arguments.healTarget;
			}
			castLeveledSpellFor( arguments.state, arguments.state.player, defender, false, spell );
		}
	}

	/**
	 * Finds `name` in `combatant[arrayKey]` (an array of spell structs, e.g.
	 * `knownCantrips`) — or, if `name` is blank, returns the array's first
	 * entry (the common case while a caster only knows one). Returns null
	 * if `arrayKey` is missing/empty, or `name` isn't found in it.
	 */
	private function _findKnownSpell( combatant, arrayKey, name ) {
		if ( !structKeyExists( arguments.combatant, arguments.arrayKey ) || !arguments.combatant[ arguments.arrayKey ].len() ) {
			return javaCast( "null", 0 );
		}
		var spells = arguments.combatant[ arguments.arrayKey ];
		if ( !len( arguments.name ) ) {
			return spells[ 1 ];
		}
		for ( var spell in spells ) {
			if ( spell.name == arguments.name ) {
				return spell;
			}
		}
		return javaCast( "null", 0 );
	}

	/**
	 * Casts `cantrip` (from `attacker.knownCantrips`, or a monster's own
	 * `attacker.knownCantrip`) at `defender` — an attack-roll damage cantrip
	 * (e.g. Fire Bolt) or a saving-throw damage cantrip (e.g. Sacred Flame)
	 * per `cantrip.type`. Spends the attacker's action. Used for both the
	 * player (via castCantrip()) and any spellcasting monster (via
	 * runEnemyTurn(), which still passes its own single `knownCantrip`).
	 *
	 * @state The encounter's full mutable game state struct.
	 * @attacker The casting combatant.
	 * @defender The combatant being targeted.
	 * @defenderIsPlayer Whether `defender` is `state.player` — decides whether reaching 0 HP means defeat (with Relentless Endurance) or victory/XP.
	 * @cantrip The cantrip struct to cast (see _spellStructFromRow()).
	 */
	function castCantripFor( state, attacker, defender, defenderIsPlayer, cantrip ) {
		if ( !isSpellTargetValid( arguments.state, arguments.attacker, arguments.defender, arguments.cantrip ) ) {
			arguments.state.log.prepend( "#arguments.attacker.name# doesn't have a clear shot at #arguments.defender.name# for #arguments.cantrip.name#." );
			return;
		}

		arguments.state.actionUsed = true;
		arguments.state.roundHadAction = true;
		// Dice default to 1d8 (save) / 1d10 (attack), matching the classes'
		// cantrips — but a monster's own signature cantrip (e.g. a Priest's
		// Radiant Flame, 2d6) can override with its own diceCount/diceSides.
		var diceCount = arguments.cantrip.keyExists( "diceCount" ) ? arguments.cantrip.diceCount : 1;
		if ( arguments.cantrip.type == "save" ) {
			var diceSides = arguments.cantrip.keyExists( "diceSides" ) ? arguments.cantrip.diceSides : 8;
			// Some save cantrips (Sacred Flame, Vicious Mockery) deal no damage
			// at all on a success, not half — real per-spell data from the
			// spells table carries its own saveEffect; the hardcoded fallback
			// cantrips (if _lookupClassSpell() found nothing for the class)
			// don't, so default to "half" same as before.
			var saveEffect = arguments.cantrip.keyExists( "saveEffect" ) ? arguments.cantrip.saveEffect : "half";
			_castSaveDamageSpell( arguments.state, arguments.attacker, arguments.defender, arguments.defenderIsPlayer, arguments.cantrip.name, arguments.cantrip.saveAbility, diceCount, diceSides, arguments.cantrip.damageType, saveEffect );
		} else {
			var diceSides = arguments.cantrip.keyExists( "diceSides" ) ? arguments.cantrip.diceSides : 10;
			_castAttackSpell( arguments.state, arguments.attacker, arguments.defender, arguments.defenderIsPlayer, arguments.cantrip.name, diceCount, diceSides, arguments.cantrip.damageType );
		}
	}

	/**
	 * Casts `spell` (from `attacker.knownLeveledSpells`, or a monster's own
	 * `attacker.knownLeveledSpell`) — either at `defender` (a damage spell
	 * like Magic Missile) or heals `defender` (a healing spell like Cure
	 * Wounds/Healing Word — the caster themself by default, or any living
	 * ally if one was explicitly chosen, see castLeveledSpell()), per
	 * `spell.type`. Spends a slot at `spell.level` if the caster has one;
	 * otherwise falls back to Magic Initiate's separate once-per-encounter
	 * bonus spell, if available and unused. A no-op if neither resource is
	 * available. If `spell.concentration` is true and the cast goes
	 * through, starts concentrating on it (see _startConcentrating()),
	 * dropping whatever the caster was concentrating on before. Used for
	 * both the player (via castLeveledSpell()) and any spellcasting monster
	 * (via runEnemyTurn() — a self-heal passes the monster itself as
	 * `defender`, not its aggro target).
	 *
	 * @state The encounter's full mutable game state struct.
	 * @attacker The casting combatant.
	 * @defender The spell's target: an opponent for a damage/save spell, or
	 *  whoever's being healed for a heal spell.
	 * @defenderIsPlayer Whether `defender` is on the player's side — decides whether reaching 0 HP means defeat (with Relentless Endurance) or victory/XP. Unused for a heal spell (healing never reduces HP).
	 * @spell The spell struct to cast (see _spellStructFromRow()).
	 */
	function castLeveledSpellFor( state, attacker, defender, defenderIsPlayer, spell ) {
		if ( !isSpellTargetValid( arguments.state, arguments.attacker, arguments.defender, arguments.spell ) ) {
			arguments.state.log.prepend( "#arguments.attacker.name# doesn't have a clear shot at #arguments.defender.name# for #arguments.spell.name#." );
			return;
		}

		var spellLevel = arguments.spell.keyExists( "level" ) ? arguments.spell.level : 1;
		var slotSpent = _spendSpellSlot( arguments.attacker, spellLevel );
		var usedMagicInitiate = false;
		if (
			slotSpent == 0 && structKeyExists( arguments.attacker, "hasMagicInitiate" ) && arguments.attacker.hasMagicInitiate &&
			!arguments.attacker.usedMagicInitiateSpell
		) {
			arguments.attacker.usedMagicInitiateSpell = true;
			usedMagicInitiate = true;
		} else if ( slotSpent == 0 ) {
			arguments.state.log.prepend( "#arguments.attacker.name# has no spell slots left to cast #arguments.spell.name#." );
			return;
		}

		arguments.state.actionUsed = true;
		arguments.state.roundHadAction = true;
		if ( arguments.spell.keyExists( "concentration" ) && arguments.spell.concentration ) {
			_startConcentrating( arguments.state, arguments.attacker, arguments.spell.name );
		}
		var spell = arguments.spell;
		var resourceNote = usedMagicInitiate ? " (Magic Initiate's bonus spell)" : " (spends a level-#slotSpent# slot)";
		if ( spell.type == "heal" ) {
			_castHealSpell( arguments.state, arguments.attacker, arguments.defender, spell.name, resourceNote, spell.diceCount, spell.diceSides );
		} else if ( spell.type == "attack" ) {
			_castAttackSpell( arguments.state, arguments.attacker, arguments.defender, arguments.defenderIsPlayer, spell.name, spell.diceCount, spell.diceSides, spell.damageType, resourceNote );
		} else if ( spell.type == "save" ) {
			_castSaveDamageSpell( arguments.state, arguments.attacker, arguments.defender, arguments.defenderIsPlayer, spell.name, spell.saveAbility, spell.diceCount, spell.diceSides, spell.damageType, spell.saveEffect, resourceNote );
		} else {
			// Legacy fallback: Magic Initiate's default bonus spell when no
			// real DB spell was found for the class ({"type":"damage","name":"Magic Missile"}).
			_castMagicMissile( arguments.state, arguments.attacker, arguments.defender, arguments.defenderIsPlayer, resourceNote );
		}
	}

	/**
	 * Fire Bolt/Eldritch Blast/Produce Flame-style attack cantrip: a spell
	 * attack roll (d20 + Proficiency Bonus + spellcasting ability modifier)
	 * vs. the defender's AC, dealing `diceCount`d`diceSides` damage on a hit
	 * (doubled on a natural 20).
	 */
	private function _castAttackSpell( state, attacker, defender, defenderIsPlayer, spellName, diceCount, diceSides, damageType, resourceNote = "" ) {
		var spellMod = arguments.attacker.modifiers[ arguments.attacker.spellcastingAbility ];
		var cover = coverBonus( arguments.state, arguments.attacker, arguments.defender );
		var effectiveAC = arguments.defender.armorClass + cover;
		var coverNote = ( cover > 0 ) ? " (+#cover# Cover)" : "";
		var roll = randRange( 1, 20 );
		var total = roll + arguments.attacker.proficiencyBonus + spellMod;
		var isCrit = ( roll == 20 );
		var hits = isCrit || total >= effectiveAC;

		if ( !hits ) {
			arguments.state.log.prepend(
				"#arguments.attacker.name# casts #arguments.spellName##arguments.resourceNote# at #arguments.defender.name#: #roll# + #arguments.attacker.proficiencyBonus + spellMod# = #total# vs AC #effectiveAC##coverNote#. Miss!"
			);
			return;
		}

		var damage = variables.dice.rollSum( arguments.diceCount * ( isCrit ? 2 : 1 ), arguments.diceSides );
		damage = applyDamageModifiers( arguments.defender, damage, arguments.damageType );

		arguments.defender.hitPoints = max( 0, arguments.defender.hitPoints - damage );
		checkConcentration( arguments.state.log, arguments.defender, damage, arguments.state );
		recordThreat( arguments.defender, arguments.attacker, damage );
		arguments.state.log.prepend(
			"#arguments.attacker.name# casts #arguments.spellName##arguments.resourceNote# at #arguments.defender.name#: #roll# + #arguments.attacker.proficiencyBonus + spellMod# = #total# vs AC #effectiveAC##coverNote#. " &
			( isCrit ? "Critical hit! " : "Hit! " ) &
			"#damage# #arguments.damageType# damage (#arguments.defender.hitPoints#/#arguments.defender.maxHitPoints# HP)."
		);
		checkDefenderDefeated( arguments.state, arguments.attacker, arguments.defender, arguments.defenderIsPlayer );
	}

	/**
	 * Sacred Flame/Vicious Mockery-style save spell/cantrip: the defender
	 * makes a saving throw (via rollSavingThrow()) against DC 8 + Proficiency
	 * Bonus + spellcasting ability modifier, taking full damage on a failure
	 * and — per `saveEffect`, from the spells table's own `save_effect` column
	 * for a real leveled spell, or "half" for the hardcoded cantrips — either
	 * half damage or none at all on a success.
	 */
	private function _castSaveDamageSpell( state, attacker, defender, defenderIsPlayer, spellName, saveAbility, diceCount, diceSides, damageType, saveEffect = "half", resourceNote = "" ) {
		var dc = 8 + arguments.attacker.proficiencyBonus + arguments.attacker.modifiers[ arguments.attacker.spellcastingAbility ];
		var cover = coverBonus( arguments.state, arguments.attacker, arguments.defender );
		var saveResult = rollSavingThrow( arguments.defender, arguments.saveAbility, dc, "", true, cover, arguments.state );

		var damage = variables.dice.rollSum( arguments.diceCount, arguments.diceSides );
		var successText = "succeeds. No effect. ";
		if ( saveResult.success && arguments.saveEffect == "half" ) {
			damage = int( damage / 2 );
			successText = "succeeds, takes half damage. ";
		} else if ( saveResult.success ) {
			damage = 0;
		}
		damage = applyDamageModifiers( arguments.defender, damage, arguments.damageType );

		arguments.defender.hitPoints = max( 0, arguments.defender.hitPoints - damage );
		checkConcentration( arguments.state.log, arguments.defender, damage, arguments.state );
		recordThreat( arguments.defender, arguments.attacker, damage );
		arguments.state.log.prepend(
			"#arguments.attacker.name# casts #arguments.spellName##arguments.resourceNote# at #arguments.defender.name#: DC #dc# #uCase( arguments.saveAbility )# save — #arguments.defender.name# rolls #saveResult.total#" &
			( saveResult.hadAdvantage ? " (Advantage)" : "" ) & " — " &
			( saveResult.success ? successText : "fails! " ) &
			"#damage# #arguments.damageType# damage (#arguments.defender.hitPoints#/#arguments.defender.maxHitPoints# HP)."
		);
		checkDefenderDefeated( arguments.state, arguments.attacker, arguments.defender, arguments.defenderIsPlayer );
	}

	/**
	 * Magic Missile: automatically hits with 3 darts of 1d4+1 Force damage
	 * each (no attack roll, no save) — always a total of 3d4+3 here, since
	 * upcasting for more darts isn't modeled.
	 */
	private function _castMagicMissile( state, attacker, defender, defenderIsPlayer, resourceNote ) {
		var damage = variables.dice.rollSum( 3, 4 ) + 3;
		damage = applyDamageModifiers( arguments.defender, damage, "Force" );

		arguments.defender.hitPoints = max( 0, arguments.defender.hitPoints - damage );
		checkConcentration( arguments.state.log, arguments.defender, damage, arguments.state );
		recordThreat( arguments.defender, arguments.attacker, damage );
		arguments.state.log.prepend(
			"#arguments.attacker.name# casts Magic Missile#arguments.resourceNote# — three darts automatically strike #arguments.defender.name# for #damage# Force damage (#arguments.defender.hitPoints#/#arguments.defender.maxHitPoints# HP)."
		);
		checkDefenderDefeated( arguments.state, arguments.attacker, arguments.defender, arguments.defenderIsPlayer );
	}

	/**
	 * Cure Wounds/Healing Word-style heal: heals `target` (the caster
	 * themself, an ally, or — for a monster's own self-heal — itself, see
	 * _runOneOpponentTurn()) for `diceCount`d`diceSides` plus the caster's
	 * spellcasting ability modifier Hit Points, capped at `target`'s
	 * maximum. Healing a downed (0 HP) target back above 0 revives them —
	 * clears the dying/stable state and death save counters, same as a
	 * natural 20 on rollDeathSave().
	 */
	private function _castHealSpell( state, attacker, target, spellName, resourceNote, diceCount, diceSides ) {
		var healing = variables.dice.rollSum( arguments.diceCount, arguments.diceSides ) + arguments.attacker.modifiers[ arguments.attacker.spellcastingAbility ];
		var wasDown = arguments.target.hitPoints <= 0;
		arguments.target.hitPoints = min( arguments.target.maxHitPoints, arguments.target.hitPoints + healing );
		if ( wasDown && arguments.target.hitPoints > 0 ) {
			arguments.target.isDying = false;
			arguments.target.isStable = false;
			arguments.target.deathSaveSuccesses = 0;
			arguments.target.deathSaveFailures = 0;
		}
		var selfCast = ( arguments.target.name == arguments.attacker.name );
		arguments.state.log.prepend(
			selfCast
				? "#arguments.attacker.name# casts #arguments.spellName##arguments.resourceNote#, healing #healing# Hit Points (#arguments.target.hitPoints#/#arguments.target.maxHitPoints# HP)."
				: "#arguments.attacker.name# casts #arguments.spellName##arguments.resourceNote# on #arguments.target.name#, healing #healing# Hit Points (#arguments.target.hitPoints#/#arguments.target.maxHitPoints# HP)."
		);
	}

	/**
	 * Applies immunity/vulnerability/resistance for `damageType` to `damage`,
	 * shared by every spell-damage path (mirrors the same logic in resolveAttack()).
	 */
	function applyDamageModifiers( defender, damage, damageType ) {
		if ( structKeyExists( arguments.defender, "immunities" ) && arrayFindNoCase( arguments.defender.immunities, arguments.damageType ) ) {
			return 0;
		}
		var damage = arguments.damage;
		if ( structKeyExists( arguments.defender, "vulnerabilities" ) && arrayFindNoCase( arguments.defender.vulnerabilities, arguments.damageType ) ) {
			damage *= 2;
		}
		if ( structKeyExists( arguments.defender, "resistances" ) && arrayFindNoCase( arguments.defender.resistances, arguments.damageType ) ) {
			damage = int( damage / 2 );
		}
		return damage;
	}

	/**
	 * Shared victory/defeat check after a spell or weapon attack deals
	 * damage. When the defeated combatant is the player, this includes the
	 * Orc Relentless Endurance check (drop to 1 HP instead of 0, once per
	 * encounter). When it's an opponent, this awards its XP once and only
	 * ends the encounter (victory) once every opponent in state.opponents
	 * (or the lone state.opponent, for single-mob state) is down — otherwise
	 * the fight continues, and the player's current target auto-advances to
	 * the next living opponent if the one they just downed was it.
	 */
	function checkDefenderDefeated( state, attacker, defender, defenderIsPlayer ) {
		if ( arguments.defender.hitPoints > 0 ) {
			return;
		}

		if ( arguments.defenderIsPlayer ) {
			if (
				structKeyExists( arguments.defender, "hasRelentlessEndurance" ) && arguments.defender.hasRelentlessEndurance &&
				!arguments.defender.usedRelentlessEndurance
			) {
				arguments.defender.hitPoints = 1;
				arguments.defender.usedRelentlessEndurance = true;
				arguments.state.log.prepend( "#arguments.defender.name#'s Relentless Endurance kicks in — clinging to 1 Hit Point instead of falling!" );
				return;
			}
			// Dropping to 0 HP starts Death Saving Throws instead of ending the
			// encounter outright — see rollDeathSave() and applyDeathSaveFailure().
			if ( !structKeyExists( arguments.defender, "isDying" ) || !arguments.defender.isDying ) {
				arguments.defender.isDying = true;
				arguments.defender.deathSaveSuccesses = 0;
				arguments.defender.deathSaveFailures = 0;
				arguments.state.log.prepend( "#arguments.defender.name# drops to 0 Hit Points and is dying!" );
			}
			return;
		}

		if ( !structKeyExists( arguments.defender, "xpAwarded" ) || !arguments.defender.xpAwarded ) {
			arguments.defender.xpAwarded = true;
			variables.progression.awardPartyExperience( arguments.state, arguments.defender.xp );
			variables.progression.incrementCharacterStat( arguments.state.player.characterId, "monsters_killed" );
			arguments.state.player.monstersKilled = ( structKeyExists( arguments.state.player, "monstersKilled" ) ? arguments.state.player.monstersKilled : 0 ) + 1;
			variables.progression.grantMonsterLoot( arguments.state, arguments.defender );
			// The round this opponent died — the sidebar keeps showing its
			// (blinking-then-fading, via CSS) defeated card through the rest of
			// this round, then drops it from the roster entirely once the round
			// advances (see default.bxm's foe-card visibility check).
			if ( structKeyExists( arguments.state, "round" ) ) {
				arguments.defender.defeatedAtRound = arguments.state.round;
			}
		}

		if ( allOpponentsDefeated( arguments.state ) ) {
			arguments.state.gameOver = true;
			arguments.state.outcome = "victory";
			arguments.state.log.prepend( "#arguments.defender.name# collapses. Victory!" );
		} else {
			arguments.state.log.prepend( "#arguments.defender.name# collapses!" );
			retargetIfCurrentOpponentDefeated( arguments.state );
		}
	}

	/**
	 * Applies an automatic death-save failure to a dying player who's just
	 * been struck again — an Unconscious creature auto-fails Dex saves and
	 * takes no roll-to-hit, so this skips normal attack resolution entirely.
	 * Counts as 2 failures (an automatic critical) if `attacker` is within 5
	 * feet, 1 otherwise, per the "Unconscious"/critical-hit-range rules. Ends
	 * the encounter in defeat once failures reach 3.
	 *
	 * @state The encounter's full mutable game state struct.
	 * @attacker The opponent striking the downed player.
	 * @defender The dying player.
	 */
	function applyDeathSaveFailure( state, attacker, defender ) {
		if ( structKeyExists( arguments.defender, "isStable" ) && arguments.defender.isStable ) {
			arguments.defender.isStable = false;
			arguments.defender.isDying = true;
			arguments.defender.deathSaveSuccesses = 0;
			arguments.defender.deathSaveFailures = 0;
		}
		var failures = ( variables.grid.chebyshev( arguments.attacker, arguments.defender ) <= 1 ) ? 2 : 1;
		arguments.defender.deathSaveFailures += failures;
		arguments.state.log.prepend(
			"#arguments.attacker.name# strikes the unconscious #arguments.defender.name#: #failures# failed death save#( failures > 1 ? 's' : '' )#!"
		);
		if ( arguments.defender.deathSaveFailures >= 3 ) {
			arguments.defender.isDying = false;
			arguments.state.gameOver = true;
			arguments.state.outcome = "defeat";
			variables.progression.incrementCharacterStat( arguments.defender.characterId, "deaths" );
			arguments.defender.deaths = ( structKeyExists( arguments.defender, "deaths" ) ? arguments.defender.deaths : 0 ) + 1;
			arguments.state.log.prepend( "#arguments.defender.name# dies." );
		}
	}

	/**
	 * Rolls one of the player's Death Saving Throws while they're dying (0 HP,
	 * per `player.isDying`) — d20 with no modifiers: 20 regains 1 Hit Point and
	 * ends the dying state outright, 10+ is a success, 2-9 is a failure, and a
	 * natural 1 counts as 2 failures. 3 successes stabilizes the player
	 * (unconscious but no longer in danger of dying on their own); 3 failures
	 * ends the encounter in defeat. A no-op if the player isn't dying.
	 *
	 * @state The encounter's full mutable game state struct.
	 */
	function rollDeathSave( state ) {
		var player = arguments.state.player;
		if ( !structKeyExists( player, "isDying" ) || !player.isDying ) {
			return;
		}

		var roll = randRange( 1, 20 );
		if ( roll == 20 ) {
			player.hitPoints = 1;
			player.isDying = false;
			player.deathSaveSuccesses = 0;
			player.deathSaveFailures = 0;
			arguments.state.log.prepend( "#player.name# rolls a natural 20 on their death save — surges back to 1 Hit Point!" );
			return;
		}

		// Aura of Protection adds a flat bonus to the death save total — it's a
		// numerical modifier, not a change to the nat-1/nat-20 special rules
		// above, which key off the raw die. See _auraOfProtectionBonus().
		var auraBonus = _auraOfProtectionBonus( arguments.state, player );
		var total = roll + auraBonus;
		var auraNote = auraBonus > 0 ? " (+#auraBonus# Aura of Protection)" : "";

		if ( roll == 1 ) {
			player.deathSaveFailures += 2;
		} else if ( total >= 10 ) {
			player.deathSaveSuccesses += 1;
		} else {
			player.deathSaveFailures += 1;
		}

		arguments.state.log.prepend(
			"#player.name# makes a death saving throw: #roll##auraNote# — " &
			( roll == 1 ? "critical failure (2 failures)!" : ( total >= 10 ? "success." : "failure." ) ) &
			" (#min( player.deathSaveSuccesses, 3 )# successes, #min( player.deathSaveFailures, 3 )# failures)"
		);

		if ( player.deathSaveSuccesses >= 3 ) {
			player.isDying = false;
			player.isStable = true;
			arguments.state.log.prepend( "#player.name# stabilizes, unconscious but stable." );
		} else if ( player.deathSaveFailures >= 3 ) {
			arguments.state.gameOver = true;
			arguments.state.outcome = "defeat";
			variables.progression.incrementCharacterStat( player.characterId, "deaths" );
			player.deaths = ( structKeyExists( player, "deaths" ) ? player.deaths : 0 ) + 1;
			arguments.state.log.prepend( "#player.name# dies." );
		}
	}


	/**
	 * d20 + Dexterity modifier, plus Proficiency Bonus if the combatant has
	 * the Alert feat's Initiative Proficiency benefit.
	 */
	function rollInitiative( combatant ) {
		var dexMod = structKeyExists( arguments.combatant, "modifiers" ) ? arguments.combatant.modifiers.dex : variables.rules.abilityModifier( arguments.combatant.abilityScores.dex );
		var hasAlert = structKeyExists( arguments.combatant, "feats" ) && arrayFindNoCase( arguments.combatant.feats, "Alert" ) > 0;
		var alertBonus = hasAlert ? arguments.combatant.proficiencyBonus : 0;
		return randRange( 1, 20 ) + dexMod + alertBonus;
	}

	/**
	 * Second Wind (Fighter 1): once per encounter, a bonus action heal of
	 * 1d10 + Fighter level Hit Points. A no-op if the bonus action is
	 * already spent, the feature isn't held, it's already been used this
	 * encounter, or the player is down/incapacitated.
	 */
	function useSecondWind( state ) {
		var player = arguments.state.player;
		if (
			( structKeyExists( arguments.state, "bonusActionUsed" ) && arguments.state.bonusActionUsed ) ||
			player.hitPoints <= 0 || isIncapacitated( player ) ||
			!structKeyExists( player, "features" ) || arrayFindNoCase( player.features, "Second Wind" ) == 0 ||
			player.usedSecondWind
		) {
			return;
		}
		arguments.state.bonusActionUsed = true;
		player.usedSecondWind = true;
		var healing = variables.dice.rollSum( 1, 10 ) + player.level;
		player.hitPoints = min( player.maxHitPoints, player.hitPoints + healing );
		arguments.state.log.prepend( "#player.name# uses Second Wind, healing #healing# Hit Points (#player.hitPoints#/#player.maxHitPoints# HP)." );
	}

	/**
	 * Rage's melee weapon damage bonus by level: +2 (1-8), +3 (9-15), +4 (16-20).
	 */
	private function _rageDamageBonus( level ) {
		if ( arguments.level >= 16 ) {
			return 4;
		} else if ( arguments.level >= 9 ) {
			return 3;
		}
		return 2;
	}

	/**
	 * Enters a Rage (Barbarian 1): a bonus action, consuming one of
	 * `player.ragesRemaining`. While raging (`player.isRaging`), melee
	 * weapon attacks deal bonus damage (see resolveAttack()'s Rage note),
	 * Strength saving throws have Advantage (see rollSavingThrow()), and the
	 * character gains resistance to Bludgeoning/Piercing/Slashing damage.
	 * A no-op if the feature isn't held, no uses remain, already raging, or
	 * the bonus action is already spent.
	 *
	 * Simplified from the full SRD rule: rage here lasts until endRage() is
	 * called or the encounter ends, rather than RAW's "ends early if you
	 * don't attack a hostile creature or take damage on your turn" — that
	 * nuance isn't tracked, matching this app's general pattern of not
	 * modeling turn-by-turn upkeep conditions it can't verify cheaply.
	 */
	function startRage( state ) {
		var player = arguments.state.player;
		if (
			( structKeyExists( arguments.state, "bonusActionUsed" ) && arguments.state.bonusActionUsed ) ||
			player.hitPoints <= 0 || isIncapacitated( player ) ||
			!structKeyExists( player, "features" ) || arrayFindNoCase( player.features, "Rage" ) == 0 ||
			player.isRaging || !structKeyExists( player, "ragesRemaining" ) || player.ragesRemaining <= 0
		) {
			return;
		}
		arguments.state.bonusActionUsed = true;
		player.ragesUsed = ( structKeyExists( player, "ragesUsed" ) ? player.ragesUsed : 0 ) + 1;
		variables.rules.recomputeRagesRemaining( player );
		player.isRaging = true;
		for ( var damageType in [ "Bludgeoning", "Piercing", "Slashing" ] ) {
			if ( arrayFindNoCase( player.resistances, damageType ) == 0 ) {
				player.resistances.append( damageType );
			}
		}
		arguments.state.log.prepend( "#player.name# flies into a Rage! (#player.ragesRemaining# use#( player.ragesRemaining == 1 ? '' : 's' )# left)" );
	}

	/**
	 * Ends an active Rage early (no action cost, matching the SRD's "you can
	 * end your Rage on your turn as a free action") — removes the
	 * Bludgeoning/Piercing/Slashing resistance startRage() granted. A no-op
	 * if not currently raging.
	 */
	function endRage( state ) {
		var player = arguments.state.player;
		if ( !structKeyExists( player, "isRaging" ) || !player.isRaging ) {
			return;
		}
		player.isRaging = false;
		for ( var damageType in [ "Bludgeoning", "Piercing", "Slashing" ] ) {
			arrayDelete( player.resistances, damageType, "textnocase" );
		}
		arguments.state.log.prepend( "#player.name#'s Rage ends." );
	}

	/**
	 * Applies an item's effect (by items.name) to the player and persists
	 * the result, same as shortRest()/longRest(). Returns true if the name
	 * matched a known effect (and was therefore consumed), false otherwise —
	 * default.bx only debits the item from inventory on a true return, so an
	 * unrecognized consumable is left alone rather than wasted.
	 */
	function useConsumableItem( state, itemName ) {
		var effects = variables.rules.consumableEffects();
		if ( !effects.keyExists( arguments.itemName ) ) {
			return false;
		}
		var effect = effects[ arguments.itemName ];
		var player = arguments.state.player;

		if ( effect.type == "heal" ) {
			var amount = variables.dice.rollSum( effect.diceCount, effect.diceSides ) + effect.flatBonus;
			var healed = min( amount, player.maxHitPoints - player.hitPoints );
			player.hitPoints += healed;
			arguments.state.log.prepend( "#player.name# drinks a #arguments.itemName# and recovers #healed# Hit Point#( healed == 1 ? "" : "s" )# (#player.hitPoints#/#player.maxHitPoints# HP)." );
		}

		variables.characterState.saveCharacterState( player );
		return true;
	}

	/**
	 * Resolves the player's attack against the opponent and, on a kill, ends
	 * the encounter and awards the opponent's XP to the player's saved
	 * character. Shared by the manual Attack action and the auto-battle
	 * player turn, so victory/XP handling only lives in one place.
	 *
	 * @state The encounter's full mutable game state struct.
	 * @weapon The weapon item being used for this attack.
	 * @disadvantage Whether this attack roll has Disadvantage.
	 */
	function playerAttack( state, weapon, disadvantage = false ) {
		var player = arguments.state.player;
		var opponent = arguments.state.opponent;
		resolveAttack( arguments.state.log, player, opponent, arguments.weapon, arguments.disadvantage, false, false, coverBonus( arguments.state, player, opponent ), arguments.state );
		checkDefenderDefeated( arguments.state, player, opponent, false );
	}

}
