	 * True if `combatant`'s Speed is effectively 0 — Restrained (already
	 * modeled), or Paralyzed/Petrified/Stunned/Unconscious, each of which
	 * separately says "can't move" on top of being incapacitated. Plain
	 * Incapacitated does *not* restrict movement by itself, per its own SRD
	 * definition — only these specific conditions do.
	 */
	function cantMove( combatant ) {
		return hasCondition( arguments.combatant, "Restrained" ) || isHelpless( arguments.combatant );
	}

	/**
	 * The SRD rules text for a condition (e.g. "Prone"), from the
	 * `conditions` table — for a tooltip on the combat log's condition chips,
	 * so a player can see what "Restrained" or "Frightened" actually does
	 * without leaving the encounter. Empty string for a name with no matching
	 * row (there's no source of untrusted/free-text condition names today,
	 * but addCondition() doesn't validate against the table, so this stays
	 * graceful rather than throwing).
	 */
	function conditionDescription( name ) {
		var rows = queryExecute(
			"SELECT description FROM conditions WHERE name = :name",
			{ "name": arguments.name },
			{ datasource: "gameserver" }
		);
		return ( rows.recordCount > 0 && !isNull( rows.description[ 1 ] ) ) ? rows.description[ 1 ] : "";
	}

	/**
	 * The full ability name a skill's checks use (e.g. "Perception" ->
	 * "Wisdom"), from SKILL_ABILITIES — for a tooltip on skill proficiency
	 * chips, same idea as conditionDescription(). Empty string for an
	 * unrecognized skill name.
	 */
	function skillAbility( name ) {
		return structKeyExists( SKILL_ABILITIES, arguments.name ) ? _abilityFullName( SKILL_ABILITIES[ arguments.name ] ) : "";
	}

	/**
	 * The actual total bonus `combatant` rolls for a `skill` check right now
	 * (ability modifier + Proficiency Bonus, the latter only if they're
	 * proficient — see _skillProficiencyBonus()) — this is "the benefit" a
	 * skill proficiency chip's tooltip should show, not just which ability
	 * it uses.
	 */
	function skillCheckBonus( combatant, skill ) {
		var ability = SKILL_ABILITIES[ arguments.skill ];
		var abilityMod = structKeyExists( arguments.combatant, "modifiers" )
			? arguments.combatant.modifiers[ ability ]
			: abilityModifier( arguments.combatant.abilityScores[ ability ] );
		return abilityMod + _skillProficiencyBonus( arguments.combatant, arguments.skill );
	}

	/**
	 * The SRD rules text for a feat — same idea as conditionDescription(),
	 * for a tooltip on the level-up screen's feat picker.
	 */
	function featDescription( name ) {
		var rows = queryExecute(
			"SELECT description FROM feats WHERE name = :name",
			{ "name": arguments.name },
			{ datasource: "gameserver" }
		);
		return ( rows.recordCount > 0 && !isNull( rows.description[ 1 ] ) ) ? rows.description[ 1 ] : "";
	}

	/**
	 * The SRD rules text for a class feature — same idea as featDescription(),
	 * for a tooltip on a Features chip (character creation, character sheet,
	 * and the combat screen's player stat card). A feature name can exist
	 * against more than one class (e.g. "Ability Score Improvement" is
	 * granted by every class); this just returns whichever row comes first,
	 * since this app doesn't track which class granted a given chip in the
	 * caller's plain name array.
	 */
	function featureDescription( name ) {
		var rows = queryExecute(
			"SELECT description FROM class_features WHERE name = :name LIMIT 1",
			{ "name": arguments.name },
			{ datasource: "gameserver" }
		);
		return ( rows.recordCount > 0 && !isNull( rows.description[ 1 ] ) ) ? rows.description[ 1 ] : "";
	}

	/**
	 * Returns `combatant`'s equipped weapon of the given category ("melee" or
	 * "ranged"), or null if they aren't carrying one.
	 */
	function equippedWeapon( combatant, category ) {
		for ( var item in arguments.combatant.inventory ) {
			if ( item.category == arguments.category && item.equipped ) {
				return item;
			}
		}
		return javaCast( "null", 0 );
	}

	/**
	 * Picks the best equipped weapon `combatant` can use against a target at
	 * `distance` squares away: melee if adjacent (better damage, no
	 * Disadvantage), otherwise an equipped ranged weapon if the target is
	 * within its long range. Returns null if nothing is usable at that range.
	 * A ranged attack beyond normal range (but within long range) has
	 * Disadvantage, per the "Ranged Attacks" rules.
	 */
	/**
	 * @grid Optional level grid (`{width, height, tiles}`, from MapService) — if given along with `targetPosition`, a ranged option is only offered when there's a clear line of sight to the target (a wall in the way blocks the shot, per the "Ranged Attacks" rules).
	 * @targetPosition Optional `{x, y}` of the target, required alongside `grid` for the line-of-sight check.
	 */
	function pickWeaponForDistance( combatant, distance, grid = javaCast( "null", 0 ), targetPosition = javaCast( "null", 0 ) ) {
		var melee = equippedWeapon( arguments.combatant, "melee" );
		if ( arguments.distance <= 1 && !isNull( melee ) ) {
			return { "weapon": melee, "disadvantage": false };
		}

		var ranged = equippedWeapon( arguments.combatant, "ranged" );
		if ( !isNull( ranged ) && arguments.distance <= ranged.longRange ) {
			if (
				!isNull( arguments.grid ) && !isNull( arguments.targetPosition ) &&
				!hasLineOfSight( arguments.grid, arguments.combatant.position, arguments.targetPosition )
			) {
				return javaCast( "null", 0 );
			}
			return {
				"weapon": ranged,
				// Also has Disadvantage at Close Combat range (within 5 ft of a foe), per the rules.
				"disadvantage": ( arguments.distance <= 1 || arguments.distance > ranged.normalRange )
			};
		}

		return javaCast( "null", 0 );
	}

	/**
	 * True if `to` is within MAX_SIGHT_SQUARES (60 feet, Chebyshev — matching
	 * the game's grid distance) of `from` AND a straight line between them
	 * doesn't pass through any wall tile along the way (the endpoints
	 * themselves aren't checked, since they're the combatants' own occupied
	 * tiles). Traces the line with
	 * Bresenham's algorithm — the same one any grid-based line-of-sight check
	 * uses — so it works regardless of which axis (or diagonal) the shot travels along.
	 *
	 * When the trace steps diagonally, the two orthogonal cells it cuts
	 * between are checked too: if BOTH block sight (a corner-to-corner
	 * "pinch", e.g. two rooms' walls meeting at a corner), sight is blocked.
	 * Plain Bresenham skips those cells and let monsters see straight through
	 * wall seams at every room corner. A single flanking wall doesn't block —
	 * peeking past one corner is normal grid line-of-sight.
	 *
	 * Door tiles block sight too (see _blocksSight()) even though they're
	 * walkable — a closed door reads as a solid barrier, so a monster behind
	 * one stays dormant until someone actually steps through.
	 *
	 * @grid A level grid (`{width, height, tiles}` and, when coming from a
	 *  real map rather than a bare test fixture, `decorations`), from MapService.
	 */
	function hasLineOfSight( grid, from, to ) {
		var x = arguments.from.x;
		var y = arguments.from.y;
		var targetX = arguments.to.x;
		var targetY = arguments.to.y;
		if ( max( abs( targetX - x ), abs( targetY - y ) ) > MAX_SIGHT_SQUARES ) {
			return false;
		}
		var dx = abs( targetX - x );
		var dy = abs( targetY - y );
		var stepX = ( x < targetX ) ? 1 : -1;
		var stepY = ( y < targetY ) ? 1 : -1;
		var err = dx - dy;

		while ( !( x == targetX && y == targetY ) ) {
			var doubledErr = 2 * err;
			var movedX = false;
			var movedY = false;
			if ( doubledErr > -dy ) {
				err -= dy;
				x += stepX;
				movedX = true;
			}
			if ( doubledErr < dx ) {
				err += dx;
				y += stepY;
				movedY = true;
			}
			// Diagonal step: blocked by a corner pinch even when the landing
			// cell itself is the target (the seam sits before it).
			if (
				movedX && movedY &&
				_blocksSight( arguments.grid, x - stepX, y ) && _blocksSight( arguments.grid, x, y - stepY )
			) {
				return false;
			}
			if ( x == targetX && y == targetY ) {
				break;
			}
			if ( _blocksSight( arguments.grid, x, y ) ) {
				return false;
			}
		}
		return true;
	}

	/**
	 * True if the tile at (x, y) blocks line of sight: a wall (or anything
	 * out of bounds), or a floor tile bearing a door decoration. Doors are
	 * deliberately walkable (a combatant "opens" one by stepping through —
	 * isWalkable()/movement never consult this) but read as closed solid
	 * barriers, so nothing sees through one until it's actually crossed.
	 * Tolerates grids without a decorations layer (the unit tests' bare
	 * {width, height, tiles} fixtures).
	 */
	private function _blocksSight( grid, x, y ) {
		if ( !isWalkable( arguments.grid, arguments.x, arguments.y ) ) {
			return true;
		}
		return structKeyExists( arguments.grid, "decorations" ) && arguments.grid.decorations[ arguments.y ][ arguments.x ] == "door";
	}

	/**
	 * Half Cover bonus (+2 AC and Dexterity saves) for an attack from
	 * `attacker` against `defender`: granted when another living combatant
	 * (not the attacker or defender themselves) occupies a grid square on the
	 * straight line between them, per the "Cover" rules — one creature
	 * providing cover for another. Simplified to this one case: this app
	 * doesn't model terrain/objects as separate obstacles from walls (which
	 * already fully block a shot via hasLineOfSight() instead of granting
	 * partial cover), so Three-Quarters Cover and wall-corner Half Cover
	 * aren't modeled. Returns 0 without a grid (e.g. the unit tests' bare
	 * combatant fixtures) or if attacker/defender aren't at least 2 squares
	 * apart (nothing can stand between adjacent combatants).
	 *
	 * @state The encounter's full mutable game state struct.
	 * @attacker The attacking combatant.
	 * @defender The targeted combatant.
	 */
	function coverBonus( state, attacker, defender ) {
		var grid = _stateGrid( arguments.state );
		if ( isNull( grid ) || chebyshev( arguments.attacker, arguments.defender ) < 2 ) {
			return 0;
		}

		var others = [];
		if ( structKeyExists( arguments.state, "players" ) ) {
			for ( var member in arguments.state.players ) {
				others.append( member );
			}
		} else if ( structKeyExists( arguments.state, "player" ) ) {
			others.append( arguments.state.player );
		}
		for ( var o in _stateOpponents( arguments.state ) ) {
			others.append( o );
		}

		var x = arguments.attacker.position.x;
		var y = arguments.attacker.position.y;
		var targetX = arguments.defender.position.x;
		var targetY = arguments.defender.position.y;
		var dx = abs( targetX - x );
		var dy = abs( targetY - y );
		var stepX = ( x < targetX ) ? 1 : -1;
		var stepY = ( y < targetY ) ? 1 : -1;
		var err = dx - dy;

		while ( !( x == targetX && y == targetY ) ) {
			var doubledErr = 2 * err;
			if ( doubledErr > -dy ) {
				err -= dy;
				x += stepX;
			}
			if ( doubledErr < dx ) {
				err += dx;
				y += stepY;
			}
			if ( x == targetX && y == targetY ) {
				break;
			}
			for ( var other in others ) {
				if (
					other.hitPoints > 0 && other.position.x == x && other.position.y == y &&
					other.name != arguments.attacker.name && other.name != arguments.defender.name
				) {
					return 2;
				}
			}
		}
		return 0;
	}

	/**
	 * Resolves one attack roll and, on a hit, one damage roll, per the core
	 * rules: d20 + attack bonus vs AC; natural 20 always hits and is a
	 * Critical Hit (roll damage dice twice); natural 1 always misses.
	 * Disadvantage rolls two d20s and keeps the lower result.
	 * Vulnerability/Resistance/Immunity to the weapon's damage type is applied.
	 * A defender with an unused Reaction and a parsed Parry trait
	 * (`defender.parryBonus`, see _structuredParryBonus()) can turn a
	 * non-critical melee hit into a miss.
	 *
	 * `state` is optional (defaults to `{}`, as every existing unit test call
	 * omits it) — it's only used for the Weapon Mastery properties that need
	 * more battlefield context than a single attacker/defender pair (Push's
	 * grid, Cleave's second target from `state.opponents`). Every real
	 * combat call site passes the full encounter state; only Weapon Mastery
	 * is gated behind it (see the "Weapon Mastery" section below), and only
	 * ever for a combatant with the "Weapon Mastery" class feature, which in
	 * this dataset is always the player.
	 *
	 * @log The encounter's combat log array — a new entry is prepended.
	 * @attacker The attacker's stat struct (has a `name`).
	 * @defender The defender's stat struct — mutated in place with the result.
	 * @weapon The weapon item being used for this attack (from inventory).
	 * @disadvantage Whether this attack roll has Disadvantage.
	 */
	function resolveAttack( log, attacker, defender, weapon, disadvantage = false, advantage = false, omitDamageBonus = false, coverBonus = 0, state = {} ) {
		// Grappler: attacks against a creature you've grappled have Advantage,
		// even if the caller didn't ask for it explicitly.
		var autoAdvantage = (
			structKeyExists( arguments.defender, "grappledBy" ) &&
			arguments.defender.grappledBy == arguments.attacker.name &&
			structKeyExists( arguments.attacker, "hasGrapplerFeat" ) &&
			arguments.attacker.hasGrapplerFeat
		);
		// Prone: melee attacks against a Prone target have Advantage, ranged
		// ones have Disadvantage. Restrained: attacks against a Restrained
		// target always have Advantage; being Restrained yourself always gives
		// Disadvantage on your own attacks, same as being Poisoned or
		// Frightened (simplified here to apply regardless of whether the
		// source of the fear is in sight, since this app doesn't track that).
		// Blinded: your own attacks have Disadvantage. Invisible: your own
		// attacks have Advantage (the mirror image of Blinded).
		var autoDisadvantage = (
			hasCondition( arguments.attacker, "Restrained" ) ||
			hasCondition( arguments.attacker, "Poisoned" ) ||
			hasCondition( arguments.attacker, "Frightened" ) ||
			hasCondition( arguments.attacker, "Blinded" )
		);
		if ( hasCondition( arguments.attacker, "Invisible" ) ) {
			autoAdvantage = true;
		}
		if ( hasCondition( arguments.defender, "Prone" ) ) {
			if ( arguments.weapon.category == "melee" ) {
				autoAdvantage = true;
			} else {
				autoDisadvantage = true;
			}
		}
		// Restrained, Blinded (can't see to defend), and Paralyzed/Petrified/
		// Stunned/Unconscious (helpless) all give attacks against the
		// defender Advantage. Invisible is the opposite: attacks against an
		// Invisible defender have Disadvantage.
		if (
			hasCondition( arguments.defender, "Restrained" ) ||
			hasCondition( arguments.defender, "Blinded" ) ||
			isHelpless( arguments.defender )
		) {
			autoAdvantage = true;
		}
		if ( hasCondition( arguments.defender, "Invisible" ) ) {
			autoDisadvantage = true;
		}
		// Weapon Mastery — Vex: a prior hit against this same target with a
		// Vex weapon grants Advantage on this attack (consumed either way).
		var usedVex = (
			structKeyExists( arguments.attacker, "vexAdvantageTarget" ) && len( arguments.attacker.vexAdvantageTarget ) &&
			arguments.attacker.vexAdvantageTarget == arguments.defender.name
		);
		if ( usedVex ) {
			autoAdvantage = true;
			arguments.attacker.vexAdvantageTarget = "";
		}
		// Weapon Mastery — Sap: a prior hit against the attacker with a Sap
		// weapon gives Disadvantage on this attack (consumed either way).
		var usedSap = structKeyExists( arguments.attacker, "sapped" ) && arguments.attacker.sapped;
		if ( usedSap ) {
			autoDisadvantage = true;
			arguments.attacker.sapped = false;
		}
		// Advantage and Disadvantage on the same roll cancel out, per the rules.
		var useAdvantage = ( arguments.advantage || autoAdvantage ) && !( arguments.disadvantage || autoDisadvantage );
		var useDisadvantage = ( arguments.disadvantage || autoDisadvantage ) && !( arguments.advantage || autoAdvantage );

		var roll = randRange( 1, 20 );
		if ( useAdvantage ) {
			roll = max( roll, randRange( 1, 20 ) );
		} else if ( useDisadvantage ) {
			roll = min( roll, randRange( 1, 20 ) );
		}
		// Halfling Luck: a natural 1 can be rerolled, and the new roll must be used.
		var usedLuck = false;
		if ( roll == 1 && structKeyExists( arguments.attacker, "hasLuck" ) && arguments.attacker.hasLuck ) {
			roll = randRange( 1, 20 );
			usedLuck = true;
		}
		// Archery fighting style: +2 to attack rolls with Ranged weapons.
		var hasArchery = structKeyExists( arguments.attacker, "feats" ) && arrayFindNoCase( arguments.attacker.feats, "Archery" ) > 0;
		var styleBonus = ( hasArchery && arguments.weapon.category == "ranged" ) ? 2 : 0;
		var effectiveAC = arguments.defender.armorClass + arguments.coverBonus;
		var total = roll + arguments.weapon.attackBonus + styleBonus;
		var isCrit = ( roll == 20 );
		var isFumble = ( roll == 1 );
		var hits = !isFumble && ( isCrit || total >= effectiveAC );

		// Human Heroic Inspiration: once per encounter, reroll a missed attack.
		var usedInspiration = false;
		if (
			!hits && structKeyExists( arguments.attacker, "hasHeroicInspiration" ) &&
			arguments.attacker.hasHeroicInspiration && !arguments.attacker.usedHeroicInspiration
		) {
			arguments.attacker.usedHeroicInspiration = true;
			usedInspiration = true;
			roll = randRange( 1, 20 );
			total = roll + arguments.weapon.attackBonus + styleBonus;
			isCrit = ( roll == 20 );
			isFumble = ( roll == 1 );
			hits = !isFumble && ( isCrit || total >= effectiveAC );
		}

		// Paralyzed/Unconscious: any melee hit against them is a Critical
		// Hit — simplified from the SRD's "within 5 feet" to "any melee
		// attack", since this app doesn't model reach weapons, so melee
		// already implies adjacency.
		if (
			hits && !isCrit && structKeyExists( arguments.weapon, "category" ) && arguments.weapon.category == "melee" &&
			( hasCondition( arguments.defender, "Paralyzed" ) || hasCondition( arguments.defender, "Unconscious" ) )
		) {
			isCrit = true;
		}

		// Parry (e.g. Bandit Captain/Erinyes): if adding the defender's parry
		// bonus to their AC would turn this hit into a miss, they spend their
		// Reaction to do so — can't help against a natural 20, which always
		// hits regardless of AC. Shares the same reactionUsed flag as
		// opportunity attacks (see checkOpportunityAttacks()), since a
		// creature only has one Reaction per round no matter the source.
		var usedParry = false;
		if (
			hits && !isCrit &&
			structKeyExists( arguments.weapon, "category" ) && arguments.weapon.category == "melee" &&
			structKeyExists( arguments.defender, "parryBonus" ) && arguments.defender.parryBonus > 0 &&
			!( structKeyExists( arguments.defender, "reactionUsed" ) && arguments.defender.reactionUsed ) &&
			total < effectiveAC + arguments.defender.parryBonus
		) {
			arguments.defender.reactionUsed = true;
			usedParry = true;
			hits = false;
		}

		// Weapon Mastery (Barbarian/Fighter/Paladin/Ranger/Rogue 1): only
		// usable with the class feature, and only if the weapon actually has
		// one of the 8 mastery properties (weapons.mastery — see
		// loadCharacter()'s inventory query).
		var hasWeaponMastery = (
			structKeyExists( arguments.attacker, "features" ) && arrayFindNoCase( arguments.attacker.features, "Weapon Mastery" ) > 0 &&
			structKeyExists( arguments.weapon, "mastery" ) && len( arguments.weapon.mastery )
		);
		var mastery = hasWeaponMastery ? arguments.weapon.mastery : "";

		var disadvantageNote = useDisadvantage ? " (Disadvantage)" : ( useAdvantage ? " (Advantage)" : "" );
		var luckNote = usedLuck ? " (Lucky reroll)" : "";
		var styleNote = ( styleBonus > 0 ) ? " (Archery)" : "";
		var inspirationNote = usedInspiration ? " (Heroic Inspiration reroll)" : "";
		var coverNote = ( arguments.coverBonus > 0 ) ? " (+#arguments.coverBonus# Cover)" : "";
		var parryNote = usedParry ? " (Parried!)" : "";
		// A monster's ranged attack drawn from a Spellcasting/Innate
		// Spellcasting trait (see _buildMonsterStruct()'s isSpell flagging)
		// reads as a cast, not a mundane weapon swing — cosmetic only, the
		// attack roll/damage math underneath is unchanged.
		var actionPhrase = ( structKeyExists( arguments.weapon, "isSpell" ) && arguments.weapon.isSpell )
			? "#arguments.attacker.name# casts #arguments.weapon.name# at #arguments.defender.name#"
			: "#arguments.attacker.name# attacks #arguments.defender.name# with #arguments.weapon.name#";

		if ( !hits ) {
			arguments.log.prepend(
				"#actionPhrase#: #roll# + #arguments.weapon.attackBonus + styleBonus# = #total# vs AC #effectiveAC##coverNote##disadvantageNote##luckNote##styleNote##inspirationNote##parryNote#. Miss!"
			);
			// Weapon Mastery — Graze: a miss still deals damage equal to the
			// ability modifier used for the attack (not further modified by
			// resistance/vulnerability nuance beyond immunity, to keep this a
			// flat chip of damage as intended).
			if ( mastery == "Graze" ) {
				var grazeDamage = max( 0, _weaponAbilityMod( arguments.attacker, arguments.weapon ) );
				if ( grazeDamage > 0 && !( structKeyExists( arguments.defender, "immunities" ) && arrayFindNoCase( arguments.defender.immunities, arguments.weapon.damageType ) ) ) {
					arguments.defender.hitPoints = max( 0, arguments.defender.hitPoints - grazeDamage );
					arguments.log.prepend( "#arguments.attacker.name#'s Graze still grazes #arguments.defender.name# for #grazeDamage# #arguments.weapon.damageType# damage (#arguments.defender.hitPoints#/#arguments.defender.maxHitPoints# HP)." );
					_checkConcentration( arguments.log, arguments.defender, grazeDamage );
					_recordThreat( arguments.defender, arguments.attacker, grazeDamage );
				}
			}
			return;
		}

		var dice = parseDice( arguments.weapon.damageDice );
		var diceCount = dice.count * ( isCrit ? 2 : 1 );
		// Half-Orc Savage Attacks: one extra weapon damage die on a melee crit.
		var usedSavageAttacks = (
			isCrit && structKeyExists( arguments.weapon, "category" ) && arguments.weapon.category == "melee" &&
			structKeyExists( arguments.attacker, "hasSavageAttacks" ) && arguments.attacker.hasSavageAttacks
		);
		if ( usedSavageAttacks ) {
			diceCount += 1;
		}
		// Great Weapon Fighting: treat any 1 or 2 rolled on the weapon's damage
		// dice as a 3, for a Two-Handed or Versatile Melee weapon.
		var hasGreatWeaponFighting = structKeyExists( arguments.attacker, "feats" ) && arrayFindNoCase( arguments.attacker.feats, "Great Weapon Fighting" ) > 0;
		var usesGreatWeaponFighting = (
			hasGreatWeaponFighting && arguments.weapon.category == "melee" &&
			structKeyExists( arguments.weapon, "properties" ) &&
			( arrayFindNoCase( arguments.weapon.properties, "Two-Handed" ) > 0 || arrayFindNoCase( arguments.weapon.properties, "Versatile" ) > 0 )
		);
		var damageRoll = usesGreatWeaponFighting ? rollSumMinFace( diceCount, dice.sides, 3 ) : rollSum( diceCount, dice.sides );
		// Savage Attacker: once per turn, roll the weapon's damage dice twice
		// and use either roll — take the higher of the two.
		var usedSavageAttacker = false;
		if ( structKeyExists( arguments.attacker, "hasSavageAttacker" ) && arguments.attacker.hasSavageAttacker ) {
			var secondRoll = usesGreatWeaponFighting ? rollSumMinFace( diceCount, dice.sides, 3 ) : rollSum( diceCount, dice.sides );
			damageRoll = max( damageRoll, secondRoll );
			usedSavageAttacker = true;
		}
		// Two-Weapon Fighting off-hand attacks omit the ability modifier from
		// damage unless the attacker has the Two-Weapon Fighting feat.
		var damage = damageRoll + ( arguments.omitDamageBonus ? 0 : arguments.weapon.damageBonus );
		var savageNote = usedSavageAttacker ? " (Savage Attacker)" : "";
		var savageAttacksNote = usedSavageAttacks ? " (Savage Attacks)" : "";
		var gwfNote = usesGreatWeaponFighting ? " (Great Weapon Fighting)" : "";

		// Sneak Attack (Rogue 1): once per turn, on a hit with a Finesse or
		// ranged weapon made with Advantage, extra ceil(level/2)d6 damage
		// (doubled on a Critical Hit, same as the weapon's own dice). RAW also
		// allows it without Advantage if another of the target's enemies is
		// within 5 ft. of it — simplified away here (not modeled without
		// giving resolveAttack full battlefield adjacency), so in practice
		// this only triggers via an existing Advantage source (a Restrained/
		// Blinded/helpless/Prone-in-melee target, Pack Tactics, etc.).
		var hasSneakAttack = structKeyExists( arguments.attacker, "features" ) && arrayFindNoCase( arguments.attacker.features, "Sneak Attack" ) > 0;
		var usedSneakAttack = (
			hasSneakAttack && useAdvantage &&
			!( structKeyExists( arguments.attacker, "usedSneakAttackThisTurn" ) && arguments.attacker.usedSneakAttackThisTurn ) &&
			( arguments.weapon.category == "ranged" || ( structKeyExists( arguments.weapon, "properties" ) && arrayFindNoCase( arguments.weapon.properties, "Finesse" ) > 0 ) )
		);
		var sneakAttackNote = "";
		if ( usedSneakAttack ) {
			var sneakDiceCount = ceiling( arguments.attacker.level / 2 ) * ( isCrit ? 2 : 1 );
			var sneakDamage = rollSum( sneakDiceCount, 6 );
			damage += sneakDamage;
			arguments.attacker.usedSneakAttackThisTurn = true;
			sneakAttackNote = " +#sneakDamage# Sneak Attack";
		}

		// Rage (Barbarian): +2/+3/+4 (by level) to melee weapon damage while
		// raging — RAW ties this to Strength-based attacks specifically; this
		// app doesn't track which ability a Finesse weapon attack actually
		// used, so it's simplified to "any melee weapon while raging."
		var rageNote = "";
		if ( structKeyExists( arguments.attacker, "isRaging" ) && arguments.attacker.isRaging && arguments.weapon.category == "melee" ) {
			var rageBonus = _rageDamageBonus( arguments.attacker.level );
			damage += rageBonus;
			rageNote = " +#rageBonus# Rage";
		}

		if ( structKeyExists( arguments.defender, "immunities" ) && arrayFindNoCase( arguments.defender.immunities, arguments.weapon.damageType ) ) {
			damage = 0;
		} else {
			if ( structKeyExists( arguments.defender, "vulnerabilities" ) && arrayFindNoCase( arguments.defender.vulnerabilities, arguments.weapon.damageType ) ) {
				damage *= 2;
			}
			if ( structKeyExists( arguments.defender, "resistances" ) && arrayFindNoCase( arguments.defender.resistances, arguments.weapon.damageType ) ) {
				damage = int( damage / 2 );
			}
			// Petrified: resistance to all damage, regardless of type.
			if ( hasCondition( arguments.defender, "Petrified" ) ) {
				damage = int( damage / 2 );
			}
		}

		arguments.defender.hitPoints = max( 0, arguments.defender.hitPoints - damage );
		_checkConcentration( arguments.log, arguments.defender, damage );
		_recordThreat( arguments.defender, arguments.attacker, damage );

		arguments.log.prepend(
			"#actionPhrase#: #roll# + #arguments.weapon.attackBonus + styleBonus# = #total# vs AC #effectiveAC##coverNote##disadvantageNote##luckNote##styleNote##inspirationNote#. " &
			( isCrit ? "Critical hit! " : "Hit! " ) &
			"#damage# #arguments.weapon.damageType# damage#savageNote##savageAttacksNote##gwfNote##sneakAttackNote##rageNote# (#arguments.defender.hitPoints#/#arguments.defender.maxHitPoints# HP)."
		);

		// Weapon Mastery — everything below is a post-hit rider that doesn't
		// change the damage number already logged above.
		if ( mastery == "Sap" ) {
			arguments.defender.sapped = true;
			arguments.log.prepend( "#arguments.defender.name# is Sapped — Disadvantage on their next attack roll." );
		}
		if ( mastery == "Vex" ) {
			arguments.attacker.vexAdvantageTarget = arguments.defender.name;
			arguments.log.prepend( "#arguments.attacker.name# gains Advantage on their next attack against #arguments.defender.name# (Vex)." );
		}
		if ( mastery == "Slow" && damage > 0 ) {
			arguments.defender.speedPenalty = ( structKeyExists( arguments.defender, "speedPenalty" ) ? arguments.defender.speedPenalty : 0 ) + 10;
			arguments.log.prepend( "#arguments.defender.name#'s Speed is reduced by 10 ft. (Slow)." );
		}
		if ( mastery == "Topple" ) {
			var toppleDC = 8 + arguments.attacker.proficiencyBonus + _weaponAbilityMod( arguments.attacker, arguments.weapon );
			var toppleSave = rollSavingThrow( arguments.defender, "con", toppleDC );
			if ( !toppleSave.success ) {
				addCondition( arguments.defender, "Prone" );
				arguments.log.prepend( "#arguments.defender.name# fails a DC #toppleDC# Constitution save and topples Prone!" );
			} else {
				arguments.log.prepend( "#arguments.defender.name# succeeds on a DC #toppleDC# Constitution save and stays upright (Topple)." );
			}
		}
		if ( mastery == "Push" && !isNull( _stateGrid( arguments.state ) ) ) {
			_applyWeaponMasteryPush( arguments.log, arguments.attacker, arguments.defender, _stateGrid( arguments.state ) );
		}
		if ( mastery == "Cleave" && arguments.weapon.category == "melee" && ( structKeyExists( arguments.state, "opponent" ) || structKeyExists( arguments.state, "opponents" ) ) ) {
			_applyWeaponMasteryCleave( arguments.state, arguments.attacker, arguments.defender, arguments.weapon, damage );
		}
	}

	/**
	 * The ability modifier a weapon attack actually uses: Dexterity for a
	 * ranged weapon, the higher of Strength/Dexterity for a Finesse weapon,
	 * Strength otherwise. Used by Weapon Mastery's Graze (miss damage) and
	 * Topple (save DC), which both need the raw modifier rather than the
	 * already-computed `weapon.attackBonus` (which also bakes in Proficiency
	 * Bonus and any magic bonus).
	 */
	private function _weaponAbilityMod( attacker, weapon ) {
		if ( !structKeyExists( arguments.attacker, "modifiers" ) ) {
			return 0;
		}
		var mods = arguments.attacker.modifiers;
		var isFinesse = structKeyExists( arguments.weapon, "properties" ) && arrayFindNoCase( arguments.weapon.properties, "Finesse" ) > 0;
		if ( isFinesse ) {
			return max( mods.str, mods.dex );
		}
		return ( arguments.weapon.category == "ranged" ) ? mods.dex : mods.str;
	}

	/**
	 * Weapon Mastery — Push: shoves `defender` 2 squares (10 ft.) directly
	 * away from `attacker`, stopping early if a wall or another living
	 * combatant blocks the path (RAW's "Large or smaller" size restriction
	 * isn't modeled — this app doesn't track combatant size). A no-op if
	 * attacker and defender occupy the same square (can't compute a direction).
	 */
	private function _applyWeaponMasteryPush( log, attacker, defender, grid ) {
		var dx = arguments.defender.position.x - arguments.attacker.position.x;
		var dy = arguments.defender.position.y - arguments.attacker.position.y;
		if ( dx == 0 && dy == 0 ) {
			return;
		}
		var stepX = ( dx > 0 ) ? 1 : ( dx < 0 ? -1 : 0 );
		var stepY = ( dy > 0 ) ? 1 : ( dy < 0 ? -1 : 0 );
		var pushed = 0;
		for ( var i = 1; i <= 2; i++ ) {
			var nextX = arguments.defender.position.x + stepX;
			var nextY = arguments.defender.position.y + stepY;
			if ( !isWalkable( arguments.grid, nextX, nextY ) ) {
				break;
			}
			arguments.defender.position = { "x": nextX, "y": nextY };
			pushed += 1;
		}
		if ( pushed > 0 ) {
			arguments.log.prepend( "#arguments.defender.name# is pushed #pushed * 5# ft. away (Push)." );
		}
	}

	/**
	 * Weapon Mastery — Cleave: a melee hit also strikes one other living
	 * hostile within reach (1 square) of the original target, using the same
	 * attack roll (no second roll) and the same damage number already dealt
	 * to the first target, adjusted for the second target's own immunity/
	 * vulnerability/resistance (see _applyDamageModifiers()).
	 */
	private function _applyWeaponMasteryCleave( state, attacker, defender, weapon, damage ) {
		for ( var other in _stateOpponents( arguments.state ) ) {
			if (
				other.hitPoints <= 0 || other.name == arguments.defender.name ||
				chebyshev( arguments.defender, other ) > 1
			) {
				continue;
			}
			var cleaveDamage = _applyDamageModifiers( other, arguments.damage, arguments.weapon.damageType );
			other.hitPoints = max( 0, other.hitPoints - cleaveDamage );
			arguments.state.log.prepend(
				"#arguments.attacker.name#'s Cleave also strikes #other.name# for #cleaveDamage# #arguments.weapon.damageType# damage (#other.hitPoints#/#other.maxHitPoints# HP)."
			);
			_checkConcentration( arguments.state.log, other, cleaveDamage );
			_recordThreat( other, arguments.attacker, cleaveDamage );
			_checkDefenderDefeated( arguments.state, arguments.attacker, other, false );
			return;
		}
	}

	/**
	 * Returns `combatant`'s off-hand Light weapon for a Two-Weapon Fighting
	 * off-hand attack — requires the equipped melee weapon to also have the
	 * Light property. The off-hand candidate is either a second copy of that
	 * same weapon (e.g. two Daggers, tracked via inventory `quantity`), or any
	 * other Light-property item carried (e.g. a Dagger filed under "ranged"
	 * for its Thrown use, held in the off hand alongside a Shortsword).
	 * Returns null if no such weapon is available.
	 */
	function offHandWeapon( combatant ) {
		var mainMelee = equippedWeapon( arguments.combatant, "melee" );
		if ( isNull( mainMelee ) || !structKeyExists( mainMelee, "properties" ) || arrayFindNoCase( mainMelee.properties, "Light" ) == 0 ) {
			return javaCast( "null", 0 );
		}

		for ( var item in arguments.combatant.inventory ) {
			if ( !structKeyExists( item, "properties" ) || arrayFindNoCase( item.properties, "Light" ) == 0 ) {
				continue;
			}
			if ( item.id == mainMelee.id ) {
				if ( structKeyExists( item, "quantity" ) && item.quantity >= 2 ) {
					return item;
				}
				continue;
			}
			return item;
		}
		return javaCast( "null", 0 );
	}

	/**
	 * Two-Weapon Fighting: makes a bonus-action off-hand attack with a second
	 * Light Melee weapon, once per turn. Requires the attacker's main equipped
	 * melee weapon to also have the Light property, and to be adjacent to the
	 * opponent. Without the Two-Weapon Fighting feat, the off-hand attack
	 * doesn't add the ability modifier to damage, per the core rules.
	 *
	 * @state The encounter's full mutable game state struct.
	 */
	function offHandAttack( state ) {
		var attacker = arguments.state.player;
		var defender = arguments.state.opponent;

		var mainWeapon = equippedWeapon( attacker, "melee" );
		// Weapon Mastery — Nick: once per turn, the off-hand attack doesn't
		// cost the bonus action (still requires the Attack action to have
		// been taken, and a Light off-hand weapon, same as normal).
		var usesNick = (
			!isNull( mainWeapon ) && structKeyExists( mainWeapon, "mastery" ) && mainWeapon.mastery == "Nick" &&
			structKeyExists( attacker, "features" ) && arrayFindNoCase( attacker.features, "Weapon Mastery" ) > 0 &&
			!( structKeyExists( attacker, "usedNickThisTurn" ) && attacker.usedNickThisTurn )
		);
		if ( !usesNick && structKeyExists( arguments.state, "bonusActionUsed" ) && arguments.state.bonusActionUsed ) {
			return;
		}

		var offhand = offHandWeapon( attacker );
		if (
			isNull( mainWeapon ) || isNull( offhand ) ||
			!structKeyExists( mainWeapon, "properties" ) || arrayFindNoCase( mainWeapon.properties, "Light" ) == 0
		) {
			arguments.state.log.prepend( "#attacker.name# needs a second Light weapon to make an off-hand attack." );
			return;
		}
		if ( chebyshev( attacker, defender ) > 1 ) {
			arguments.state.log.prepend( "#attacker.name# is too far away to make an off-hand attack." );
			return;
		}

		if ( usesNick ) {
			attacker.usedNickThisTurn = true;
		} else {
			arguments.state.bonusActionUsed = true;
		}
		var hasTwoWeaponFighting = structKeyExists( attacker, "feats" ) && arrayFindNoCase( attacker.feats, "Two-Weapon Fighting" ) > 0;
		resolveAttack( arguments.state.log, attacker, defender, offhand, false, false, !hasTwoWeaponFighting, 0, arguments.state );

		if ( defender.hitPoints <= 0 ) {
			if ( !structKeyExists( defender, "xpAwarded" ) || !defender.xpAwarded ) {
				defender.xpAwarded = true;
				_awardPartyExperience( arguments.state, defender.xp );
				_incrementCharacterStat( attacker.characterId, "monsters_killed" );
				attacker.monstersKilled = ( structKeyExists( attacker, "monstersKilled" ) ? attacker.monstersKilled : 0 ) + 1;
				if ( structKeyExists( arguments.state, "round" ) ) {
					defender.defeatedAtRound = arguments.state.round;
				}
			}
			if ( _allOpponentsDefeated( arguments.state ) ) {
				arguments.state.gameOver = true;
				arguments.state.outcome = "victory";
				arguments.state.log.prepend( "#defender.name# collapses into a pile of bones. Victory!" );
			} else {
				arguments.state.log.prepend( "#defender.name# collapses into a pile of bones!" );
				_retargetIfCurrentOpponentDefeated( arguments.state );
			}
		}
	}

	/**
	 * Paladin's Smite (level 2): makes one melee weapon attack (spending the
	 * Attack action, same as playerAttack()) and, only if it actually hits
	 * (the opponent's Hit Points went down), spends a spell slot at
	 * `slotLevel` to add Divine Smite's bonus Radiant damage — 2d8 for a
	 * 1st-level slot, +1d8 per level above 1st (capped at 5d8), +1 further
	 * d8 if the target is a Fiend or Undead. No slot is spent on a miss.
	 *
	 * Simplified from the real 2024 rule (which lets you decide to smite
	 * *after* seeing the attack roll, even choosing not to on a miss to
	 * save the slot) into "commit to smiting before you know if you'll
	 * hit" — functionally identical in outcome (a miss never costs a slot
	 * either way), just without a separate post-roll prompt this app's
	 * turn structure doesn't have anywhere else either.
	 *
	 * @state The encounter's full mutable game state struct.
	 * @slotLevel The spell slot level to spend if the attack hits.
	 */
	function smiteAttack( state, slotLevel ) {
		var player = arguments.state.player;
		var opponent = arguments.state.opponent;
		if (
			player.hitPoints <= 0 || isIncapacitated( player ) ||
			!structKeyExists( player, "features" ) || arrayFindNoCase( player.features, "Paladin's Smite" ) == 0 ||
			!structKeyExists( player, "spellSlots" ) || !structKeyExists( player.spellSlots, arguments.slotLevel ) ||
			player.spellSlots[ arguments.slotLevel ] <= 0
		) {
			return;
		}
		var weapon = equippedWeapon( player, "melee" );
		if ( isNull( weapon ) ) {
			arguments.state.log.prepend( "#player.name# has no melee weapon to Smite with." );
			return;
		}

		var hpBefore = opponent.hitPoints;
		playerAttack( arguments.state, weapon, false );

		if ( !arguments.state.gameOver && opponent.hitPoints < hpBefore ) {
			player.spellSlots[ arguments.slotLevel ] -= 1;
			if ( !structKeyExists( player, "spentSpellSlots" ) ) {
				player.spentSpellSlots = {};
			}
			var lvlKey = toString( arguments.slotLevel );
			player.spentSpellSlots[ lvlKey ] = ( player.spentSpellSlots.keyExists( lvlKey ) ? player.spentSpellSlots[ lvlKey ] : 0 ) + 1;

			var isFiendOrUndead = structKeyExists( opponent, "creatureType" ) && arrayFindNoCase( [ "Fiend", "Undead" ], opponent.creatureType ) > 0;
			var diceCount = min( arguments.slotLevel + 1, 5 ) + ( isFiendOrUndead ? 1 : 0 );
			var smiteDamage = _applyDamageModifiers( opponent, rollSum( diceCount, 8 ), "Radiant" );
			opponent.hitPoints = max( 0, opponent.hitPoints - smiteDamage );
			_recordThreat( opponent, player, smiteDamage );
			arguments.state.log.prepend(
				"#player.name# calls down Divine Smite (spends a level-#arguments.slotLevel# slot)#( isFiendOrUndead ? ' against the #opponent.creatureType#' : '' )#: " &
				"#smiteDamage# Radiant damage (#opponent.hitPoints#/#opponent.maxHitPoints# HP)."
			);
			_checkDefenderDefeated( arguments.state, player, opponent, false );
		}
	}

	/**
	 * General d20-vs-DC saving throw: ability modifier plus Proficiency Bonus
	 * if the combatant is proficient in that save. Grants Advantage for Fey
	 * Ancestry (Elf) against the Charmed condition, for Gnomish Cunning (Gnome)
	 * against magical Intelligence/Wisdom/Charisma saves, for Magic Resistance
	 * against any magical save, and for Rage on Strength saves. Grants
	 * Disadvantage for Restrained specifically on Dexterity saves (Advantage
	 * and Disadvantage cancel if both apply). Paralyzed/Petrified/Stunned/
	 * Unconscious auto-fail any Strength or Dexterity save with no roll.
	 *
	 * @combatant The saving combatant (has `abilityScores` and, ideally, `modifiers`/`proficiencyBonus`/`savingThrowProficiencies`).
	 * @ability One of "str","dex","con","int","wis","cha".
	 * @dc The Difficulty Class to meet or beat.
	 * @condition Optional: the condition being saved against (e.g. "Charmed"), for Fey Ancestry.
	 * @isMagical Optional: whether this save is against a magical effect, for Gnomish Cunning and Magic Resistance.
	 * @coverBonus Optional: Half/Three-Quarters Cover bonus added to a Dexterity save against an area effect.
	 */
	function rollSavingThrow( combatant, ability, dc, condition = "", isMagical = false, coverBonus = 0 ) {
		// Paralyzed/Petrified/Stunned/Unconscious: automatically fails any
		// Strength or Dexterity saving throw, no roll needed.
		if ( listFindNoCase( "str,dex", arguments.ability ) && isHelpless( arguments.combatant ) ) {
			return { "roll": 1, "total": 1, "success": false, "hadAdvantage": false, "hadDisadvantage": false };
		}
		// Monsters carry their SRD stat block's saving throw bonus pre-computed
		// per ability (modifier + proficiency bonus already summed, straight
		// from the monsters table's str_save/dex_save/etc. columns — see
		// _buildMonsterStruct()) rather than separate proficiency flags like
		// the player has, since that's the shape the source data comes in.
		var abilityMod;
		var proficiencyBonus = 0;
		if ( structKeyExists( arguments.combatant, "savingThrowBonuses" ) ) {
			abilityMod = arguments.combatant.savingThrowBonuses[ arguments.ability ];
		} else {
			abilityMod = structKeyExists( arguments.combatant, "modifiers" )
				? arguments.combatant.modifiers[ arguments.ability ]
				: abilityModifier( arguments.combatant.abilityScores[ arguments.ability ] );

			var proficient = (
				structKeyExists( arguments.combatant, "savingThrowProficiencies" ) &&
				arrayFindNoCase( arguments.combatant.savingThrowProficiencies, _abilityFullName( arguments.ability ) ) > 0
			);
			proficiencyBonus = ( proficient && structKeyExists( arguments.combatant, "proficiencyBonus" ) ) ? arguments.combatant.proficiencyBonus : 0;
		}

		var hasAdvantage = false;
		if ( arguments.condition == "Charmed" && structKeyExists( arguments.combatant, "hasFeyAncestry" ) && arguments.combatant.hasFeyAncestry ) {
			hasAdvantage = true;
		}
		if (
			arguments.isMagical && listFindNoCase( "int,wis,cha", arguments.ability ) &&
			structKeyExists( arguments.combatant, "hasGnomishCunning" ) && arguments.combatant.hasGnomishCunning
		) {
			hasAdvantage = true;
		}
		// Magic Resistance (e.g. many demons/devils/dragons): Advantage on
		// saving throws against spells and other magical effects — any
		// ability, not just Int/Wis/Cha like Gnomish Cunning.
		if (
			arguments.isMagical &&
			structKeyExists( arguments.combatant, "hasMagicResistance" ) && arguments.combatant.hasMagicResistance
		) {
			hasAdvantage = true;
		}
		// Rage: Advantage on Strength saving throws while raging.
		if ( arguments.ability == "str" && structKeyExists( arguments.combatant, "isRaging" ) && arguments.combatant.isRaging ) {
			hasAdvantage = true;
		}
		// Restrained: Disadvantage specifically on Dexterity saves.
		var hasDisadvantage = ( arguments.ability == "dex" ) && hasCondition( arguments.combatant, "Restrained" );

		var useAdvantage = hasAdvantage && !hasDisadvantage;
		var useDisadvantage = hasDisadvantage && !hasAdvantage;

		var roll = randRange( 1, 20 );
		if ( useAdvantage ) {
			roll = max( roll, randRange( 1, 20 ) );
		} else if ( useDisadvantage ) {
			roll = min( roll, randRange( 1, 20 ) );
		}
		// Cover (Half/Three-Quarters) also applies to Dexterity saves against
		// area effects, per the "Cover" rules — this app only models Half Cover.
		var coverAdjustment = ( arguments.ability == "dex" ) ? arguments.coverBonus : 0;
		var total = roll + abilityMod + proficiencyBonus + coverAdjustment;
		return { "roll": roll, "total": total, "success": ( total >= arguments.dc ), "hadAdvantage": useAdvantage, "hadDisadvantage": useDisadvantage };
	}

	/**
	 * Maps an ability abbreviation ("str") to its full SRD name ("Strength"),
	 * matching the format `savingThrowProficiencies` is stored in.
	 */
	private function _abilityFullName( abbreviation ) {
		var names = { "str": "Strength", "dex": "Dexterity", "con": "Constitution", "int": "Intelligence", "wis": "Wisdom", "cha": "Charisma" };
		return names[ arguments.abbreviation ];
	}

	/**
	 * Attempts to grapple `defender` (a contested Strength (Athletics) check
	 * vs. the defender's better of Strength (Athletics) or Dexterity
	 * (Acrobatics) — Proficiency Bonus applies on either side only if that
	 * combatant is actually proficient in the relevant skill, per
	 * _skillProficiencyBonus()), spending the attacker's action. Requires the
	 * attacker to already be adjacent. On success, marks `defender.
	 * grappledBy` (subsequent attacks by the same attacker get Advantage if
	 * the attacker has the Grappler feat) and applies the Restrained
	 * condition — a grappled creature is Restrained per the core rules,
	 * which also grants Advantage to anyone attacking it, not just the
	 * Grappler-feat attacker, and Disadvantage on the grappled creature's own
	 * attacks and Dexterity saves.
	 *
	 * @state The encounter's full mutable game state struct.
	 * @attacker The grappling combatant.
	 * @defender The combatant being grappled.
	 */
	function attemptGrapple( state, attacker, defender ) {
		if ( chebyshev( arguments.attacker, arguments.defender ) > 1 ) {
			arguments.state.log.prepend( "#arguments.attacker.name# is too far away to grapple #arguments.defender.name#." );
			return;
		}

		var attackerStrMod = structKeyExists( arguments.attacker, "modifiers" ) ? arguments.attacker.modifiers.str : abilityModifier( arguments.attacker.abilityScores.str );
		var defenderStrMod = structKeyExists( arguments.defender, "modifiers" ) ? arguments.defender.modifiers.str : abilityModifier( arguments.defender.abilityScores.str );
		var defenderDexMod = structKeyExists( arguments.defender, "modifiers" ) ? arguments.defender.modifiers.dex : abilityModifier( arguments.defender.abilityScores.dex );

		var attackerRoll = randRange( 1, 20 ) + attackerStrMod + _skillProficiencyBonus( arguments.attacker, "Athletics" );
		var defenderAthleticsRoll = defenderStrMod + _skillProficiencyBonus( arguments.defender, "Athletics" );
		var defenderAcrobaticsRoll = defenderDexMod + _skillProficiencyBonus( arguments.defender, "Acrobatics" );
		var defenderRoll = randRange( 1, 20 ) + max( defenderAthleticsRoll, defenderAcrobaticsRoll );
		var success = attackerRoll >= defenderRoll;

		arguments.state.actionUsed = true;
		if ( success ) {
			arguments.defender.grappledBy = arguments.attacker.name;
			addCondition( arguments.defender, "Restrained" );
		}

		arguments.state.log.prepend(
			"#arguments.attacker.name# attempts to grapple #arguments.defender.name#: #attackerRoll# vs #defenderRoll# — " &
			( success ? "Grappled!" : "#arguments.defender.name# resists." )
		);
	}

	/**
	 * Attempts to shove `defender` prone (a contested Strength (Athletics)
	 * check vs. the defender's better of Strength (Athletics) or Dexterity
	 * (Acrobatics), simplified the same way as attemptGrapple — Proficiency
	 * Bonus only applies where each combatant is actually proficient),
	 * spending the attacker's action. Requires the attacker to already be
	 * adjacent. On success, applies the Prone condition — melee attacks
	 * against a Prone target get Advantage, ranged ones get Disadvantage,
	 * and the Prone creature's own attacks have Disadvantage until it stands
	 * back up (this app has no stand-up action yet, so Prone otherwise
	 * persists for the fight once applied).
	 *
	 * @state The encounter's full mutable game state struct.
	 * @attacker The shoving combatant.
	 * @defender The combatant being shoved.
	 */
	function attemptShove( state, attacker, defender ) {
		if ( chebyshev( arguments.attacker, arguments.defender ) > 1 ) {
			arguments.state.log.prepend( "#arguments.attacker.name# is too far away to shove #arguments.defender.name#." );
			return;
		}

		var attackerStrMod = structKeyExists( arguments.attacker, "modifiers" ) ? arguments.attacker.modifiers.str : abilityModifier( arguments.attacker.abilityScores.str );
		var defenderStrMod = structKeyExists( arguments.defender, "modifiers" ) ? arguments.defender.modifiers.str : abilityModifier( arguments.defender.abilityScores.str );
		var defenderDexMod = structKeyExists( arguments.defender, "modifiers" ) ? arguments.defender.modifiers.dex : abilityModifier( arguments.defender.abilityScores.dex );

		var attackerRoll = randRange( 1, 20 ) + attackerStrMod + _skillProficiencyBonus( arguments.attacker, "Athletics" );
		var defenderAthleticsRoll = defenderStrMod + _skillProficiencyBonus( arguments.defender, "Athletics" );
		var defenderAcrobaticsRoll = defenderDexMod + _skillProficiencyBonus( arguments.defender, "Acrobatics" );
		var defenderRoll = randRange( 1, 20 ) + max( defenderAthleticsRoll, defenderAcrobaticsRoll );
		var success = attackerRoll >= defenderRoll;

		arguments.state.actionUsed = true;
		if ( success ) {
			addCondition( arguments.defender, "Prone" );
		}

		arguments.state.log.prepend(
			"#arguments.attacker.name# attempts to shove #arguments.defender.name#: #attackerRoll# vs #defenderRoll# — " &
			( success ? "Knocked Prone!" : "#arguments.defender.name# resists." )
		);
	}

	/**
	 * Dragonborn Breath Weapon: once per encounter, exhale a blast that deals
	 * 2d6 damage (of the character's draconic ancestry's type — simplified to
	 * Fire here, since ancestry choice isn't tracked) to the opponent, who
	 * makes a Dexterity save (DC 8 + Proficiency Bonus + Constitution modifier)
	 * for half damage. Spends the attacker's action.
	 *
	 * @state The encounter's full mutable game state struct.
	 */
	function useBreathWeapon( state ) {
		var attacker = arguments.state.player;
		var defender = arguments.state.opponent;
		if ( !structKeyExists( attacker, "hasBreathWeapon" ) || !attacker.hasBreathWeapon || attacker.usedBreathWeapon ) {
			return;
		}

		attacker.usedBreathWeapon = true;
		arguments.state.actionUsed = true;

		var dc = 8 + attacker.proficiencyBonus + attacker.modifiers.con;
		var defenderDexMod = structKeyExists( defender, "modifiers" ) ? defender.modifiers.dex : abilityModifier( defender.abilityScores.dex );
		var saveRoll = randRange( 1, 20 ) + defenderDexMod;
		var saved = ( saveRoll >= dc );

		var damage = rollSum( 2, 6 );
		if ( saved ) {
			damage = int( damage / 2 );
		}
		if ( structKeyExists( defender, "immunities" ) && arrayFindNoCase( defender.immunities, "Fire" ) ) {
			damage = 0;
		} else {
			if ( structKeyExists( defender, "vulnerabilities" ) && arrayFindNoCase( defender.vulnerabilities, "Fire" ) ) {
				damage *= 2;
			}
			if ( structKeyExists( defender, "resistances" ) && arrayFindNoCase( defender.resistances, "Fire" ) ) {
				damage = int( damage / 2 );
			}
		}

		defender.hitPoints = max( 0, defender.hitPoints - damage );
		_checkConcentration( arguments.state.log, defender, damage );
		_recordThreat( defender, attacker, damage );
		arguments.state.log.prepend(
			"#attacker.name# exhales a blast of fire! #defender.name# rolls a DC #dc# Dexterity save: #saveRoll# — " &
			( saved ? "succeeds, takes half damage. " : "fails! " ) &
			"#damage# Fire damage (#defender.hitPoints#/#defender.maxHitPoints# HP)."
		);
		_checkDefenderDefeated( arguments.state, attacker, defender, false );
	}

	/**
	 * Assigns `player`'s spellcasting fields — spellcasting ability, known
	 * cantrips/leveled spells (arrays — see `player.knownCantrips`/
	 * `knownLeveledSpells`), and starting spell slots by level — from its
	 * class (via ICONIC_CANTRIP_BY_CLASS, _lookupClassSpell(), and the slot
	 * tables) plus the Magic Initiate feat, if any. Spell slots are computed
	 * fresh each time a character is loaded, then reduced by whatever's
	 * already been spent this rest cycle (`player.spentSpellSlots`, restored
	 * by loadCharacter() from the persisted column, cleared by longRest()).
	 *
	 * If the player has chosen cantrips/spells (via character creation or
	 * chooseCantrip()/chooseSpell() at level-up — stored on `player.
	 * knownCantripNames`/`knownSpellNames` by loadCharacter(), from the
	 * `characters.known_cantrips`/`known_spells` columns), those exact
	 * spells are used instead of the auto-pick — falling back to the old
	 * iconic/heal-preferring single auto-pick (as this character's only
	 * known cantrip/spell) only for a full caster with nothing chosen yet
	 * (character creation always offers a full caster a Spells step, so an
	 * empty list there only means "created before that step existed") or a
	 * non-caster with Magic Initiate. A half-caster (Paladin, Ranger) never
	 * gets a creation-time pick — auto-picking for them here would violate
	 * the "never auto-assign a player choice" rule, so they're left with an
	 * empty list until pendingSpellChoice()/chooseSpell() gives them one
	 * once their first spell slot actually unlocks (level 2).
	 */
	private function _assignSpellcasting( player ) {
		var className = arguments.player.class;
		var isFullCaster = isFullCasterClass( className );
		var isHalfCaster = arrayFindNoCase( HALF_CASTER_CLASSES, className ) > 0;

		// Multiclassing: a character can be a caster via ANY of their
		// classes — spellcasting ability comes from whichever caster class
		// has the higher level (ties favor the earlier-taken one). Real SRD
		// spells still use their own class's ability; this app keeps a
		// single spellcastingAbility value per character (see WIP.md's
		// multiclassing section) rather than tracking it per known spell.
		if ( structKeyExists( arguments.player, "classes" ) && arguments.player.classes.len() > 1 ) {
			var bestCasterClass = javaCast( "null", 0 );
			for ( var classEntry in arguments.player.classes ) {
				var entryIsCaster = isFullCasterClass( classEntry.className ) || arrayFindNoCase( HALF_CASTER_CLASSES, classEntry.className ) > 0;
				if ( entryIsCaster && ( isNull( bestCasterClass ) || classEntry.level > bestCasterClass.level ) ) {
					bestCasterClass = classEntry;
				}
			}
			isFullCaster = !isNull( bestCasterClass ) && isFullCasterClass( bestCasterClass.className );
			isHalfCaster = !isNull( bestCasterClass ) && arrayFindNoCase( HALF_CASTER_CLASSES, bestCasterClass.className ) > 0;
			className = isNull( bestCasterClass ) ? className : bestCasterClass.className;
		}

		arguments.player.isSpellcaster = isFullCaster || isHalfCaster || arguments.player.hasMagicInitiate;
		arguments.player.spellcastingAbility = SPELLCASTING_ABILITY_BY_CLASS.keyExists( className )
			? SPELLCASTING_ABILITY_BY_CLASS[ className ]
			: "";
		if ( !len( arguments.player.spellcastingAbility ) && arguments.player.hasMagicInitiate ) {
			// Magic Initiate doesn't track which ability was chosen; use whichever
			// of Intelligence, Wisdom, or Charisma is highest.
			var mods = arguments.player.modifiers;
			arguments.player.spellcastingAbility = ( mods.int >= mods.wis && mods.int >= mods.cha ) ? "int" : ( mods.wis >= mods.cha ? "wis" : "cha" );
		}

		var chosenCantripNames = structKeyExists( arguments.player, "knownCantripNames" ) ? arguments.player.knownCantripNames : [];
		arguments.player.knownCantrips = [];
		for ( var cantripName in chosenCantripNames ) {
			var dbCantrip = lookupSpellByName( cantripName );
			if ( !isNull( dbCantrip ) ) {
				arguments.player.knownCantrips.append( dbCantrip );
			}
		}
		if ( !arguments.player.knownCantrips.len() ) {
			// The auto-pick fallback below only applies to a full caster (whose
			// character-creation Spells step always makes a choice, so an empty
			// list here only ever means "a character predating that step") or a
			// non-caster with Magic Initiate. A half-caster (Paladin, Ranger)
			// never gets a creation-time pick at all — falling back here would
			// silently auto-assign their very first spell/cantrip, violating
			// the "never auto-assign a player choice" rule. They rely entirely
			// on pendingCantripChoice()/pendingSpellChoice() instead, which
			// only start reporting anything once they actually reach a level
			// that grants one — Paladin/Ranger never get cantrips at all, so
			// pendingCantripChoice() correctly never applies to them either.
			var preferredCantrip = ICONIC_CANTRIP_BY_CLASS.keyExists( className ) ? ICONIC_CANTRIP_BY_CLASS[ className ] : "";
			var autoCantrip = isFullCaster ? _lookupClassSpell( className, 0, false, preferredCantrip ) : javaCast( "null", 0 );
			if ( !isNull( autoCantrip ) ) {
				arguments.player.knownCantrips.append( autoCantrip );
			} else if ( arguments.player.hasMagicInitiate ) {
				// Fire Bolt: 120 ft.
				arguments.player.knownCantrips.append( { "type": "attack", "name": "Fire Bolt", "level": 0, "concentration": false, "damageType": "Fire", "rangeSquares": 24 } );
			}
		}

		var chosenSpellNames = structKeyExists( arguments.player, "knownSpellNames" ) ? arguments.player.knownSpellNames : [];
		arguments.player.knownLeveledSpells = [];
		for ( var spellName in chosenSpellNames ) {
			var dbSpell = lookupSpellByName( spellName );
			if ( !isNull( dbSpell ) ) {
				arguments.player.knownLeveledSpells.append( dbSpell );
			}
		}
		if ( !arguments.player.knownLeveledSpells.len() ) {
			// Same reasoning as the cantrip fallback above: only a full caster
			// (always offered a creation-time pick) or Magic Initiate gets an
			// auto-pick here. A half-caster with nothing chosen yet is left
			// with an empty list — pendingSpellChoice() picks it up as soon as
			// their first spell slot (level 2) unlocks, and stays pending until
			// they actually choose one via the character sheet.
			var preferHeal = arrayFindNoCase( HEAL_PREFERRING_CLASSES, className ) > 0;
			var autoSpell = isFullCaster ? _lookupClassSpell( className, 1, preferHeal ) : javaCast( "null", 0 );
			if ( !isNull( autoSpell ) ) {
				arguments.player.knownLeveledSpells.append( autoSpell );
			} else if ( arguments.player.hasMagicInitiate ) {
				// Magic Missile: 120 ft.
				arguments.player.knownLeveledSpells.append( { "type": "damage", "name": "Magic Missile", "level": 1, "concentration": false, "rangeSquares": 24 } );
			}
		}

		_recomputeSpellSlots( arguments.player );
		// Magic Initiate's bonus 1st-level spell is a separate resource, not a
		// slot — usable even by a class with no slots at all. It recovers on a
		// Long Rest only (see longRest()); loadCharacter() sets its persisted
		// used/unused state, so this function leaves it alone rather than
		// resetting it on every load.
	}

	/**
	 * Combined "Multiclass Spellcaster" caster level across every class in
	 * `player.classes`, per the Multiclassing rules: a full-caster class
	 * contributes its whole level, a half-caster (Paladin, Ranger)
	 * contributes floor(level / 2), anything else contributes nothing.
	 * Only meaningful once a character has more than one class — see the
	 * caller in _recomputeSpellSlots(). Public (like hasSpellResource())
	 * purely so this easy-to-get-wrong arithmetic (fractional caster levels
	 * from half-casters, deliberately NOT matching a solo half-caster's own
	 * table at some levels — see _recomputeSpellSlots()'s note) has a direct
	 * unit test.
	 */
	function multiclassCasterLevel( player ) {
		var total = 0;
		for ( var classEntry in arguments.player.classes ) {
			if ( isFullCasterClass( classEntry.className ) ) {
				total += classEntry.level;
			} else if ( arrayFindNoCase( HALF_CASTER_CLASSES, classEntry.className ) > 0 ) {
				total += int( classEntry.level / 2 );
			}
		}
		return total;
	}

	/**
	 * (Re)computes `player.spellSlots` from the full/half-caster slot tables
	 * at their current level, then subtracts whatever's already been spent
	 * this rest cycle (`player.spentSpellSlots`). Factored out of
	 * _assignSpellcasting() so _levelUp() can also call it — a level-up
	 * happening mid-encounter (a Paladin reaching level 2 by killing the
	 * monster in front of them, say) needs its new/increased slot count to
	 * take effect immediately, not just the next time the character is
	 * loaded fresh into a new encounter.
	 */
	private function _recomputeSpellSlots( player ) {
		var slotTable = [];
		var levelIndex = 0;
		// Multiclassing: the combined "Multiclass Spellcaster" slot table is
		// mechanically identical to the full-caster progression, indexed by
		// an effective caster level (see multiclassCasterLevel()) instead
		// of a single class's own level. A single-class character (still
		// the overwhelming default) keeps using its own class's table
		// directly and unchanged — the combined formula is a deliberately
		// worse fit than a half-caster's own table at some levels (a real
		// RAW quirk of multiclassing, not a bug), so it must only apply once
		// there's actually more than one class to combine.
		if ( structKeyExists( arguments.player, "classes" ) && arguments.player.classes.len() > 1 ) {
			slotTable = SPELL_SLOTS_FULL_CASTER;
			levelIndex = min( multiclassCasterLevel( arguments.player ), slotTable.len() );
		} else {
			var className = arguments.player.class;
			var isFullCaster = isFullCasterClass( className );
			var isHalfCaster = arrayFindNoCase( HALF_CASTER_CLASSES, className ) > 0;
			slotTable = isFullCaster ? SPELL_SLOTS_FULL_CASTER : ( isHalfCaster ? SPELL_SLOTS_HALF_CASTER : [] );
			levelIndex = min( arguments.player.level, slotTable.len() );
		}
		arguments.player.spellSlots = {};
		if ( levelIndex > 0 ) {
			var slotsAtLevel = slotTable[ levelIndex ];
			for ( var spellLevel = 1; spellLevel <= slotsAtLevel.len(); spellLevel++ ) {
				arguments.player.spellSlots[ spellLevel ] = slotsAtLevel[ spellLevel ];
			}
		}
		// Subtract any slots already spent this encounter/rest cycle.
		if ( structKeyExists( arguments.player, "spentSpellSlots" ) ) {
			for ( var spentLvl in arguments.player.spentSpellSlots ) {
				if ( structKeyExists( arguments.player.spellSlots, spentLvl ) ) {
					arguments.player.spellSlots[ spentLvl ] = max( 0, arguments.player.spellSlots[ spentLvl ] - arguments.player.spentSpellSlots[ spentLvl ] );
				}
			}
		}
	}

	/**
	 * Looks up one castable spell of `level` for `className` from the
	 * gameserver.spells table's structured mechanics columns (added by
	 * migrations/002_spell_mechanics.sql and populated by
	 * resources/database/extract_spell_mechanics.py) — a real attack-roll,
	 * saving-throw, or healing spell instead of this app's old fixed-per-class
	 * Magic Missile/Cure Wounds stand-ins. Prefers a `heal` spell when
	 * `preferHeal` is true and one's available for the class, otherwise an
	 * `attack`/`save` damage spell; falls back to whichever effect type IS
	 * available if the preferred one isn't. Skips any spell whose dice don't
	 * parse as plain "NdM" (e.g. Disintegrate's "10d6 + 40") — not a concern
	 * at level 1 today, but a safety net if this is ever asked for higher
	 * levels. Returns null if the class has no non-utility spell at that level.
	 *
	 * @className The class to find a spell for (must match a name in the spells table's `classes` column).
	 * @level The spell's level (0 for cantrips, 1-9 otherwise).
	 * @preferHeal Whether to prefer a heal-type spell over an attack/save one, when both are available.
	 * @preferredName If a spell by this exact name matches, it wins over any other candidate — lets a class keep its iconic pick (Fire Bolt, Eldritch Blast, Sacred Flame) when the class has more than one option, without hardcoding the spell's own mechanics.
	 */
	private function _lookupClassSpell( className, level, preferHeal, preferredName = "" ) {
		var preferredTypes = arguments.preferHeal ? "'heal'" : "'attack','save'";
		var rows = queryExecute(
			"SELECT name, level, duration, effect_type, attack_type, save_ability, save_effect, damage_dice, damage_type, heal_dice, `range`
			 FROM spells
			 WHERE FIND_IN_SET( :className, REPLACE( classes, ', ', ',' ) ) > 0
			   AND level = :level
			   AND effect_type IN ( #preferredTypes# )
			   AND ( damage_dice IS NULL OR damage_dice REGEXP '^[0-9]+d[0-9]+$' )
			   AND ( heal_dice IS NULL OR heal_dice REGEXP '^[0-9]+d[0-9]+$' )
			 ORDER BY ( name = :preferredName ) DESC, name
			 LIMIT 1",
			{ "className": arguments.className, "level": arguments.level, "preferredName": arguments.preferredName },
			{ datasource: "gameserver" }
		);

		if ( rows.recordCount == 0 ) {
			// Try the other effect type before giving up — e.g. Warlock only
			// has a damage spell at level 1, no heal, even though Warlock
			// isn't in HEAL_PREFERRING_CLASSES anyway; this also covers a
			// heal-preferring class whose only level-1 option is a damage spell.
			var fallbackTypes = arguments.preferHeal ? "'attack','save'" : "'heal'";
			rows = queryExecute(
				"SELECT name, level, duration, effect_type, attack_type, save_ability, save_effect, damage_dice, damage_type, heal_dice, `range`
				 FROM spells
				 WHERE FIND_IN_SET( :className, REPLACE( classes, ', ', ',' ) ) > 0
				   AND level = :level
				   AND effect_type IN ( #fallbackTypes# )
				   AND ( damage_dice IS NULL OR damage_dice REGEXP '^[0-9]+d[0-9]+$' )
				   AND ( heal_dice IS NULL OR heal_dice REGEXP '^[0-9]+d[0-9]+$' )
				 ORDER BY ( name = :preferredName ) DESC, name
				 LIMIT 1",
				{ "className": arguments.className, "level": arguments.level, "preferredName": arguments.preferredName },
				{ datasource: "gameserver" }
			);
		}

		if ( rows.recordCount == 0 ) {
			return javaCast( "null", 0 );
		}
		return _spellStructFromRow( rows, 1 );
	}

	/**
	 * Converts one row of a `spells` query (with the standard SELECT list
	 * used throughout this file — name, level, duration, effect_type,
	 * attack_type, save_ability, save_effect, damage_dice, damage_type,
	 * heal_dice, `range`) into the discriminated struct shape castCantrip()/
	 * castLeveledSpell()/_runOneOpponentTurn() all expect. Shared by
	 * _lookupClassSpell() (picks one row), listCastableSpells() (every
	 * matching row), and lookupSpellByName() (one row by exact name).
	 *
	 * `level` lets castLeveledSpell() spend the correct-level slot
	 * instead of always assuming 1st; `concentration` (derived from the
	 * `duration` text, e.g. "Concentration, up to 1 minute" — there's no
	 * dedicated boolean column) drives the single-concentration-spell rule
	 * in _startConcentrating().
	 */
	private function _spellStructFromRow( rows, i ) {
		var level = arguments.rows.level[ arguments.i ];
		var concentration = findNoCase( "Concentration", arguments.rows.duration[ arguments.i ] ) > 0;
		if ( arguments.rows.effect_type[ arguments.i ] == "heal" ) {
			var healDice = parseDice( arguments.rows.heal_dice[ arguments.i ] );
			return { "type": "heal", "name": arguments.rows.name[ arguments.i ], "level": level, "concentration": concentration, "diceCount": healDice.count, "diceSides": healDice.sides };
		}

		var damageDice = parseDice( arguments.rows.damage_dice[ arguments.i ] );
		var rangeSquares = _parseSpellRangeSquares( arguments.rows.range[ arguments.i ] );
		if ( arguments.rows.effect_type[ arguments.i ] == "attack" ) {
			return {
				"type": "attack", "name": arguments.rows.name[ arguments.i ], "level": level, "concentration": concentration, "damageType": arguments.rows.damage_type[ arguments.i ],
				"diceCount": damageDice.count, "diceSides": damageDice.sides, "rangeSquares": rangeSquares
			};
		}
		return {
			"type": "save", "name": arguments.rows.name[ arguments.i ], "level": level, "concentration": concentration, "damageType": arguments.rows.damage_type[ arguments.i ],
			"saveAbility": arguments.rows.save_ability[ arguments.i ], "saveEffect": arguments.rows.save_effect[ arguments.i ],
			"diceCount": damageDice.count, "diceSides": damageDice.sides, "rangeSquares": rangeSquares
		};
	}

	/**
	 * Lists every castable (non-utility, plain-"NdM"-dice) spell `className`
	 * has available at `level` (0 for cantrips, 1 for 1st-level spells) — the
	 * options a player picks from at character creation (see
	 * app/wires/characterCreation.bx). Each entry is the same struct shape
	 * `player.knownCantrip`/`knownLeveledSpell` use in combat.
	 *
	 * @className The class to list spells for (must match a name in the spells table's `classes` column).
	 * @level The spell's level (0 for cantrips, 1-9 otherwise).
	 */
	function listCastableSpells( className, level ) {
		var rows = queryExecute(
			"SELECT name, level, duration, effect_type, attack_type, save_ability, save_effect, damage_dice, damage_type, heal_dice, `range`
			 FROM spells
			 WHERE FIND_IN_SET( :className, REPLACE( classes, ', ', ',' ) ) > 0
			   AND level = :level
			   AND effect_type IN ( 'attack', 'save', 'heal' )
			   AND ( damage_dice IS NULL OR damage_dice REGEXP '^[0-9]+d[0-9]+$' )
			   AND ( heal_dice IS NULL OR heal_dice REGEXP '^[0-9]+d[0-9]+$' )
			 ORDER BY name",
			{ "className": arguments.className, "level": arguments.level },
			{ datasource: "gameserver" }
		);
		var results = [];
		for ( var i = 1; i <= rows.recordCount; i++ ) {
			results.append( _spellStructFromRow( rows, i ) );
		}
		return results;
	}

	/**
	 * Looks up one specific castable spell by its exact name — used to
	 * resolve one of a character's stored `known_cantrips`/`known_spells` choices (see
	 * loadCharacter()) into full casting mechanics. Returns null if there's
	 * no such castable spell (e.g. the name doesn't exist, or is a
	 * utility-only spell this app can't mechanize).
	 *
	 * @name The spell's exact name, as stored in the `spells` table.
	 */
	function lookupSpellByName( name ) {
		var rows = queryExecute(
			"SELECT name, level, duration, effect_type, attack_type, save_ability, save_effect, damage_dice, damage_type, heal_dice, `range`
			 FROM spells
			 WHERE name = :name
			   AND effect_type IN ( 'attack', 'save', 'heal' )
			   AND ( damage_dice IS NULL OR damage_dice REGEXP '^[0-9]+d[0-9]+$' )
			   AND ( heal_dice IS NULL OR heal_dice REGEXP '^[0-9]+d[0-9]+$' )
			 LIMIT 1",
			{ "name": arguments.name },
			{ datasource: "gameserver" }
		);
		if ( rows.recordCount == 0 ) {
			return javaCast( "null", 0 );
		}
		return _spellStructFromRow( rows, 1 );
	}

	/**
	 * Whether `className` is one of the six full-caster classes (Bard,
	 * Cleric, Druid, Sorcerer, Warlock, Wizard) — the only classes with any
	 * spells to choose at 1st level (half-casters get their first spell
	 * slot at 2nd, per SPELL_SLOTS_HALF_CASTER). Public so the
	 * character-creation wire can decide whether to show the Spells step.
	 */
	function isFullCasterClass( className ) {
		return arrayFindNoCase( FULL_CASTER_CLASSES, arguments.className ) > 0;
	}

	// A cone/cube/line AoE centered on the caster (Burning Hands, Thunderwave,
	// etc.) shows up in the spells table as Range "Self" — that's the origin
	// point for the shape, not "must be adjacent". This app doesn't model
	// spell shapes/areas at all, so as a stand-in, "Self"-range damage/save
	// spells get treated as reaching this many squares (15 ft, the smallest
	// common cone/cube size in the SRD) instead of 0.
	SELF_RANGE_SPELL_SQUARES = 3;

	/**
	 * Converts a spells-table Range string ("120 feet", "Touch", "Self", ...)
	 * into a distance in 5-foot squares, for range-checking a cast against
	 * chebyshev(attacker, defender). "Touch" is 1 square (melee range);
	 * "Self" is SELF_RANGE_SPELL_SQUARES (see above); anything unparseable
	 * falls back to 24 squares (120 ft, the most common attack-cantrip range)
	 * rather than blocking a spell this app already decided was castable.
	 */
	private function _parseSpellRangeSquares( rangeText ) {
		if ( arguments.rangeText == "Touch" ) {
			return 1;
		}
		if ( arguments.rangeText == "Self" ) {
			return SELF_RANGE_SPELL_SQUARES;
		}
		var feetMatch = reFind( "(\d+)\s*feet", arguments.rangeText, 1, true );
		if ( structKeyExists( feetMatch, "len" ) && feetMatch.len.len() >= 2 && feetMatch.len[ 2 ] > 0 ) {
			var feet = int( mid( arguments.rangeText, feetMatch.pos[ 2 ], feetMatch.len[ 2 ] ) );
			return int( feet / 5 );
		}
		return 24;
	}

	/**
	 * Spends the lowest available spell slot at or above `minimumLevel`.
	 * Returns the slot level spent, or 0 if none are available.
	 */
	private function _spendSpellSlot( player, minimumLevel ) {
		for ( var level = arguments.minimumLevel; level <= 9; level++ ) {
			if ( structKeyExists( arguments.player.spellSlots, level ) && arguments.player.spellSlots[ level ] > 0 ) {
				arguments.player.spellSlots[ level ] -= 1;
				if ( !structKeyExists( arguments.player, "spentSpellSlots" ) ) {
					arguments.player.spentSpellSlots = {};
				}
				var lvlKey = toString( level );
				arguments.player.spentSpellSlots[ lvlKey ] = ( arguments.player.spentSpellSlots.keyExists( lvlKey ) ? arguments.player.spentSpellSlots[ lvlKey ] : 0 ) + 1;
				return level;
			}
		}
		return 0;
	}

	/**
	 * True if `combatant` could actually cast a spell right now — a slot at
	 * or above `minimumLevel`, or an unused Magic Initiate bonus spell.
	 * Doesn't spend anything; lets the enemy AI decide whether casting is
	 * worth attempting before committing to it via _castLeveledSpellFor(),
	 * and lets the combat screen disable a "Cast" button for a leveled
	 * spell it can't actually pay for right now.
	 */
	function hasSpellResource( combatant, minimumLevel ) {
		if ( structKeyExists( arguments.combatant, "spellSlots" ) ) {
			for ( var level = arguments.minimumLevel; level <= 9; level++ ) {
				if ( structKeyExists( arguments.combatant.spellSlots, level ) && arguments.combatant.spellSlots[ level ] > 0 ) {
					return true;
				}
			}
		}
		return (
			structKeyExists( arguments.combatant, "hasMagicInitiate" ) && arguments.combatant.hasMagicInitiate &&
			!arguments.combatant.usedMagicInitiateSpell
		);
	}

	/**
	 * Starts `combatant` concentrating on `spellName`, ending whatever they
	 * were concentrating on before — a creature can only concentrate on one
	 * spell at a time, per the "Concentration" rules. No spell in this
	 * app's data currently has a sustained combat effect (no ongoing
	 * buff/debuff like Bless or Hunter's Mark is modeled), so ending a
	 * prior spell here is bookkeeping and a log line, not an active effect
	 * removal — see _checkConcentration() for the other half of this rule.
	 */
	private function _startConcentrating( state, combatant, spellName ) {
		if (
			structKeyExists( arguments.combatant, "concentratingOn" ) && len( arguments.combatant.concentratingOn ) &&
			arguments.combatant.concentratingOn != arguments.spellName
		) {
			arguments.state.log.prepend( "#arguments.combatant.name#'s concentration on #arguments.combatant.concentratingOn# ends." );
		}
		arguments.combatant.concentratingOn = arguments.spellName;
	}

	/**
	 * Rolls a Constitution saving throw (DC = the higher of 10 or half the
	 * damage just taken, per the "Concentration" rules) to maintain
	 * concentration — a no-op if `combatant` isn't concentrating on
	 * anything, or took no damage. Ends concentration (clearing
	 * `concentratingOn` and logging it) on a failed save.
	 */
	private function _checkConcentration( log, combatant, damageTaken ) {
		if (
			!structKeyExists( arguments.combatant, "concentratingOn" ) || !len( arguments.combatant.concentratingOn ) ||
			arguments.damageTaken <= 0
		) {
			return;
		}
		var dc = max( 10, int( arguments.damageTaken / 2 ) );
		var result = rollSavingThrow( arguments.combatant, "con", dc );
		if ( result.success ) {
			arguments.log.prepend( "#arguments.combatant.name# maintains concentration on #arguments.combatant.concentratingOn# (DC #dc# Constitution save)." );
		} else {
			arguments.log.prepend( "#arguments.combatant.name# loses concentration on #arguments.combatant.concentratingOn# (failed a DC #dc# Constitution save)." );
			arguments.combatant.concentratingOn = "";
		}
	}

	/**
	 * True if `attacker` could actually reach `defender` with `spell` right
	 * now — within `spell.rangeSquares` (defaulting to 24/120 ft. if the
	 * struct doesn't carry one — the hardcoded Magic Initiate/monster
	 * fallbacks always do, so this only matters for stray callers), and with
	 * a clear line of sight if a grid is in play. Healing spells always
	 * target the caster, so they're always valid regardless of `defender`.
	 */
	private function _isSpellTargetValid( state, attacker, defender, spell ) {
		if ( arguments.spell.type == "heal" ) {
			return true;
		}
		var rangeSquares = structKeyExists( arguments.spell, "rangeSquares" ) ? arguments.spell.rangeSquares : 24;
		if ( chebyshev( arguments.attacker, arguments.defender ) > rangeSquares ) {
			return false;
		}
		var grid = _stateGrid( arguments.state );
		return isNull( grid ) || hasLineOfSight( grid, arguments.attacker.position, arguments.defender.position );
	}

	/**
	 * Casts one of the player's known cantrips at the opponent, by name — a
	 * thin wrapper around `_castCantripFor()`. Defaults to the player's
	 * first known cantrip if `name` is omitted (the common case while a
	 * player only knows one).
	 *
	 * @state The encounter's full mutable game state struct.
	 * @name The exact name of a spell in `state.player.knownCantrips`.
	 */
	function castCantrip( state, name = "" ) {
		var cantrip = _findKnownSpell( arguments.state.player, "knownCantrips", arguments.name );
		if ( !isNull( cantrip ) ) {
			_castCantripFor( arguments.state, arguments.state.player, arguments.state.opponent, false, cantrip );
		}
	}

	/**
	 * Casts one of the player's known leveled spells, by name — a thin
	 * wrapper around `_castLeveledSpellFor()`. Same defaults-to-first-known
	 * behavior as castCantrip(). For a damage/save spell this always
	 * targets `state.opponent`; for a heal spell it targets `healTarget` if
	 * given (any living party member — see WebSocket.bx's
	 * _handleCastSpell()), or the caster themself otherwise.
	 *
	 * @state The encounter's full mutable game state struct.
	 * @name The exact name of a spell in `state.player.knownLeveledSpells`.
	 * @healTarget Optional: the party member struct to heal, for a heal-type spell.
	 */
	function castLeveledSpell( state, name = "", healTarget = javaCast( "null", 0 ) ) {
		var spell = _findKnownSpell( arguments.state.player, "knownLeveledSpells", arguments.name );
		if ( !isNull( spell ) ) {
			var defender = arguments.state.opponent;
			if ( spell.type == "heal" ) {
				defender = isNull( arguments.healTarget ) ? arguments.state.player : arguments.healTarget;
			}
			_castLeveledSpellFor( arguments.state, arguments.state.player, defender, false, spell );
		}
	}

	/**
	 * Finds `name` in `combatant[arrayKey]` (an array of spell structs, e.g.
	 * `knownCantrips`) — or, if `name` is blank, returns the array's first
	 * entry (the common case while a caster only knows one). Returns null
	 * if `arrayKey` is missing/empty, or `name` isn't found in it.
	 */
	private function _findKnownSpell( combatant, arrayKey, name ) {
		if ( !structKeyExists( arguments.combatant, arguments.arrayKey ) || !arguments.combatant[ arguments.arrayKey ].len() ) {
			return javaCast( "null", 0 );
		}
		var spells = arguments.combatant[ arguments.arrayKey ];
		if ( !len( arguments.name ) ) {
			return spells[ 1 ];
		}
		for ( var spell in spells ) {
			if ( spell.name == arguments.name ) {
				return spell;
			}
		}
		return javaCast( "null", 0 );
	}

	/**
	 * Casts `cantrip` (from `attacker.knownCantrips`, or a monster's own
	 * `attacker.knownCantrip`) at `defender` — an attack-roll damage cantrip
	 * (e.g. Fire Bolt) or a saving-throw damage cantrip (e.g. Sacred Flame)
	 * per `cantrip.type`. Spends the attacker's action. Used for both the
	 * player (via castCantrip()) and any spellcasting monster (via
	 * runEnemyTurn(), which still passes its own single `knownCantrip`).
	 *
	 * @state The encounter's full mutable game state struct.
	 * @attacker The casting combatant.
	 * @defender The combatant being targeted.
	 * @defenderIsPlayer Whether `defender` is `state.player` — decides whether reaching 0 HP means defeat (with Relentless Endurance) or victory/XP.
	 * @cantrip The cantrip struct to cast (see _spellStructFromRow()).
	 */
	private function _castCantripFor( state, attacker, defender, defenderIsPlayer, cantrip ) {
		if ( !_isSpellTargetValid( arguments.state, arguments.attacker, arguments.defender, arguments.cantrip ) ) {
			arguments.state.log.prepend( "#arguments.attacker.name# doesn't have a clear shot at #arguments.defender.name# for #arguments.cantrip.name#." );
			return;
		}

		arguments.state.actionUsed = true;
		arguments.state.roundHadAction = true;
		// Dice default to 1d8 (save) / 1d10 (attack), matching the classes'
		// cantrips — but a monster's own signature cantrip (e.g. a Priest's
		// Radiant Flame, 2d6) can override with its own diceCount/diceSides.
		var diceCount = arguments.cantrip.keyExists( "diceCount" ) ? arguments.cantrip.diceCount : 1;
		if ( arguments.cantrip.type == "save" ) {
			var diceSides = arguments.cantrip.keyExists( "diceSides" ) ? arguments.cantrip.diceSides : 8;
			// Some save cantrips (Sacred Flame, Vicious Mockery) deal no damage
			// at all on a success, not half — real per-spell data from the
			// spells table carries its own saveEffect; the hardcoded fallback
			// cantrips (if _lookupClassSpell() found nothing for the class)
			// don't, so default to "half" same as before.
			var saveEffect = arguments.cantrip.keyExists( "saveEffect" ) ? arguments.cantrip.saveEffect : "half";
			_castSaveDamageSpell( arguments.state, arguments.attacker, arguments.defender, arguments.defenderIsPlayer, arguments.cantrip.name, arguments.cantrip.saveAbility, diceCount, diceSides, arguments.cantrip.damageType, saveEffect );
		} else {
			var diceSides = arguments.cantrip.keyExists( "diceSides" ) ? arguments.cantrip.diceSides : 10;
			_castAttackSpell( arguments.state, arguments.attacker, arguments.defender, arguments.defenderIsPlayer, arguments.cantrip.name, diceCount, diceSides, arguments.cantrip.damageType );
		}
	}

	/**
	 * Casts `spell` (from `attacker.knownLeveledSpells`, or a monster's own
	 * `attacker.knownLeveledSpell`) — either at `defender` (a damage spell
	 * like Magic Missile) or heals `defender` (a healing spell like Cure
	 * Wounds/Healing Word — the caster themself by default, or any living
	 * ally if one was explicitly chosen, see castLeveledSpell()), per
	 * `spell.type`. Spends a slot at `spell.level` if the caster has one;
	 * otherwise falls back to Magic Initiate's separate once-per-encounter
	 * bonus spell, if available and unused. A no-op if neither resource is
	 * available. If `spell.concentration` is true and the cast goes
	 * through, starts concentrating on it (see _startConcentrating()),
	 * dropping whatever the caster was concentrating on before. Used for
	 * both the player (via castLeveledSpell()) and any spellcasting monster
	 * (via runEnemyTurn() — a self-heal passes the monster itself as
	 * `defender`, not its aggro target).
	 *
	 * @state The encounter's full mutable game state struct.
	 * @attacker The casting combatant.
	 * @defender The spell's target: an opponent for a damage/save spell, or
	 *  whoever's being healed for a heal spell.
	 * @defenderIsPlayer Whether `defender` is on the player's side — decides whether reaching 0 HP means defeat (with Relentless Endurance) or victory/XP. Unused for a heal spell (healing never reduces HP).
	 * @spell The spell struct to cast (see _spellStructFromRow()).
	 */
	private function _castLeveledSpellFor( state, attacker, defender, defenderIsPlayer, spell ) {
		if ( !_isSpellTargetValid( arguments.state, arguments.attacker, arguments.defender, arguments.spell ) ) {
			arguments.state.log.prepend( "#arguments.attacker.name# doesn't have a clear shot at #arguments.defender.name# for #arguments.spell.name#." );
			return;
		}

		var spellLevel = arguments.spell.keyExists( "level" ) ? arguments.spell.level : 1;
		var slotSpent = _spendSpellSlot( arguments.attacker, spellLevel );
		var usedMagicInitiate = false;
		if (
			slotSpent == 0 && structKeyExists( arguments.attacker, "hasMagicInitiate" ) && arguments.attacker.hasMagicInitiate &&
			!arguments.attacker.usedMagicInitiateSpell
		) {
			arguments.attacker.usedMagicInitiateSpell = true;
			usedMagicInitiate = true;
		} else if ( slotSpent == 0 ) {
			arguments.state.log.prepend( "#arguments.attacker.name# has no spell slots left to cast #arguments.spell.name#." );
			return;
		}

		arguments.state.actionUsed = true;
		arguments.state.roundHadAction = true;
		if ( arguments.spell.keyExists( "concentration" ) && arguments.spell.concentration ) {
			_startConcentrating( arguments.state, arguments.attacker, arguments.spell.name );
		}
		var spell = arguments.spell;
		var resourceNote = usedMagicInitiate ? " (Magic Initiate's bonus spell)" : " (spends a level-#slotSpent# slot)";
		if ( spell.type == "heal" ) {
			_castHealSpell( arguments.state, arguments.attacker, arguments.defender, spell.name, resourceNote, spell.diceCount, spell.diceSides );
		} else if ( spell.type == "attack" ) {
			_castAttackSpell( arguments.state, arguments.attacker, arguments.defender, arguments.defenderIsPlayer, spell.name, spell.diceCount, spell.diceSides, spell.damageType, resourceNote );
		} else if ( spell.type == "save" ) {
			_castSaveDamageSpell( arguments.state, arguments.attacker, arguments.defender, arguments.defenderIsPlayer, spell.name, spell.saveAbility, spell.diceCount, spell.diceSides, spell.damageType, spell.saveEffect, resourceNote );
		} else {
			// Legacy fallback: Magic Initiate's default bonus spell when no
			// real DB spell was found for the class ({"type":"damage","name":"Magic Missile"}).
			_castMagicMissile( arguments.state, arguments.attacker, arguments.defender, arguments.defenderIsPlayer, resourceNote );
		}
	}

	/**
	 * Fire Bolt/Eldritch Blast/Produce Flame-style attack cantrip: a spell
	 * attack roll (d20 + Proficiency Bonus + spellcasting ability modifier)
	 * vs. the defender's AC, dealing `diceCount`d`diceSides` damage on a hit
	 * (doubled on a natural 20).
	 */
	private function _castAttackSpell( state, attacker, defender, defenderIsPlayer, spellName, diceCount, diceSides, damageType, resourceNote = "" ) {
		var spellMod = arguments.attacker.modifiers[ arguments.attacker.spellcastingAbility ];
		var cover = coverBonus( arguments.state, arguments.attacker, arguments.defender );
		var effectiveAC = arguments.defender.armorClass + cover;
		var coverNote = ( cover > 0 ) ? " (+#cover# Cover)" : "";
		var roll = randRange( 1, 20 );
		var total = roll + arguments.attacker.proficiencyBonus + spellMod;
		var isCrit = ( roll == 20 );
		var hits = isCrit || total >= effectiveAC;

		if ( !hits ) {
			arguments.state.log.prepend(
				"#arguments.attacker.name# casts #arguments.spellName##arguments.resourceNote# at #arguments.defender.name#: #roll# + #arguments.attacker.proficiencyBonus + spellMod# = #total# vs AC #effectiveAC##coverNote#. Miss!"
			);
			return;
		}

		var damage = rollSum( arguments.diceCount * ( isCrit ? 2 : 1 ), arguments.diceSides );
		damage = _applyDamageModifiers( arguments.defender, damage, arguments.damageType );

		arguments.defender.hitPoints = max( 0, arguments.defender.hitPoints - damage );
		_checkConcentration( arguments.state.log, arguments.defender, damage );
		_recordThreat( arguments.defender, arguments.attacker, damage );
		arguments.state.log.prepend(
			"#arguments.attacker.name# casts #arguments.spellName##arguments.resourceNote# at #arguments.defender.name#: #roll# + #arguments.attacker.proficiencyBonus + spellMod# = #total# vs AC #effectiveAC##coverNote#. " &
			( isCrit ? "Critical hit! " : "Hit! " ) &
			"#damage# #arguments.damageType# damage (#arguments.defender.hitPoints#/#arguments.defender.maxHitPoints# HP)."
		);
		_checkDefenderDefeated( arguments.state, arguments.attacker, arguments.defender, arguments.defenderIsPlayer );
	}

	/**
	 * Sacred Flame/Vicious Mockery-style save spell/cantrip: the defender
	 * makes a saving throw (via rollSavingThrow()) against DC 8 + Proficiency
	 * Bonus + spellcasting ability modifier, taking full damage on a failure
	 * and — per `saveEffect`, from the spells table's own `save_effect` column
	 * for a real leveled spell, or "half" for the hardcoded cantrips — either
	 * half damage or none at all on a success.
	 */
	private function _castSaveDamageSpell( state, attacker, defender, defenderIsPlayer, spellName, saveAbility, diceCount, diceSides, damageType, saveEffect = "half", resourceNote = "" ) {
		var dc = 8 + arguments.attacker.proficiencyBonus + arguments.attacker.modifiers[ arguments.attacker.spellcastingAbility ];
		var cover = coverBonus( arguments.state, arguments.attacker, arguments.defender );
		var saveResult = rollSavingThrow( arguments.defender, arguments.saveAbility, dc, "", true, cover );

		var damage = rollSum( arguments.diceCount, arguments.diceSides );
		var successText = "succeeds. No effect. ";
		if ( saveResult.success && arguments.saveEffect == "half" ) {
			damage = int( damage / 2 );
			successText = "succeeds, takes half damage. ";
		} else if ( saveResult.success ) {
			damage = 0;
		}
		damage = _applyDamageModifiers( arguments.defender, damage, arguments.damageType );

		arguments.defender.hitPoints = max( 0, arguments.defender.hitPoints - damage );
		_checkConcentration( arguments.state.log, arguments.defender, damage );
		_recordThreat( arguments.defender, arguments.attacker, damage );
		arguments.state.log.prepend(
			"#arguments.attacker.name# casts #arguments.spellName##arguments.resourceNote# at #arguments.defender.name#: DC #dc# #uCase( arguments.saveAbility )# save — #arguments.defender.name# rolls #saveResult.total#" &
			( saveResult.hadAdvantage ? " (Advantage)" : "" ) & " — " &
			( saveResult.success ? successText : "fails! " ) &
			"#damage# #arguments.damageType# damage (#arguments.defender.hitPoints#/#arguments.defender.maxHitPoints# HP)."
		);
		_checkDefenderDefeated( arguments.state, arguments.attacker, arguments.defender, arguments.defenderIsPlayer );
	}

	/**
	 * Magic Missile: automatically hits with 3 darts of 1d4+1 Force damage
	 * each (no attack roll, no save) — always a total of 3d4+3 here, since
	 * upcasting for more darts isn't modeled.
	 */
	private function _castMagicMissile( state, attacker, defender, defenderIsPlayer, resourceNote ) {
		var damage = rollSum( 3, 4 ) + 3;
		damage = _applyDamageModifiers( arguments.defender, damage, "Force" );

		arguments.defender.hitPoints = max( 0, arguments.defender.hitPoints - damage );
		_checkConcentration( arguments.state.log, arguments.defender, damage );
		_recordThreat( arguments.defender, arguments.attacker, damage );
		arguments.state.log.prepend(
			"#arguments.attacker.name# casts Magic Missile#arguments.resourceNote# — three darts automatically strike #arguments.defender.name# for #damage# Force damage (#arguments.defender.hitPoints#/#arguments.defender.maxHitPoints# HP)."
		);
		_checkDefenderDefeated( arguments.state, arguments.attacker, arguments.defender, arguments.defenderIsPlayer );
	}

	/**
	 * Cure Wounds/Healing Word-style heal: heals `target` (the caster
	 * themself, an ally, or — for a monster's own self-heal — itself, see
	 * _runOneOpponentTurn()) for `diceCount`d`diceSides` plus the caster's
	 * spellcasting ability modifier Hit Points, capped at `target`'s
	 * maximum. Healing a downed (0 HP) target back above 0 revives them —
	 * clears the dying/stable state and death save counters, same as a
	 * natural 20 on rollDeathSave().
	 */
	private function _castHealSpell( state, attacker, target, spellName, resourceNote, diceCount, diceSides ) {
		var healing = rollSum( arguments.diceCount, arguments.diceSides ) + arguments.attacker.modifiers[ arguments.attacker.spellcastingAbility ];
		var wasDown = arguments.target.hitPoints <= 0;
		arguments.target.hitPoints = min( arguments.target.maxHitPoints, arguments.target.hitPoints + healing );
		if ( wasDown && arguments.target.hitPoints > 0 ) {
			arguments.target.isDying = false;
			arguments.target.isStable = false;
			arguments.target.deathSaveSuccesses = 0;
			arguments.target.deathSaveFailures = 0;
		}
		var selfCast = ( arguments.target.name == arguments.attacker.name );
		arguments.state.log.prepend(
			selfCast
				? "#arguments.attacker.name# casts #arguments.spellName##arguments.resourceNote#, healing #healing# Hit Points (#arguments.target.hitPoints#/#arguments.target.maxHitPoints# HP)."
				: "#arguments.attacker.name# casts #arguments.spellName##arguments.resourceNote# on #arguments.target.name#, healing #healing# Hit Points (#arguments.target.hitPoints#/#arguments.target.maxHitPoints# HP)."
		);
	}

	/**
	 * Applies immunity/vulnerability/resistance for `damageType` to `damage`,
	 * shared by every spell-damage path (mirrors the same logic in resolveAttack()).
	 */
	private function _applyDamageModifiers( defender, damage, damageType ) {
		if ( structKeyExists( arguments.defender, "immunities" ) && arrayFindNoCase( arguments.defender.immunities, arguments.damageType ) ) {
			return 0;
		}
		var damage = arguments.damage;
		if ( structKeyExists( arguments.defender, "vulnerabilities" ) && arrayFindNoCase( arguments.defender.vulnerabilities, arguments.damageType ) ) {
			damage *= 2;
		}
		if ( structKeyExists( arguments.defender, "resistances" ) && arrayFindNoCase( arguments.defender.resistances, arguments.damageType ) ) {
			damage = int( damage / 2 );
		}
		return damage;
	}

	/**
	 * Shared victory/defeat check after a spell or weapon attack deals
	 * damage. When the defeated combatant is the player, this includes the
	 * Orc Relentless Endurance check (drop to 1 HP instead of 0, once per
	 * encounter). When it's an opponent, this awards its XP once and only
	 * ends the encounter (victory) once every opponent in state.opponents
	 * (or the lone state.opponent, for single-mob state) is down — otherwise
	 * the fight continues, and the player's current target auto-advances to
	 * the next living opponent if the one they just downed was it.
	 */
	private function _checkDefenderDefeated( state, attacker, defender, defenderIsPlayer ) {
		if ( arguments.defender.hitPoints > 0 ) {
			return;
		}

		if ( arguments.defenderIsPlayer ) {
			if (
				structKeyExists( arguments.defender, "hasRelentlessEndurance" ) && arguments.defender.hasRelentlessEndurance &&
				!arguments.defender.usedRelentlessEndurance
			) {
				arguments.defender.hitPoints = 1;
				arguments.defender.usedRelentlessEndurance = true;
				arguments.state.log.prepend( "#arguments.defender.name#'s Relentless Endurance kicks in — clinging to 1 Hit Point instead of falling!" );
				return;
			}
			// Dropping to 0 HP starts Death Saving Throws instead of ending the
			// encounter outright — see rollDeathSave() and _applyDeathSaveFailure().
			if ( !structKeyExists( arguments.defender, "isDying" ) || !arguments.defender.isDying ) {
				arguments.defender.isDying = true;
				arguments.defender.deathSaveSuccesses = 0;
				arguments.defender.deathSaveFailures = 0;
				arguments.state.log.prepend( "#arguments.defender.name# drops to 0 Hit Points and is dying!" );
			}
			return;
		}

		if ( !structKeyExists( arguments.defender, "xpAwarded" ) || !arguments.defender.xpAwarded ) {
			arguments.defender.xpAwarded = true;
			_awardPartyExperience( arguments.state, arguments.defender.xp );
			_incrementCharacterStat( arguments.state.player.characterId, "monsters_killed" );
			arguments.state.player.monstersKilled = ( structKeyExists( arguments.state.player, "monstersKilled" ) ? arguments.state.player.monstersKilled : 0 ) + 1;
			_grantMonsterLoot( arguments.state, arguments.defender );
			// The round this opponent died — the sidebar keeps showing its
			// (blinking-then-fading, via CSS) defeated card through the rest of
			// this round, then drops it from the roster entirely once the round
			// advances (see default.bxm's foe-card visibility check).
			if ( structKeyExists( arguments.state, "round" ) ) {
				arguments.defender.defeatedAtRound = arguments.state.round;
			}
		}

		if ( _allOpponentsDefeated( arguments.state ) ) {
			arguments.state.gameOver = true;
			arguments.state.outcome = "victory";
			arguments.state.log.prepend( "#arguments.defender.name# collapses. Victory!" );
		} else {
			arguments.state.log.prepend( "#arguments.defender.name# collapses!" );
			_retargetIfCurrentOpponentDefeated( arguments.state );
		}
	}

	/**
	 * Applies an automatic death-save failure to a dying player who's just
	 * been struck again — an Unconscious creature auto-fails Dex saves and
	 * takes no roll-to-hit, so this skips normal attack resolution entirely.
	 * Counts as 2 failures (an automatic critical) if `attacker` is within 5
	 * feet, 1 otherwise, per the "Unconscious"/critical-hit-range rules. Ends
	 * the encounter in defeat once failures reach 3.
	 *
	 * @state The encounter's full mutable game state struct.
	 * @attacker The opponent striking the downed player.
	 * @defender The dying player.
	 */
	private function _applyDeathSaveFailure( state, attacker, defender ) {
		if ( structKeyExists( arguments.defender, "isStable" ) && arguments.defender.isStable ) {
			arguments.defender.isStable = false;
			arguments.defender.isDying = true;
			arguments.defender.deathSaveSuccesses = 0;
			arguments.defender.deathSaveFailures = 0;
		}
		var failures = ( chebyshev( arguments.attacker, arguments.defender ) <= 1 ) ? 2 : 1;
		arguments.defender.deathSaveFailures += failures;
		arguments.state.log.prepend(
			"#arguments.attacker.name# strikes the unconscious #arguments.defender.name#: #failures# failed death save#( failures > 1 ? 's' : '' )#!"
		);
		if ( arguments.defender.deathSaveFailures >= 3 ) {
			arguments.defender.isDying = false;
			arguments.state.gameOver = true;
			arguments.state.outcome = "defeat";
			_incrementCharacterStat( arguments.defender.characterId, "deaths" );
			arguments.defender.deaths = ( structKeyExists( arguments.defender, "deaths" ) ? arguments.defender.deaths : 0 ) + 1;
			arguments.state.log.prepend( "#arguments.defender.name# dies." );
		}
	}

	/**
	 * Rolls one of the player's Death Saving Throws while they're dying (0 HP,
	 * per `player.isDying`) — d20 with no modifiers: 20 regains 1 Hit Point and
	 * ends the dying state outright, 10+ is a success, 2-9 is a failure, and a
	 * natural 1 counts as 2 failures. 3 successes stabilizes the player
	 * (unconscious but no longer in danger of dying on their own); 3 failures
	 * ends the encounter in defeat. A no-op if the player isn't dying.
	 *
	 * @state The encounter's full mutable game state struct.
	 */
	function rollDeathSave( state ) {
		var player = arguments.state.player;
		if ( !structKeyExists( player, "isDying" ) || !player.isDying ) {
			return;
		}

		var roll = randRange( 1, 20 );
		if ( roll == 20 ) {
			player.hitPoints = 1;
			player.isDying = false;
			player.deathSaveSuccesses = 0;
			player.deathSaveFailures = 0;
			arguments.state.log.prepend( "#player.name# rolls a natural 20 on their death save — surges back to 1 Hit Point!" );
			return;
		}

		if ( roll == 1 ) {
			player.deathSaveFailures += 2;
		} else if ( roll >= 10 ) {
			player.deathSaveSuccesses += 1;
		} else {
			player.deathSaveFailures += 1;
		}

		arguments.state.log.prepend(
			"#player.name# makes a death saving throw: #roll# — " &
			( roll == 1 ? "critical failure (2 failures)!" : ( roll >= 10 ? "success." : "failure." ) ) &
			" (#min( player.deathSaveSuccesses, 3 )# successes, #min( player.deathSaveFailures, 3 )# failures)"
		);

		if ( player.deathSaveSuccesses >= 3 ) {
			player.isDying = false;
			player.isStable = true;
			arguments.state.log.prepend( "#player.name# stabilizes, unconscious but stable." );
		} else if ( player.deathSaveFailures >= 3 ) {
			arguments.state.gameOver = true;
			arguments.state.outcome = "defeat";
			_incrementCharacterStat( player.characterId, "deaths" );
			player.deaths = ( structKeyExists( player, "deaths" ) ? player.deaths : 0 ) + 1;
			arguments.state.log.prepend( "#player.name# dies." );
		}
	}

	/**
	 * Rolls Initiative for both combatants (d20 + Dexterity modifier, plus
	 * Proficiency Bonus for a character with the Alert feat) and sets
	 * `state.currentTurn` to whoever acts first (ties favor the player
	 * character). If the opponent wins, immediately runs their first turn.
	 *
	 * @state The encounter's full mutable game state struct.
	 */
	function rollForInitiative( state ) {
		var opponents = _stateOpponents( arguments.state );

		// "Fought" is counted per encounter, not per kill — every opponent in
		// this fight's roster, win or lose, the moment combat actually starts —
		// and every living party member takes credit, not just whoever's active.
		var bestPlayerRoll = "";
		var fastestPlayerName = "";
		for ( var member in arguments.state.players ) {
			_incrementCharacterStat( member.characterId, "monsters_fought", opponents.len() );
			member.monstersFought = ( structKeyExists( member, "monstersFought" ) ? member.monstersFought : 0 ) + opponents.len();
			var r = rollInitiative( member );
			if ( !isNumeric( bestPlayerRoll ) || r > bestPlayerRoll ) {
				bestPlayerRoll = r;
				fastestPlayerName = member.name;
			}
		}

		var bestOpponentRoll = "";
		var fastestOpponentName = "";
		for ( var o in opponents ) {
			var r = rollInitiative( o );
			if ( !isNumeric( bestOpponentRoll ) || r > bestOpponentRoll ) {
				bestOpponentRoll = r;
				fastestOpponentName = o.name;
			}
		}
		var playerFirst = ( bestPlayerRoll >= bestOpponentRoll );
		var playerLabel = ( arguments.state.players.len() > 1 ) ? "the party (#fastestPlayerName# leads at #bestPlayerRoll#)" : "#fastestPlayerName# rolls #bestPlayerRoll#";
		var opponentLabel = ( opponents.len() > 1 ) ? "the enemies (#fastestOpponentName# leads at #bestOpponentRoll#)" : "#fastestOpponentName# rolls #bestOpponentRoll#";
		var winnerLabel = playerFirst ? ( arguments.state.players.len() > 1 ? "The party" : fastestPlayerName ) : ( opponents.len() > 1 ? "The enemies" : fastestOpponentName );

		arguments.state.log.prepend(
			"Initiative: #playerLabel#, #opponentLabel#. #winnerLabel# goes first!"
		);

		if ( playerFirst ) {
			arguments.state.currentTurn = "player";
			return;
		}

		arguments.state.currentTurn = "enemy";
		runEnemyTurn( arguments.state );
		if ( !arguments.state.gameOver ) {
			arguments.state.currentTurn = "player";
		}
	}

	/**
	 * d20 + Dexterity modifier, plus Proficiency Bonus if the combatant has
	 * the Alert feat's Initiative Proficiency benefit.
	 */
	function rollInitiative( combatant ) {
		var dexMod = structKeyExists( arguments.combatant, "modifiers" ) ? arguments.combatant.modifiers.dex : abilityModifier( arguments.combatant.abilityScores.dex );
		var hasAlert = structKeyExists( arguments.combatant, "feats" ) && arrayFindNoCase( arguments.combatant.feats, "Alert" ) > 0;
		var alertBonus = hasAlert ? arguments.combatant.proficiencyBonus : 0;
		return randRange( 1, 20 ) + dexMod + alertBonus;
	}

	/**
	 * Parses a "NdM" damage notation, e.g. "2d6" -> { count: 2, sides: 6 }.
	 * Returns 0 dice for anything that isn't that exact shape (blank, or a
	 * malformed value that shouldn't exist in well-formed data but has
	 * turned up before in imported monster stat blocks — see the "Elk"/
	 * "Killer Whale"/"Tiger" seed data bug fixed alongside this) — a weapon
	 * with 0 dice just deals its flat damage bonus, same as a real SRD
	 * flat-damage attack, rather than crashing combat outright.
	 */
	function parseDice( notation ) {
		var parts = listToArray( arguments.notation, "d" );
		if ( parts.len() < 2 ) {
			return { "count": 0, "sides": 0 };
		}
		return { "count": int( parts[ 1 ] ), "sides": int( parts[ 2 ] ) };
	}

	/**
	 * Rolls `count` dice of `sides` and returns their sum.
	 */
	function rollSum( count, sides ) {
		var total = 0;
		for ( var i = 1; i <= arguments.count; i++ ) {
			total += randRange( 1, arguments.sides );
		}
		return total;
	}

	/**
	 * Rolls `count` dice of `sides`, treating any face below `minFace` as
	 * `minFace` instead (Great Weapon Fighting: "treat any 1 or 2 as a 3").
	 */
	function rollSumMinFace( count, sides, minFace ) {
		var total = 0;
		for ( var i = 1; i <= arguments.count; i++ ) {
			total += max( randRange( 1, arguments.sides ), arguments.minFace );
		}
		return total;
	}

	/**
	 * Awards `xp` to a saved character's persisted record (gameserver.characters),
	 * then checks the Character Advancement table and levels the character up
	 * (possibly multiple times, for a very large XP award) if the new total
	 * crosses one or more thresholds. Levels, HP, Proficiency Bonus, and any
	 * newly-gained class features are updated on both `state.player` (so the
	 * running encounter reflects it immediately) and the persisted row.
	 *
	 * @state The encounter's full mutable game state struct.
	 * @xp The amount of XP being awarded.
	 */
	/**
	 * Increments one of a character's lifetime counters (monsters_fought,
	 * monsters_killed, deaths) directly in the DB, the same "persist as it
	 * happens" pattern awardExperience() uses rather than waiting for
	 * saveCharacterState() — these are per-event counters, not per-encounter
	 * resource state, so they shouldn't be lost if the browser closes
	 * mid-encounter. A no-op for a player with no characterId (e.g. a test
	 * double), same guard awardExperience() applies via its own recordCount
	 * check.
	 *
	 * @characterId characters.id.
	 * @column One of "monsters_fought", "monsters_killed", "deaths" — never
	 *  user input, so string-building the column name into the UPDATE is safe.
	 * @amount How much to add (default 1).
	 */
	private function _incrementCharacterStat( characterId, column, amount = 1 ) {
		if ( isNull( arguments.characterId ) || !len( arguments.characterId ) ) {
			return;
		}
		queryExecute(
			"UPDATE characters SET #arguments.column# = #arguments.column# + :amount WHERE id = :characterId",
			{ "amount": arguments.amount, "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
	}

	/**
	 * Splits `xp` evenly (rounded down) across every character in
	 * `state.players` and awards each their share via awardExperience() —
	 * everyone in the party benefits from a kill, not just whoever's
	 * currently active/landed the blow. Downed-but-not-dead members still
	 * get a share (this app has no "left the party" state to exclude
	 * anyone by), matching the SRD's usual "everyone present splits it"
	 * guidance. A party of one gets the full amount, same as before party
	 * play existed.
	 *
	 * @state The encounter's full mutable game state struct.
	 * @xp The opponent's total XP award, before splitting.
	 */
	private function _awardPartyExperience( state, xp ) {
		var share = int( arguments.xp / arguments.state.players.len() );
		if ( share <= 0 ) {
			return;
		}
		for ( var member in arguments.state.players ) {
			awardExperience( arguments.state, share, member );
		}
	}

	/**
	 * Awards `xp` to `player` specifically (see _awardPartyExperience() for
	 * the usual party-wide entry point every opponent-defeated call site
	 * actually uses) — persists it immediately and cascades through as
	 * many level-ups as the new total crosses thresholds for.
	 *
	 * @state The encounter's full mutable game state struct.
	 * @xp The amount of XP being awarded to `player`.
	 * @player The specific character struct being credited.
	 */
	function awardExperience( state, xp, player ) {
		var player = arguments.player;

		queryExecute(
			"UPDATE characters SET experience_points = experience_points + :xp WHERE id = :characterId",
			{ "xp": arguments.xp, "characterId": player.characterId },
			{ datasource: "gameserver" }
		);

		var totals = queryExecute(
			"SELECT experience_points FROM characters WHERE id = :characterId",
			{ "characterId": player.characterId },
			{ datasource: "gameserver" }
		);
		if ( totals.recordCount == 0 ) {
			return; // no saved character record to advance (e.g. a test double)
		}

		var newTotalXp = totals.experience_points[ 1 ];
		arguments.state.log.prepend( "#player.name# gains #arguments.xp# XP (#newTotalXp# total)." );

		// `totalLevel` (sum across every class — see loadCharacter()) is what
		// the XP table actually measures; a single-class character always has
		// totalLevel == level, unchanged from before multiclassing existed.
		var currentLevel = structKeyExists( player, "totalLevel" ) ? player.totalLevel : player.level;
		var targetLevel = levelForXp( newTotalXp );
		var leveledUp = false;
		while ( currentLevel < targetLevel ) {
			_levelUp( arguments.state, player );
			currentLevel = structKeyExists( player, "totalLevel" ) ? player.totalLevel : player.level;
			leveledUp = true;
		}

		if ( leveledUp ) {
			// hit_points is persisted as the new max, not the character's
			// (possibly damaged) current total — loadCharacter() always
			// starts a fresh encounter at full HP (see there), so keeping
			// hit_points in sync with max_hit_points avoids leaving a stale,
			// no-longer-meaningful lower number sitting in the row.
			queryExecute(
				"UPDATE characters SET level = :level, proficiency_bonus = :proficiencyBonus, hit_points = :maxHitPoints, max_hit_points = :maxHitPoints WHERE id = :characterId",
				{
					"level": player.classes[ 1 ].level,
					"proficiencyBonus": player.proficiencyBonus,
					"maxHitPoints": player.maxHitPoints,
					"characterId": player.characterId
				},
				{ datasource: "gameserver" }
			);
			// Any classes beyond the original one (see startMulticlass()) keep
			// their own level in character_multiclass_levels — upserted here
			// too in case this batch of level-ups landed on one of them.
			for ( var i = 2; i <= player.classes.len(); i++ ) {
				queryExecute(
					"INSERT INTO character_multiclass_levels (character_id, class_id, level)
					 VALUES (:characterId, :classId, :level)
					 ON DUPLICATE KEY UPDATE level = :level",
					{ "characterId": player.characterId, "classId": player.classes[ i ].classId, "level": player.classes[ i ].level },
					{ datasource: "gameserver" }
				);
			}
		}
	}

	/**
	 * Rolls a defeated monster's gold (and a small chance of a Potion of
	 * Healing) and persists it immediately — same "write straight to the DB
	 * from here, no CharacterService dependency" approach awardExperience()
	 * already uses for XP, and the same in-memory `state.player.gold`/
	 * `state.items` mirroring default.bx's loot-POI grant does, so the
	 * character sheet/HUD reflect it within this same request without a
	 * full reload.
	 *
	 * Gold scales off the monster's own `xp` (already a CR proxy — see
	 * _levelAppropriateCRRange()) rather than a separate treasure table per
	 * monster: roughly xp/10 to xp/3, e.g. 2-8 gold for a Bandit (25 XP) up
	 * to 45-150 for a CR 2 dragon wyrmling (450 XP).
	 */
	private function _grantMonsterLoot( state, defender ) {
		var player = arguments.state.player;
		if ( !structKeyExists( player, "characterId" ) ) {
			return; // no saved character record to credit (e.g. a test double)
		}
		var existing = queryExecute(
			"SELECT id FROM characters WHERE id = :characterId",
			{ "characterId": player.characterId },
			{ datasource: "gameserver" }
		);
		if ( existing.recordCount == 0 ) {
			return; // characterId doesn't reference a real row (e.g. a test double)
		}

		var gold = randRange( max( 1, int( arguments.defender.xp / 10 ) ), max( 2, int( arguments.defender.xp / 3 ) ) );
		queryExecute(
			"UPDATE characters SET gold = gold + :gold WHERE id = :characterId",
			{ "gold": gold, "characterId": player.characterId },
			{ datasource: "gameserver" }
		);
		player.gold = ( structKeyExists( player, "gold" ) ? player.gold : 0 ) + gold;
		var messages = [ "#gold# gold" ];

		// 15% chance of a Potion of Healing — the one seeded item with a
		// coded effect (see consumableEffects()); other seeded items are
		// flavor/treasure, not worth rolling for here.
		if ( randRange( 1, 100 ) <= 15 ) {
			var itemRow = queryExecute(
				"SELECT id FROM items WHERE name = 'Potion of Healing'",
				{}, { datasource: "gameserver" }
			);
			if ( itemRow.recordCount > 0 ) {
				queryExecute(
					"INSERT INTO character_items (character_id, item_id, quantity)
					 VALUES (:characterId, :itemId, 1)
					 ON DUPLICATE KEY UPDATE quantity = quantity + 1",
					{ "characterId": player.characterId, "itemId": itemRow.id[ 1 ] },
					{ datasource: "gameserver" }
				);
				if ( structKeyExists( arguments.state, "items" ) ) {
					var itemRows = queryExecute(
						"SELECT ci.id, ci.quantity, i.name AS itemName, i.item_type, i.description
						 FROM character_items ci JOIN items i ON i.id = ci.item_id
						 WHERE ci.character_id = :characterId
						 ORDER BY i.item_type, i.name",
						{ "characterId": player.characterId }, { datasource: "gameserver" }
					);
					var refreshedItems = [];
					for ( var inventoryRow in itemRows ) {
						arrayAppend( refreshedItems, {
							"id": inventoryRow.id, "itemName": inventoryRow.itemName, "itemType": inventoryRow.item_type,
							"description": inventoryRow.description, "quantity": inventoryRow.quantity
						} );
					}
					arguments.state.items = refreshedItems;
				}
				arrayAppend( messages, "a Potion of Healing" );
			}
		}

		arguments.state.log.prepend( "#arguments.defender.name# drops #arrayToList( messages, " and " )#." );
	}

	/**
	 * Returns the character level for a given total XP, per the Character
	 * Advancement table (level = highest threshold met or exceeded).
	 */
	function levelForXp( xp ) {
		var level = 1;
		for ( var i = 1; i <= XP_THRESHOLDS.len(); i++ ) {
			if ( arguments.xp >= XP_THRESHOLDS[ i ] ) {
				level = i;
			}
		}
		return level;
	}

	/**
	 * Total XP required to reach a given level, per the Character Advancement
	 * table — the inverse lookup of levelForXp(), exposed for callers outside
	 * this class (e.g. the character-select API's XP progress bar) since
	 * class-body constants like XP_THRESHOLDS aren't reachable externally.
	 */
	function xpForLevel( level ) {
		if ( arguments.level < 1 || arguments.level > XP_THRESHOLDS.len() ) {
			return 0;
		}
		return XP_THRESHOLDS[ arguments.level ];
	}

	/**
	 * Proficiency Bonus for a given character level, per the Character
	 * Advancement table: +2 at levels 1-4, +3 at 5-8, +4 at 9-12, +5 at
	 * 13-16, +6 at 17-20.
	 */
	function proficiencyBonusForLevel( level ) {
		return 2 + int( ( arguments.level - 1 ) / 4 );
	}

	/**
	 * Finds the entry in `player.classes` that the next level-up applies to
	 * (see `player.nextLevelClassId`, set by loadCharacter()/startMulticlass()/
	 * setNextLevelClass()). If `nextLevelClassId` names a class the
	 * character doesn't have yet (startMulticlass() only ever records
	 * *intent*, not an actual level — see its doc comment), this is that
	 * class's first level: a fresh level-0 entry is appended to
	 * `player.classes` here so the caller's `level += 1` takes it to 1, same
	 * as the original class's very first level. Falls back to the original
	 * class (`classes[1]`) if `nextLevelClassId` is unset or names a class
	 * that no longer exists (a stray/deleted id).
	 */
	private function _levelingClassFor( player ) {
		for ( var classEntry in arguments.player.classes ) {
			if ( classEntry.classId == arguments.player.nextLevelClassId ) {
				return classEntry;
			}
		}
		var newClassRows = queryExecute(
			"SELECT id, name, hit_die FROM classes WHERE id = :classId",
			{ "classId": arguments.player.nextLevelClassId },
			{ datasource: "gameserver" }
		);
		if ( newClassRows.recordCount == 0 ) {
			return arguments.player.classes[ 1 ];
		}
		var newClassEntry = {
			"classId": newClassRows.id[ 1 ], "className": newClassRows.name[ 1 ],
			"subclassId": javaCast( "null", 0 ), "level": 0, "hitDie": newClassRows.hit_die[ 1 ]
		};
		arrayAppend( arguments.player.classes, newClassEntry );
		return newClassEntry;
	}

	/**
	 * Applies one level's worth of advancement to `player`, per "Gaining a
	 * Level": +1 Hit Die worth of HP (using the *leveling class's* fixed
	 * value + Constitution modifier, minimum 1 — see
	 * _levelingClassFor()/multiclassing above), an increased Proficiency
	 * Bonus (by total character level) at the levels that grant one
	 * (bumping equipped weapons' attack bonus to match), and any new class
	 * features that class unlocks at its new level.
	 *
	 * @state The encounter's full mutable game state struct.
	 * @player The specific character struct leveling up.
	 */
	private function _levelUp( state, player ) {
		var player = arguments.player;
		var levelingClass = _levelingClassFor( player );
		levelingClass.level += 1;
		// `player.level`/`hitDiceMax` mirror the original class specifically
		// (used for its own short-rest hit-die size) — kept in sync only
		// when the original class is the one gaining this level.
		if ( levelingClass.classId == player.classes[ 1 ].classId ) {
			player.level = levelingClass.level;
		}
		player.totalLevel += 1;
		player.hitDiceMax = player.totalLevel;

		// A caster's slot count is level-dependent (and a half-caster's very
		// first slot unlocks at level 2) — recompute immediately so a level-up
		// mid-encounter doesn't leave them with a stale (often empty)
		// spellSlots table until their next fresh character load. Same idea
		// for a Barbarian's max Rage uses, which also increases with level.
		_recomputeSpellSlots( player );
		_recomputeRagesRemaining( player );

		// Dwarven Toughness adds +1 per level on top of the normal Hit Die gain.
		var hpBonusPerLevel = structKeyExists( player, "hpBonusPerLevel" ) ? player.hpBonusPerLevel : 0;
		var hitPointsPerLevel = _fixedHitPointsPerLevel( levelingClass.hitDie );
		var hpGain = max( 1, hitPointsPerLevel + player.modifiers.con ) + hpBonusPerLevel;
		player.maxHitPoints += hpGain;
		player.hitPoints += hpGain;

		var newProficiencyBonus = proficiencyBonusForLevel( player.totalLevel );
		var proficiencyIncreased = ( newProficiencyBonus > player.proficiencyBonus );
		if ( proficiencyIncreased ) {
			var bonusIncrease = newProficiencyBonus - player.proficiencyBonus;
			player.proficiencyBonus = newProficiencyBonus;
			for ( var item in player.inventory ) {
				if ( item.equipped ) {
					item.attackBonus += bonusIncrease;
				}
			}
		}

		var newFeatureNames = _grantNewFeatures(
			player, levelingClass.classId, isNull( levelingClass.subclassId ) ? 0 : levelingClass.subclassId, levelingClass.level
		);

		arguments.state.log.prepend(
			"#player.name# reaches character level #player.totalLevel# (#levelingClass.className# #levelingClass.level#)! +#hpGain# HP" &
			( proficiencyIncreased ? ", Proficiency Bonus now +#player.proficiencyBonus#" : "" ) &
			( newFeatureNames.len() ? ", gains #arrayToList( newFeatureNames, ", " )#" : "" ) &
			"."
		);
	}

	/**
	 * Every class in the current dataset unlocks its (sole) subclass at
	 * level 3 — see class_features rows with a non-null subclass_id.
	 * Returns `{ pending, availableSubclasses }`: `pending` is true once
	 * `characterId` has reached that level without a subclass chosen yet
	 * (this doesn't auto-assign it — the player chooses via chooseSubclass(),
	 * from the character sheet, and can leave it pending indefinitely);
	 * `availableSubclasses` is `[{id, name, tagline}]` for the character's
	 * class (currently always exactly one, but shaped for a class ever
	 * having more).
	 */
	function pendingSubclassChoice( characterId ) {
		var charRow = queryExecute(
			"SELECT class_id, subclass_id, level FROM characters WHERE id = :characterId",
			{ "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
		if ( charRow.recordCount == 0 || !isNull( charRow.subclass_id[ 1 ] ) ) {
			return { "pending": false, "availableSubclasses": [] };
		}

		var subclassRows = queryExecute(
			"SELECT s.id, s.name, s.tagline, MIN(cf.level) AS unlockLevel
			 FROM subclasses s JOIN class_features cf ON cf.subclass_id = s.id
			 WHERE s.class_id = :classId
			 GROUP BY s.id, s.name, s.tagline",
			{ "classId": charRow.class_id[ 1 ] },
			{ datasource: "gameserver" }
		);
		if ( subclassRows.recordCount == 0 || subclassRows.unlockLevel[ 1 ] > charRow.level[ 1 ] ) {
			return { "pending": false, "availableSubclasses": [] };
		}

		var availableSubclasses = [];
		for ( var row in subclassRows ) {
			availableSubclasses.append( { "id": row.id, "name": row.name, "tagline": row.tagline } );
		}
		return { "pending": true, "availableSubclasses": availableSubclasses };
	}

	/**
	 * Assigns `characterId`'s subclass and retroactively grants every
	 * subclass feature at or below their current level (in case they leveled
	 * past the unlock level before choosing) — the character sheet's
	 * "Choose Your Subclass" panel's action, per pendingSubclassChoice().
	 */
	function chooseSubclass( characterId, subclassId ) {
		var charRow = queryExecute(
			"SELECT level FROM characters WHERE id = :characterId",
			{ "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
		if ( charRow.recordCount == 0 ) {
			return;
		}
		queryExecute(
			"UPDATE characters SET subclass_id = :subclassId WHERE id = :characterId",
			{ "subclassId": arguments.subclassId, "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
		var featureRows = queryExecute(
			"SELECT id FROM class_features WHERE subclass_id = :subclassId AND level <= :level",
			{ "subclassId": arguments.subclassId, "level": charRow.level[ 1 ] },
			{ datasource: "gameserver" }
		);
		for ( var row in featureRows ) {
			queryExecute(
				"INSERT IGNORE INTO character_features (character_id, class_feature_id) VALUES (:characterId, :featureId)",
				{ "characterId": arguments.characterId, "featureId": row.id },
				{ datasource: "gameserver" }
			);
		}
	}

	/**
	 * True if `abilityScores` meets the Multiclassing ability-score
	 * prerequisite described by `primaryAbilityText` — the exact text
	 * already stored in `classes.primary_ability` (e.g. "Strength or
	 * Dexterity" for Fighter, "Strength and Charisma" for Paladin, a bare
	 * "Wisdom" for Cleric), which happens to already match the SRD's
	 * multiclassing prerequisite table for every class in this dataset.
	 * "and" requires every named ability at 13+; "or" requires any one of
	 * them; a single ability name requires just that one. Empty/unrecognized
	 * text never blocks (treated as "no prerequisite" rather than silently
	 * excluding every class from multiclass options). Public (like
	 * hasSpellResource()/multiclassCasterLevel()) so this string-parsing —
	 * easy to get subtly wrong around "and" vs. "or" and the 13 boundary —
	 * has a direct unit test, independent of multiclassOptions()'s DB query.
	 */
	function meetsMulticlassPrerequisite( abilityScores, primaryAbilityText ) {
		var text = trim( arguments.primaryAbilityText );
		if ( !len( text ) ) {
			return true;
		}
		var abilityAbbrevByName = {
			"strength": "str", "dexterity": "dex", "constitution": "con",
			"intelligence": "int", "wisdom": "wis", "charisma": "cha"
		};
		var requireAll = findNoCase( " and ", text ) > 0;
		var separator = requireAll ? " and " : " or ";
		// `true` as the 4th arg treats `separator` as one literal delimiter
		// string rather than a set of delimiter characters — same listToArray()
		// usage already relied on elsewhere for this kind of " and "-joined
		// SRD text (see the savingThrowProficiencies parsing in loadCharacter()).
		var parts = ( findNoCase( separator, text ) > 0 ) ? listToArray( text, separator, false, true ) : [ text ];
		var anyMet = false;
		var allMet = true;
		for ( var part in parts ) {
			var abbrev = abilityAbbrevByName.keyExists( lCase( trim( part ) ) ) ? abilityAbbrevByName[ lCase( trim( part ) ) ] : "";
			var met = len( abbrev ) && structKeyExists( arguments.abilityScores, abbrev ) && arguments.abilityScores[ abbrev ] >= 13;
			anyMet = anyMet || met;
			allMet = allMet && met;
		}
		return requireAll ? allMet : anyMet;
	}

	/**
	 * Classes `characterId` could multiclass into right now: every class
	 * they don't already have, whose own ability-score prerequisite they
	 * meet — provided they also still meet the prerequisite for every class
	 * they've *already* taken (the real "you need 13+ in your current
	 * class's primary ability too" multiclassing rule). Returns
	 * `[{id, name, primaryAbility}, ...]`, empty if none qualify. Never
	 * auto-applied — the player picks via startMulticlass(), same
	 * skippable/revisitable pattern as pendingSubclassChoice().
	 */
	function multiclassOptions( characterId ) {
		var charRow = queryExecute(
			"SELECT class_id, str, dex, con, int_score, wis, cha FROM characters WHERE id = :characterId",
			{ "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
		if ( charRow.recordCount == 0 ) {
			return [];
		}
		var abilityScores = {
			"str": charRow.str[ 1 ], "dex": charRow.dex[ 1 ], "con": charRow.con[ 1 ],
			"int": charRow.int_score[ 1 ], "wis": charRow.wis[ 1 ], "cha": charRow.cha[ 1 ]
		};

		var takenRows = queryExecute(
			"SELECT id, primary_ability FROM classes WHERE id = :classId
			 UNION
			 SELECT cl.id, cl.primary_ability FROM character_multiclass_levels cml
			 JOIN classes cl ON cl.id = cml.class_id WHERE cml.character_id = :characterId",
			{ "classId": charRow.class_id[ 1 ], "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
		var takenClassIds = [];
		var meetsAllTakenPrereqs = true;
		for ( var row in takenRows ) {
			arrayAppend( takenClassIds, row.id );
			if ( !meetsMulticlassPrerequisite( abilityScores, row.primary_ability ) ) {
				meetsAllTakenPrereqs = false;
			}
		}
		if ( !meetsAllTakenPrereqs ) {
			return [];
		}

		var candidateRows = queryExecute( "SELECT id, name, primary_ability FROM classes ORDER BY name", {}, { datasource: "gameserver" } );
		var options = [];
		for ( var row in candidateRows ) {
			if ( arrayFind( takenClassIds, row.id ) > 0 ) {
				continue;
			}
			if ( meetsMulticlassPrerequisite( abilityScores, row.primary_ability ) ) {
				arrayAppend( options, { "id": row.id, "name": row.name, "primaryAbility": row.primary_ability } );
			}
		}
		return options;
	}

	/**
	 * Declares intent to multiclass into `classId` — validated against
	 * multiclassOptions() so a stray/invalid id can't bypass the ability-score
	 * prerequisite. Only redirects future automatic level-ups (`_levelUp()`,
	 * via `next_level_class_id`) at the new class; grants nothing by itself.
	 * A character doesn't actually gain a level (HP, features, a real row in
	 * `character_multiclass_levels`) in the new class until they've earned
	 * enough XP for their *next* character level and `_levelUp()` fires
	 * naturally — multiclassing redirects where that next level goes, it
	 * doesn't hand out a free one. See _levelingClassFor(), which creates the
	 * actual level-1 entry (and grants its features) the moment that happens.
	 */
	function startMulticlass( characterId, classId ) {
		var options = multiclassOptions( arguments.characterId );
		var isValid = false;
		for ( var option in options ) {
			if ( option.id == arguments.classId ) {
				isValid = true;
			}
		}
		if ( !isValid ) {
			return;
		}
		queryExecute(
			"UPDATE characters SET next_level_class_id = :classId WHERE id = :characterId",
			{ "classId": arguments.classId, "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
	}

	/**
	 * Redirects future automatic level-ups (`_levelUp()`) to `classId` —
	 * always available once a character has multiclassed, so the player can
	 * change which class their next kill's XP advances at any time from the
	 * character sheet. A no-op if `classId` isn't one of the character's
	 * original or multiclass classes (guards against a stray id) — use
	 * startMulticlass() instead to redirect at a class not yet taken.
	 */
	function setNextLevelClass( characterId, classId ) {
		var validRows = queryExecute(
			"SELECT class_id FROM characters WHERE id = :characterId AND class_id = :classId
			 UNION
			 SELECT class_id FROM character_multiclass_levels WHERE character_id = :characterId AND class_id = :classId",
			{ "characterId": arguments.characterId, "classId": arguments.classId },
			{ datasource: "gameserver" }
		);
		if ( validRows.recordCount == 0 ) {
			return;
		}
		queryExecute(
			"UPDATE characters SET next_level_class_id = :classId WHERE id = :characterId",
			{ "classId": arguments.classId, "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
	}

	/**
	 * Grants `player` any class features of `classId` at `level` (the class
	 * that's just gained this level — see _levelingClassFor(); for a
	 * single-class character this is always their one class), from the
	 * gameserver rule set — adding them to `player.features` and recording
	 * them against the persisted character. A subclass feature is only
	 * included once the player has actually chosen a subclass for that
	 * class (see chooseSubclass()/startMulticlass()) — reaching the unlock
	 * level alone doesn't grant them. Returns the names of any features
	 * gained.
	 *
	 * @subclassId Pass 0 (not a real id) for "no subclass chosen yet" — avoids binding a SQL NULL parameter.
	 */
	private function _grantNewFeatures( player, classId, subclassId, level ) {
		var names = [];

		var rows = queryExecute(
			"SELECT id, name FROM class_features
			 WHERE class_id = :classId AND level = :level
			   AND ( subclass_id IS NULL OR subclass_id = :subclassId )",
			{ "classId": arguments.classId, "level": arguments.level, "subclassId": arguments.subclassId },
			{ datasource: "gameserver" }
		);

		for ( var row in rows ) {
			arrayAppend( names, row.name );
			arrayAppend( arguments.player.features, row.name );
			queryExecute(
				"INSERT IGNORE INTO character_features (character_id, class_feature_id) VALUES (:characterId, :featureId)",
				{ "characterId": arguments.player.characterId, "featureId": row.id },
				{ datasource: "gameserver" }
			);

			// Fighting Style (Fighter 1/7, Paladin/Ranger 2): the class
			// feature itself is recorded above like any other; the specific
			// style is a player choice made afterward on the character
			// sheet (see pendingFightingStyleChoice()/grantFightingStyle()),
			// not auto-picked.

			// Ability Score Improvement: queue it instead of auto-applying —
			// the player chooses which ability/abilities to raise via the
			// level-up screen (see applyAbilityScoreImprovement()). Queued as
			// a count rather than a flag since a big enough XP award can carry
			// the player through more than one ASI-granting level at once.
			if ( row.name == "Ability Score Improvement" ) {
				arguments.player.pendingAbilityScoreImprovements = (
					structKeyExists( arguments.player, "pendingAbilityScoreImprovements" ) ? arguments.player.pendingAbilityScoreImprovements : 0
				) + 1;
				names[ names.len() ] = "an Ability Score Improvement (choose below)";
			}
		}
		return names;
	}

	/**
	 * Applies a player-chosen Ability Score Improvement, consuming one of the
	 * character's `pendingAbilityScoreImprovements` (queued by
	 * _grantNewFeatures() instead of auto-applying it) — either +2 to one
	 * ability, or +1 to two different ones, per the "Ability Scores"
	 * increase rule, each capped at 20. A no-op if there's no pending
	 * improvement to spend, or if `choice.abilities` isn't 1 or 2 entries.
	 * (This app doesn't model the alternative — taking a feat instead of an
	 * ability increase — since it has no broader feat-selection UI at all.)
	 *
	 * @state The encounter's full mutable game state struct.
	 * @choice `{ "abilities": [ "str" ] }` for +2 to one ability, or `{ "abilities": [ "str", "dex" ] }` for +1 to two.
	 */
	function applyAbilityScoreImprovement( state, choice ) {
		var player = arguments.state.player;
		if ( !structKeyExists( player, "pendingAbilityScoreImprovements" ) || player.pendingAbilityScoreImprovements <= 0 ) {
			return;
		}
		var abilities = arguments.choice.abilities;
		if ( abilities.len() != 1 && abilities.len() != 2 ) {
			return;
		}

		var amountEach = ( abilities.len() == 1 ) ? 2 : 1;
		var improvedNames = [];
		for ( var abbrev in abilities ) {
			var improvedName = _increaseAbilityScore( player, abbrev, amountEach );
			if ( len( improvedName ) ) {
				improvedNames.append( "+#amountEach# #improvedName#" );
			}
		}

		player.pendingAbilityScoreImprovements -= 1;
		arguments.state.log.prepend(
			improvedNames.len()
				? "#player.name# improves their abilities: #arrayToList( improvedNames, ", " )#."
				: "#player.name#'s chosen abilities are already at the maximum of 20."
		);
	}

	/**
	 * Raises `player`'s `abbrev` ability score by `amount` (capped at 20),
	 * updating its modifier and any AC/equipped-weapon bonuses derived from
	 * it, then persisting the change — shared by applyAbilityScoreImprovement()
	 * for both the "+2 to one ability" and "+1 to two abilities" choices.
	 * Returns the full ability name raised (e.g. "Strength"), or "" if
	 * already at the cap.
	 */
	private function _increaseAbilityScore( player, abbrev, amount ) {
		var oldScore = arguments.player.abilityScores[ arguments.abbrev ];
		if ( oldScore >= 20 ) {
			return "";
		}
		var newScore = min( 20, oldScore + arguments.amount );
		var oldMod = arguments.player.modifiers[ arguments.abbrev ];
		var newMod = abilityModifier( newScore );
		arguments.player.abilityScores[ arguments.abbrev ] = newScore;
		arguments.player.modifiers[ arguments.abbrev ] = newMod;
		var modDelta = newMod - oldMod;

		if ( modDelta != 0 ) {
			if ( arguments.abbrev == "dex" ) {
				arguments.player.armorClass += modDelta;
			}
			for ( var item in arguments.player.inventory ) {
				if ( item.equipped && ( ( item.category == "melee" && arguments.abbrev == "str" ) || ( item.category == "ranged" && arguments.abbrev == "dex" ) ) ) {
					item.attackBonus += modDelta;
					item.damageBonus += modDelta;
					if ( structKeyExists( item, "id" ) ) {
						queryExecute(
							"UPDATE character_inventory SET attack_bonus = :attackBonus, damage_bonus = :damageBonus WHERE id = :id",
							{ "attackBonus": item.attackBonus, "damageBonus": item.damageBonus, "id": item.id },
							{ datasource: "gameserver" }
						);
					}
				}
			}
		}

		if ( structKeyExists( arguments.player, "characterId" ) ) {
			var dbColumns = { "str": "str", "dex": "dex", "con": "con", "int": "int_score", "wis": "wis", "cha": "cha" };
			queryExecute(
				"UPDATE characters SET #dbColumns[ arguments.abbrev ]# = :score, armor_class = :armorClass WHERE id = :characterId",
				{ "score": newScore, "armorClass": arguments.player.armorClass, "characterId": arguments.player.characterId },
				{ datasource: "gameserver" }
			);
		}

		var abilityFullNames = { "str": "Strength", "dex": "Dexterity", "con": "Constitution", "int": "Intelligence", "wis": "Wisdom", "cha": "Charisma" };
		return abilityFullNames[ arguments.abbrev ];
	}

	// The non-Fighting-Style feats with a real mechanical hook elsewhere in
	// this file (Alert: initiative, Grappler: Advantage vs. a Grappled
	// target, Magic Initiate: a simple attack cantrip, Savage Attacker: roll
	// damage twice, Skilled: skill proficiencies via _grantSkilledSkills())
	// — offered at an Ability Score Improvement level-up as the alternative
	// to raising ability scores. The other ~10 feats in the `feats` table
	// (the "Boon of ..." epic boons, plain "Ability Score Improvement" as a
	// feat) have no mechanical hook anywhere and aren't offered.
	LEVEL_UP_FEAT_NAMES = [ "Alert", "Grappler", "Magic Initiate", "Savage Attacker", "Skilled" ];

	/**
	 * The subset of LEVEL_UP_FEAT_NAMES `player` can still pick — every
	 * repeatable feat (Magic Initiate, Skilled — feats.repeatable), plus any
	 * non-repeatable one they don't already have.
	 */
	function availableLevelUpFeats( player ) {
		var repeatableRows = queryExecute(
			"SELECT name FROM feats WHERE repeatable = 1", {}, { datasource: "gameserver" }
		);
		var repeatableNames = [];
		for ( var row in repeatableRows ) {
			repeatableNames.append( row.name );
		}

		var available = [];
		for ( var featName in LEVEL_UP_FEAT_NAMES ) {
			var alreadyHas = structKeyExists( arguments.player, "feats" ) && arrayFindNoCase( arguments.player.feats, featName ) > 0;
			if ( !alreadyHas || arrayFindNoCase( repeatableNames, featName ) > 0 ) {
				available.append( featName );
			}
		}
		return available;
	}

	/**
	 * Grants `featName` (one of LEVEL_UP_FEAT_NAMES) to the player in place
	 * of an Ability Score Improvement, consuming one of their
	 * pendingAbilityScoreImprovements — the level-up screen's other choice,
	 * alongside applyAbilityScoreImprovement(). A no-op if there's no
	 * pending improvement to spend, or `featName` isn't a real feat.
	 *
	 * Re-picking a repeatable feat (Magic Initiate, Skilled) still applies
	 * its mechanical effect (e.g. Skilled grants 3 more skills) even though
	 * `character_feats` has a UNIQUE(character_id, feat_id) constraint that
	 * silently no-ops the second row — this app doesn't track how many
	 * times a feat's been taken, just whether it's held at all.
	 *
	 * @state The encounter's full mutable game state struct.
	 * @featName One of LEVEL_UP_FEAT_NAMES.
	 * @chosenSkills For "Skilled" only: up to 3 skill names the player picked
	 *  (see the level-up screen's secondary skill picker) — ignored for any
	 *  other feat.
	 */
	function grantChosenFeat( state, featName, chosenSkills = [] ) {
		var player = arguments.state.player;
		if ( !structKeyExists( player, "pendingAbilityScoreImprovements" ) || player.pendingAbilityScoreImprovements <= 0 ) {
			return;
		}
		if ( arguments.featName == "Skilled" && arguments.chosenSkills.len() != 3 ) {
			return;
		}
		var featRows = queryExecute(
			"SELECT id FROM feats WHERE name = :name",
			{ "name": arguments.featName },
			{ datasource: "gameserver" }
		);
		if ( featRows.recordCount == 0 ) {
			return;
		}

		if ( structKeyExists( player, "characterId" ) ) {
			queryExecute(
				"INSERT IGNORE INTO character_feats (character_id, feat_id) VALUES (:characterId, :featId)",
				{ "characterId": player.characterId, "featId": featRows.id[ 1 ] },
				{ datasource: "gameserver" }
			);
		}
		if ( arrayFindNoCase( player.feats, arguments.featName ) == 0 ) {
			arrayAppend( player.feats, arguments.featName );
		}
		player.pendingAbilityScoreImprovements -= 1;

		if ( arguments.featName == "Skilled" ) {
			_grantSkilledSkills( player, arguments.chosenSkills );
		}

		if ( arguments.featName == "Magic Initiate" && structKeyExists( player, "characterId" ) ) {
			queryExecute(
				"UPDATE characters SET pending_magic_initiate_cantrips = 2, pending_magic_initiate_spell = 1 WHERE id = :characterId",
				{ "characterId": player.characterId },
				{ datasource: "gameserver" }
			);
			player.hasMagicInitiate = true;
			_assignSpellcasting( player );
		}

		arguments.state.log.prepend( "#player.name# takes the #arguments.featName# feat instead of an Ability Score Improvement." );
	}

	/**
	 * Skilled: grants proficiency in the (up to 3) player-chosen `skills` the
	 * character doesn't already have — persisted the same way a class's
	 * chosen skills are (characters.chosen_skill_proficiencies).
	 */
	private function _grantSkilledSkills( player, skills ) {
		var newSkills = [];
		for ( var skill in arguments.skills ) {
			if ( arrayFindNoCase( arguments.player.skillProficiencies, skill ) == 0 && arrayFindNoCase( newSkills, skill ) == 0 ) {
				newSkills.append( skill );
				arrayAppend( arguments.player.skillProficiencies, skill );
			}
		}
		if ( !newSkills.len() || !structKeyExists( arguments.player, "characterId" ) ) {
			return;
		}

		var charRow = queryExecute(
			"SELECT chosen_skill_proficiencies FROM characters WHERE id = :characterId",
			{ "characterId": arguments.player.characterId },
			{ datasource: "gameserver" }
		);
		var storedSkills = ( charRow.recordCount > 0 && len( charRow.chosen_skill_proficiencies[ 1 ] ) )
			? listToArray( charRow.chosen_skill_proficiencies[ 1 ], "," )
			: [];
		for ( var skill in newSkills ) {
			storedSkills.append( skill );
		}
		queryExecute(
			"UPDATE characters SET chosen_skill_proficiencies = :skills WHERE id = :characterId",
			{ "skills": arrayToList( storedSkills, "," ), "characterId": arguments.player.characterId },
			{ datasource: "gameserver" }
		);
	}

	// The 4 Fighting Style feats with a mechanical hook in this file —
	// Archery (attack roll bonus), Great Weapon Fighting (reroll low damage
	// dice), Defense (+1 AC), Two-Weapon Fighting (ability mod on off-hand
	// damage). Chosen by the player, never auto-picked — see
	// grantFightingStyle()/pendingFightingStyleChoice().
	FIGHTING_STYLE_NAMES = [ "Archery", "Defense", "Great Weapon Fighting", "Two-Weapon Fighting" ];

	/**
	 * The pickable Fighting Style names — see FIGHTING_STYLE_NAMES.
	 */
	function fightingStyleNames() {
		return FIGHTING_STYLE_NAMES;
	}

	/**
	 * Grants a specific, player-chosen Fighting Style feat. Returns true if
	 * granted, false for an unrecognized style name or missing feat row.
	 *
	 * @characterId characters.id to grant the feat to.
	 * @styleName One of FIGHTING_STYLE_NAMES.
	 */
	function grantFightingStyle( characterId, styleName ) {
		if ( arrayFindNoCase( FIGHTING_STYLE_NAMES, arguments.styleName ) == 0 ) {
			return false;
		}
		var featRows = queryExecute(
			"SELECT id FROM feats WHERE name = :name",
			{ "name": arguments.styleName },
			{ datasource: "gameserver" }
		);
		if ( featRows.recordCount == 0 ) {
			return false;
		}
		queryExecute(
			"INSERT IGNORE INTO character_feats (character_id, feat_id) VALUES (:characterId, :featId)",
			{ "characterId": arguments.characterId, "featId": featRows.id[ 1 ] },
			{ datasource: "gameserver" }
		);
		return true;
	}

	/**
	 * Whether `characterId` has an un-chosen Fighting Style waiting (Fighter
	 * gets one at level 1 and a second, "Additional Fighting Style", at
	 * level 7; Paladin/Ranger get one at level 2) — compares how many
	 * Fighting-Style-granting class features have been recorded against how
	 * many Fighting Style feats have actually been chosen, since a
	 * character can be due more than one over their career. Returns
	 * `{ pending, availableStyles }` — `availableStyles` excludes any style
	 * already held (can't pick the same one twice).
	 */
	function pendingFightingStyleChoice( characterId ) {
		var unlockedRows = queryExecute(
			"SELECT COUNT(*) AS unlockedCount FROM character_features chf
			 JOIN class_features cf ON cf.id = chf.class_feature_id
			 WHERE chf.character_id = :characterId AND cf.name IN ('Fighting Style', 'Additional Fighting Style')",
			{ "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
		var chosenRows = queryExecute(
			"SELECT f.name FROM character_feats chf JOIN feats f ON f.id = chf.feat_id WHERE chf.character_id = :characterId",
			{ "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
		var chosenNames = [];
		var chosenStyleCount = 0;
		for ( var row in chosenRows ) {
			chosenNames.append( row.name );
			if ( arrayFindNoCase( FIGHTING_STYLE_NAMES, row.name ) > 0 ) {
				chosenStyleCount += 1;
			}
		}

		var pending = unlockedRows.unlockedCount[ 1 ] > chosenStyleCount;
		var availableStyles = [];
		if ( pending ) {
			for ( var style in FIGHTING_STYLE_NAMES ) {
				if ( arrayFindNoCase( chosenNames, style ) == 0 ) {
					availableStyles.append( style );
				}
			}
		}
		return { "pending": pending, "availableStyles": availableStyles };
	}

	/**
	 * Second Wind (Fighter 1): once per encounter, a bonus action heal of
	 * 1d10 + Fighter level Hit Points. A no-op if the bonus action is
	 * already spent, the feature isn't held, it's already been used this
	 * encounter, or the player is down/incapacitated.
	 */
	function useSecondWind( state ) {
		var player = arguments.state.player;
		if (
			( structKeyExists( arguments.state, "bonusActionUsed" ) && arguments.state.bonusActionUsed ) ||
			player.hitPoints <= 0 || isIncapacitated( player ) ||
			!structKeyExists( player, "features" ) || arrayFindNoCase( player.features, "Second Wind" ) == 0 ||
			player.usedSecondWind
		) {
			return;
		}
		arguments.state.bonusActionUsed = true;
		player.usedSecondWind = true;
		var healing = rollSum( 1, 10 ) + player.level;
		player.hitPoints = min( player.maxHitPoints, player.hitPoints + healing );
		arguments.state.log.prepend( "#player.name# uses Second Wind, healing #healing# Hit Points (#player.hitPoints#/#player.maxHitPoints# HP)." );
	}

	/**
	 * Rage (Barbarian 1) uses per long rest, from RAGE_USES_BY_LEVEL.
	 */
	private function _rageUsesForLevel( level ) {
		return RAGE_USES_BY_LEVEL[ min( max( arguments.level, 1 ), RAGE_USES_BY_LEVEL.len() ) ];
	}

	/**
	 * Derives `player.ragesRemaining` from the persisted `player.ragesUsed`
	 * (like spentSpellSlots, the actual source of truth) and the level-based
	 * max (_rageUsesForLevel()) — 0 for a non-Barbarian. Called on load, on
	 * level-up (a higher level can raise the max mid-encounter), and after
	 * startRage()/shortRest()/longRest() change `ragesUsed`.
	 */
	private function _recomputeRagesRemaining( player ) {
		if ( !structKeyExists( arguments.player, "features" ) || arrayFindNoCase( arguments.player.features, "Rage" ) == 0 ) {
			arguments.player.ragesRemaining = 0;
			return;
		}
		var used = structKeyExists( arguments.player, "ragesUsed" ) ? arguments.player.ragesUsed : 0;
		arguments.player.ragesRemaining = max( 0, _rageUsesForLevel( arguments.player.level ) - used );
	}

	/**
	 * Rage's melee weapon damage bonus by level: +2 (1-8), +3 (9-15), +4 (16-20).
	 */
	private function _rageDamageBonus( level ) {
		if ( arguments.level >= 16 ) {
			return 4;
		} else if ( arguments.level >= 9 ) {
			return 3;
		}
		return 2;
	}

	/**
	 * Enters a Rage (Barbarian 1): a bonus action, consuming one of
	 * `player.ragesRemaining`. While raging (`player.isRaging`), melee
	 * weapon attacks deal bonus damage (see resolveAttack()'s Rage note),
	 * Strength saving throws have Advantage (see rollSavingThrow()), and the
	 * character gains resistance to Bludgeoning/Piercing/Slashing damage.
	 * A no-op if the feature isn't held, no uses remain, already raging, or
	 * the bonus action is already spent.
	 *
	 * Simplified from the full SRD rule: rage here lasts until endRage() is
	 * called or the encounter ends, rather than RAW's "ends early if you
	 * don't attack a hostile creature or take damage on your turn" — that
	 * nuance isn't tracked, matching this app's general pattern of not
	 * modeling turn-by-turn upkeep conditions it can't verify cheaply.
	 */
	function startRage( state ) {
		var player = arguments.state.player;
		if (
			( structKeyExists( arguments.state, "bonusActionUsed" ) && arguments.state.bonusActionUsed ) ||
			player.hitPoints <= 0 || isIncapacitated( player ) ||
			!structKeyExists( player, "features" ) || arrayFindNoCase( player.features, "Rage" ) == 0 ||
			player.isRaging || !structKeyExists( player, "ragesRemaining" ) || player.ragesRemaining <= 0
		) {
			return;
		}
		arguments.state.bonusActionUsed = true;
		player.ragesUsed = ( structKeyExists( player, "ragesUsed" ) ? player.ragesUsed : 0 ) + 1;
		_recomputeRagesRemaining( player );
		player.isRaging = true;
		for ( var damageType in [ "Bludgeoning", "Piercing", "Slashing" ] ) {
			if ( arrayFindNoCase( player.resistances, damageType ) == 0 ) {
				player.resistances.append( damageType );
			}
		}
		arguments.state.log.prepend( "#player.name# flies into a Rage! (#player.ragesRemaining# use#( player.ragesRemaining == 1 ? '' : 's' )# left)" );
	}

	/**
	 * Ends an active Rage early (no action cost, matching the SRD's "you can
	 * end your Rage on your turn as a free action") — removes the
	 * Bludgeoning/Piercing/Slashing resistance startRage() granted. A no-op
	 * if not currently raging.
	 */
	function endRage( state ) {
		var player = arguments.state.player;
		if ( !structKeyExists( player, "isRaging" ) || !player.isRaging ) {
			return;
		}
		player.isRaging = false;
		for ( var damageType in [ "Bludgeoning", "Piercing", "Slashing" ] ) {
			arrayDelete( player.resistances, damageType, "textnocase" );
		}
		arguments.state.log.prepend( "#player.name#'s Rage ends." );
	}

	/**
	 * Whether `characterId` has an Expertise pick waiting (Rogue 1, Bard 2,
	 * Ranger 9 in this dataset — each grants exactly one "choose 2 skills"
	 * Expertise, not stacking further) — compares how many Expertise-granting
	 * class features have been recorded (each worth 2 skills) against how
	 * many Expertise skills have actually been chosen. Returns
	 * `{ pending, availableSkills }` — `availableSkills` is the character's
	 * own skill proficiencies not already given Expertise (Expertise can
	 * only be applied to a skill you're already proficient in).
	 */
	function pendingExpertiseChoice( characterId ) {
		var charRow = queryExecute(
			"SELECT chosen_skill_proficiencies, expertise_skills, species, background FROM characters WHERE id = :characterId",
			{ "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
		if ( charRow.recordCount == 0 ) {
			return { "pending": false, "availableSkills": [] };
		}
		var unlockedRows = queryExecute(
			"SELECT COUNT(*) AS unlockedCount FROM character_features chf
			 JOIN class_features cf ON cf.id = chf.class_feature_id
			 WHERE chf.character_id = :characterId AND cf.name = 'Expertise'",
			{ "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
		var expertiseSkills = len( charRow.expertise_skills[ 1 ] ) ? listToArray( charRow.expertise_skills[ 1 ] ) : [];
		var pending = ( unlockedRows.unlockedCount[ 1 ] * 2 ) > expertiseSkills.len();
		var availableSkills = [];
		if ( pending ) {
			var speciesMechanics = _resolveSpeciesMechanics( len( charRow.species[ 1 ] ) ? charRow.species[ 1 ] : "" );
			var skillProficiencies = _skillProficienciesFromTraits( speciesMechanics.traitNames, charRow.background[ 1 ] );
			if ( len( charRow.chosen_skill_proficiencies[ 1 ] ) ) {
				for ( var chosenSkill in listToArray( charRow.chosen_skill_proficiencies[ 1 ], "," ) ) {
					if ( arrayFindNoCase( skillProficiencies, chosenSkill ) == 0 ) {
						skillProficiencies.append( chosenSkill );
					}
				}
			}
			for ( var skill in skillProficiencies ) {
				if ( arrayFindNoCase( expertiseSkills, skill ) == 0 ) {
					availableSkills.append( skill );
				}
			}
		}
		return { "pending": pending, "availableSkills": availableSkills };
	}

	/**
	 * Grants Expertise in one already-proficient skill, per
	 * pendingExpertiseChoice() — the character sheet's "Choose Expertise"
	 * panel's action. A no-op if the skill is already an Expertise pick.
	 */
	function chooseExpertise( characterId, skillName ) {
		var current = queryExecute(
			"SELECT expertise_skills FROM characters WHERE id = :characterId",
			{ "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
		if ( current.recordCount == 0 ) {
			return;
		}
		var expertiseSkills = len( current.expertise_skills[ 1 ] ) ? listToArray( current.expertise_skills[ 1 ] ) : [];
		if ( arrayFindNoCase( expertiseSkills, arguments.skillName ) > 0 ) {
			return;
		}
		expertiseSkills.append( arguments.skillName );
		queryExecute(
			"UPDATE characters SET expertise_skills = :skills WHERE id = :characterId",
			{ "skills": arrayToList( expertiseSkills, "," ), "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
	}

	/**
	 * Simplified cantrips-known-by-level rule shared by every full-caster
	 * class (the SRD's actual per-class tables vary slightly — e.g. Cleric
	 * gains its 4th cantrip at level 4, Warlock's tables differ further
	 * still — collapsed here to one curve, a deliberate simplification
	 * matching how this app already treats "spells known" more broadly).
	 * Half-casters (Paladin, Ranger) and Magic Initiate don't grow their
	 * cantrip count at all, so this only applies to FULL_CASTER_CLASSES.
	 */
	private function _expectedCantripCount( level ) {
		if ( arguments.level >= 10 ) {
			return 4;
		} else if ( arguments.level >= 4 ) {
			return 3;
		}
		return 2;
	}

	/**
	 * Whether `characterId` (a full-caster class) has fewer known cantrips
	 * than their level should grant (see _expectedCantripCount()) —
	 * compares that expected count against `known_cantrips`' actual length,
	 * never auto-granting the difference. Returns
	 * `{ pending, availableCantrips }`; `availableCantrips` is every
	 * castable cantrip for the class not already known.
	 */
	function pendingCantripChoice( characterId ) {
		var charRow = queryExecute(
			"SELECT cl.name AS className, c.level, c.known_cantrips
			 FROM characters c JOIN classes cl ON cl.id = c.class_id
			 WHERE c.id = :characterId",
			{ "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
		if ( charRow.recordCount == 0 || arrayFindNoCase( FULL_CASTER_CLASSES, charRow.className[ 1 ] ) == 0 ) {
			return { "pending": false, "availableCantrips": [] };
		}

		var knownNames = len( charRow.known_cantrips[ 1 ] ) ? listToArray( charRow.known_cantrips[ 1 ] ) : [];
		var pending = knownNames.len() < _expectedCantripCount( charRow.level[ 1 ] );
		var availableCantrips = [];
		if ( pending ) {
			for ( var cantrip in listCastableSpells( charRow.className[ 1 ], 0 ) ) {
				if ( arrayFindNoCase( knownNames, cantrip.name ) == 0 ) {
					availableCantrips.append( cantrip );
				}
			}
		}
		return { "pending": pending, "availableCantrips": availableCantrips };
	}

	/**
	 * Records a player-chosen new cantrip against `characterId`, per
	 * pendingCantripChoice() — the character sheet's "Learn a Cantrip"
	 * panel's action. A no-op if the cantrip is already known.
	 */
	function chooseCantrip( characterId, cantripName ) {
		_appendKnownSpellName( arguments.characterId, "known_cantrips", arguments.cantripName );
	}

	/**
	 * Whether `characterId` has unlocked a new maximum spell-slot level
	 * (via the SPELL_SLOTS_FULL_CASTER/HALF_CASTER tables) that they don't
	 * yet have a known spell of — e.g. reaching level 3 unlocks 2nd-level
	 * slots, so they're due a 2nd-level spell pick. Only ever grants one
	 * spell per unlocked level, matching how a level-1 character starts
	 * with exactly one 1st-level spell. Returns
	 * `{ pending, availableSpells, level }` — `level` is the highest
	 * spell level they're due a pick for; `availableSpells` excludes any
	 * spell of that level already known.
	 */
	function pendingSpellChoice( characterId ) {
		var charRow = queryExecute(
			"SELECT cl.name AS className, c.level, c.known_spells
			 FROM characters c JOIN classes cl ON cl.id = c.class_id
			 WHERE c.id = :characterId",
			{ "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
		if ( charRow.recordCount == 0 ) {
			return { "pending": false, "availableSpells": [], "level": 0 };
		}
		var className = charRow.className[ 1 ];
		var isFullCaster = isFullCasterClass( className );
		var isHalfCaster = arrayFindNoCase( HALF_CASTER_CLASSES, className ) > 0;
		if ( !isFullCaster && !isHalfCaster ) {
			return { "pending": false, "availableSpells": [], "level": 0 };
		}

		var slotTable = isFullCaster ? SPELL_SLOTS_FULL_CASTER : SPELL_SLOTS_HALF_CASTER;
		var levelIndex = min( charRow.level[ 1 ], slotTable.len() );
		var maxSlotLevel = 0;
		if ( levelIndex > 0 ) {
			var slotsAtLevel = slotTable[ levelIndex ];
			for ( var spellLevel = 1; spellLevel <= slotsAtLevel.len(); spellLevel++ ) {
				if ( slotsAtLevel[ spellLevel ] > 0 ) {
					maxSlotLevel = spellLevel;
				}
			}
		}
		if ( maxSlotLevel == 0 ) {
			return { "pending": false, "availableSpells": [], "level": 0 };
		}

		var knownNames = len( charRow.known_spells[ 1 ] ) ? listToArray( charRow.known_spells[ 1 ] ) : [];
		var availableSpellsByLevel = listCastableSpells( className, maxSlotLevel );
		var spellNamesAtMaxLevel = [];
		for ( var spell in availableSpellsByLevel ) {
			spellNamesAtMaxLevel.append( spell.name );
		}
		var knownAtMaxLevel = 0;
		for ( var name in knownNames ) {
			if ( arrayFindNoCase( spellNamesAtMaxLevel, name ) > 0 ) {
				knownAtMaxLevel += 1;
			}
		}
		var pending = knownAtMaxLevel == 0;
		var availableSpells = [];
		if ( pending ) {
			for ( var spell in availableSpellsByLevel ) {
				if ( arrayFindNoCase( knownNames, spell.name ) == 0 ) {
					availableSpells.append( spell );
				}
			}
		}
		return { "pending": pending, "availableSpells": availableSpells, "level": maxSlotLevel };
	}

	/**
	 * Records a player-chosen new leveled spell against `characterId`, per
	 * pendingSpellChoice() — the character sheet's "Learn a Spell" panel's
	 * action. A no-op if the spell is already known.
	 */
	function chooseSpell( characterId, spellName ) {
		_appendKnownSpellName( arguments.characterId, "known_spells", arguments.spellName );
	}

	/**
	 * Returns pending Magic Initiate spell/cantrip picks for the character:
	 * `{ pendingCantrips, availableCantrips, pendingSpell, availableSpells }`.
	 * Uses the Wizard spell list as the source for Magic Initiate picks.
	 */
	function pendingMagicInitiateChoice( characterId ) {
		var charRow = queryExecute(
			"SELECT known_cantrips, known_spells, pending_magic_initiate_cantrips, pending_magic_initiate_spell
			 FROM characters WHERE id = :characterId",
			{ "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
		if ( charRow.recordCount == 0 ) {
			return { "pendingCantrips": 0, "availableCantrips": [], "pendingSpell": false, "availableSpells": [] };
		}

		var pendingCantrips = charRow.pending_magic_initiate_cantrips[ 1 ];
		var pendingSpellFlag = charRow.pending_magic_initiate_spell[ 1 ];
		var knownCantrips    = len( charRow.known_cantrips[ 1 ] ) ? listToArray( charRow.known_cantrips[ 1 ] ) : [];
		var knownSpells      = len( charRow.known_spells[ 1 ] ) ? listToArray( charRow.known_spells[ 1 ] ) : [];

		var availableCantrips = [];
		if ( pendingCantrips > 0 ) {
			for ( var cantrip in listCastableSpells( "Wizard", 0 ) ) {
				if ( arrayFindNoCase( knownCantrips, cantrip.name ) == 0 ) {
					availableCantrips.append( cantrip );
				}
			}
		}

		var availableSpells = [];
		if ( pendingSpellFlag ) {
			for ( var spell in listCastableSpells( "Wizard", 1 ) ) {
				if ( arrayFindNoCase( knownSpells, spell.name ) == 0 ) {
					availableSpells.append( spell );
				}
			}
		}

		return {
			"pendingCantrips":    pendingCantrips,
			"availableCantrips":  availableCantrips,
			"pendingSpell":       pendingSpellFlag,
			"availableSpells":    availableSpells
		};
	}

	/**
	 * Records one Magic Initiate cantrip pick, decrementing the pending count.
	 */
	function chooseMagicInitiateCantrip( characterId, cantripName ) {
		_appendKnownSpellName( arguments.characterId, "known_cantrips", arguments.cantripName );
		queryExecute(
			"UPDATE characters
			 SET pending_magic_initiate_cantrips = GREATEST( 0, pending_magic_initiate_cantrips - 1 )
			 WHERE id = :characterId",
			{ "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
	}

	/**
	 * Records the Magic Initiate 1st-level spell pick, clearing the pending flag.
	 */
	function chooseMagicInitiateSpell( characterId, spellName ) {
		_appendKnownSpellName( arguments.characterId, "known_spells", arguments.spellName );
		queryExecute(
			"UPDATE characters SET pending_magic_initiate_spell = 0 WHERE id = :characterId",
			{ "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
	}

	/**
	 * Appends `spellName` to a character's comma-separated known_cantrips/
	 * known_spells column, unless already present. Shared by
	 * chooseCantrip()/chooseSpell(); `columnName` is always one of those two
	 * literal, hardcoded column names, never user input.
	 */
	private function _appendKnownSpellName( characterId, columnName, spellName ) {
		var current = queryExecute(
			"SELECT #arguments.columnName# AS known_list FROM characters WHERE id = :characterId",
			{ "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
		if ( current.recordCount == 0 ) {
			return;
		}
		var known = len( current.known_list[ 1 ] ) ? listToArray( current.known_list[ 1 ] ) : [];
		if ( arrayFindNoCase( known, arguments.spellName ) > 0 ) {
			return;
		}
		known.append( arguments.spellName );
		queryExecute(
			"UPDATE characters SET #arguments.columnName# = :knownList WHERE id = :characterId",
			{ "characterId": arguments.characterId, "knownList": arrayToList( known ) },
			{ datasource: "gameserver" }
		);
	}

	/**
	 * Persists current HP, spent hit dice, and spent spell slots to the DB so
	 * they survive across encounter boundaries. Called after each combat ends
	 * and after each hit die is spent during a short rest.
	 */
	function saveCharacterState( player ) {
		var spentSlots = structKeyExists( arguments.player, "spentSpellSlots" ) ? arguments.player.spentSpellSlots : {};
		queryExecute(
			"UPDATE characters SET
			     hit_points = :hp, hit_dice_spent = :hitDiceSpent, spent_spell_slots = :spentSlots,
			     game_clock_seconds = :gameClockSeconds, last_long_rest_seconds = :lastLongRestSeconds,
			     rages_used = :ragesUsed, used_second_wind = :usedSecondWind, used_breath_weapon = :usedBreathWeapon,
			     used_relentless_endurance = :usedRelentlessEndurance, used_heroic_inspiration = :usedHeroicInspiration,
			     used_magic_initiate_spell = :usedMagicInitiateSpell
			 WHERE id = :characterId",
			{
				"hp":           arguments.player.hitPoints,
				"hitDiceSpent": arguments.player.hitDiceSpent,
				"spentSlots":   JSONSerialize( spentSlots ),
				"gameClockSeconds": structKeyExists( arguments.player, "gameClockSeconds" ) ? arguments.player.gameClockSeconds : 0,
				"lastLongRestSeconds": ( structKeyExists( arguments.player, "lastLongRestSeconds" ) && !isNull( arguments.player.lastLongRestSeconds ) )
					? arguments.player.lastLongRestSeconds : javaCast( "null", 0 ),
				"ragesUsed": structKeyExists( arguments.player, "ragesUsed" ) ? arguments.player.ragesUsed : 0,
				"usedSecondWind": ( structKeyExists( arguments.player, "usedSecondWind" ) && arguments.player.usedSecondWind ) ? 1 : 0,
				"usedBreathWeapon": ( structKeyExists( arguments.player, "usedBreathWeapon" ) && arguments.player.usedBreathWeapon ) ? 1 : 0,
				"usedRelentlessEndurance": ( structKeyExists( arguments.player, "usedRelentlessEndurance" ) && arguments.player.usedRelentlessEndurance ) ? 1 : 0,
				"usedHeroicInspiration": ( structKeyExists( arguments.player, "usedHeroicInspiration" ) && arguments.player.usedHeroicInspiration ) ? 1 : 0,
				"usedMagicInitiateSpell": ( structKeyExists( arguments.player, "usedMagicInitiateSpell" ) && arguments.player.usedMagicInitiateSpell ) ? 1 : 0,
				"characterId":  arguments.player.characterId
			},
			{ datasource: "gameserver" }
		);
	}

	/**
	 * Short Rest: a minimum 1-hour activity (advances the in-game clock by
	 * SHORT_REST_SECONDS) during which the character can spend `diceCount`
	 * Hit Dice (each d[hitDieSize] + CON mod, minimum 0 per die) to recover
	 * HP — clamped to however many are actually left unspent. Also recovers
	 * Second Wind and one Rage use, per those features' "regain ... when you
	 * finish a Short Rest" text. `diceCount` can be 0 (rest without spending
	 * any dice — still worth taking purely for the Second Wind/Rage
	 * recovery). Returns `{ rolls, healing }` — `rolls` is one entry per die
	 * actually spent, so the caller can log each roll.
	 *
	 * @player The player struct to rest (mutated in place).
	 * @diceCount How many Hit Dice to spend as part of this rest (default 1).
	 */
	function shortRest( player, diceCount = 1 ) {
		var spendable = min( max( 0, arguments.diceCount ), arguments.player.hitDiceMax - arguments.player.hitDiceSpent );
		var rolls = [];
		var healing = 0;
		for ( var i = 1; i <= spendable; i++ ) {
			var roll = randRange( 1, arguments.player.hitDieSize );
			rolls.append( roll );
			healing += max( 0, roll + arguments.player.modifiers.con );
		}
		arguments.player.hitDiceSpent = min( arguments.player.hitDiceMax, arguments.player.hitDiceSpent + spendable );
		arguments.player.hitPoints = min( arguments.player.maxHitPoints, arguments.player.hitPoints + healing );

		arguments.player.gameClockSeconds += SHORT_REST_SECONDS;
		arguments.player.usedSecondWind = false;
		if ( structKeyExists( arguments.player, "ragesUsed" ) && arguments.player.ragesUsed > 0 ) {
			arguments.player.ragesUsed -= 1;
		}
		_recomputeRagesRemaining( arguments.player );

		// Warlocks recover all Pact Magic spell slots on a short rest.
		var isWarlock = arguments.player.class == "Warlock";
		if ( !isWarlock && structKeyExists( arguments.player, "classes" ) ) {
			for ( var classEntry in arguments.player.classes ) {
				if ( classEntry.className == "Warlock" ) {
					isWarlock = true;
					break;
				}
			}
		}
		if ( isWarlock ) {
			arguments.player.spentSpellSlots = {};
			_recomputeSpellSlots( arguments.player );
		}

		saveCharacterState( arguments.player );
		return { "rolls": rolls, "healing": healing, "conMod": arguments.player.modifiers.con };
	}

	/**
	 * How many more in-game hours (rounded up) until `player` is allowed
	 * another Long Rest — 0 if one is allowed right now (including if
	 * they've never taken one). Doesn't mutate anything; used both by
	 * longRest() itself and by the UI to show/disable the Long Rest button
	 * ahead of actually attempting it.
	 */
	function hoursUntilNextLongRest( player ) {
		if ( isNull( arguments.player.lastLongRestSeconds ) ) {
			return 0;
		}
		var elapsed = arguments.player.gameClockSeconds - arguments.player.lastLongRestSeconds;
		if ( elapsed >= LONG_REST_COOLDOWN_SECONDS ) {
			return 0;
		}
		return ceiling( ( LONG_REST_COOLDOWN_SECONDS - elapsed ) / 3600 );
	}

	/**
	 * Long Rest: an 8-hour activity (advances the in-game clock by
	 * LONG_REST_SECONDS) that fully restores HP, recovers up to half the
	 * character's max hit dice (minimum 1), resets all spell slots, and
	 * recovers every other Long-Rest-only resource (Rage uses, Breath
	 * Weapon, Relentless Endurance, Heroic Inspiration, Magic Initiate's
	 * bonus spell). Blocked — a no-op, per the "can't benefit from more than
	 * one Long Rest in a 24-hour period" rule — if one was already completed
	 * within the last LONG_REST_COOLDOWN_SECONDS of in-game time, unless
	 * `ignoreCooldown` is true. Returns `{ success, hoursUntilNext }` so the
	 * caller can show why it was refused; `hoursUntilNext` is 0 when
	 * `success` is true.
	 *
	 * @player The player struct to rest (mutated in place).
	 * @ignoreCooldown Bypasses the 24-hour gate — used only by
	 *  default.bx's onMount() to fully heal a character who loaded at 0 HP
	 *  (persisted from a defeat), so they're never left permanently stuck
	 *  just because they happened to rest recently. Not exposed to the
	 *  player-facing Rest panel, which always respects the real cooldown.
	 */
	function longRest( player, ignoreCooldown = false ) {
		var hoursUntilNext = arguments.ignoreCooldown ? 0 : hoursUntilNextLongRest( arguments.player );
		if ( hoursUntilNext > 0 ) {
			return { "success": false, "hoursUntilNext": hoursUntilNext };
		}

		arguments.player.gameClockSeconds += LONG_REST_SECONDS;
		arguments.player.lastLongRestSeconds = arguments.player.gameClockSeconds;

		arguments.player.hitPoints    = arguments.player.maxHitPoints;
		var recoverDice               = max( 1, int( arguments.player.hitDiceMax / 2 ) );
		arguments.player.hitDiceSpent = max( 0, arguments.player.hitDiceSpent - recoverDice );
		arguments.player.spentSpellSlots = {};
		arguments.player.ragesUsed = 0;
		arguments.player.usedSecondWind = false;
		arguments.player.usedBreathWeapon = false;
		arguments.player.usedRelentlessEndurance = false;
		arguments.player.usedHeroicInspiration = false;
		arguments.player.usedMagicInitiateSpell = false;
		_assignSpellcasting( arguments.player );
		_recomputeRagesRemaining( arguments.player );
		saveCharacterState( arguments.player );
		return { "success": true, "hoursUntilNext": 0 };
	}

	/**
	 * D&D 5e CR-vs-party-level guidance is calibrated for a four-person
	 * party — this app only ever fields 2-3 solo monsters against one
	 * character at once (see MIN_MOB_COUNT/MAX_MOB_COUNT in default.bx), so
	 * a monster's CR needs to sit well below the player's level rather than
	 * at or above it, and the top of the band matters more than the bottom
	 * (a CR right at the target, times up to 3 of them, is already a hard
	 * fight solo). Capped at level/4 (so a level 1-4 character never faces
	 * anything above CR 1/4-ish), down to a quarter of that for variety.
	 */
	private function _levelAppropriateCRRange( level ) {
		var target = max( 0.125, arguments.level / 4 );
		return { "min": target * 0.25, "max": target };
	}

	/**
	 * Parses a monsters.cr value ("1/8", "1/2", "5", ...) into a decimal
	 * number for range comparisons. Returns -1 for NULL/blank so it never
	 * matches a CR range.
	 */
	private function _crToDecimal( crText ) {
		if ( isNull( arguments.crText ) || !len( trim( arguments.crText ) ) ) {
			return -1;
		}
		if ( find( "/", arguments.crText ) ) {
			var parts = listToArray( arguments.crText, "/" );
			return val( parts[ 1 ] ) / val( parts[ 2 ] );
		}
		return val( arguments.crText );
	}

	/**
	 * Extracts the base walking speed (in feet) from a monsters.speed string
	 * ("30 ft.", "10 ft., Swim 40 ft.") — always the first number, per the
	 * SRD stat block convention of listing walking speed first.
	 */
	private function _parseMonsterSpeed( speedText ) {
		var match = reFind( "(\d+)\s*ft", arguments.speedText, 1, true );
		if ( structKeyExists( match, "len" ) && match.len.len() >= 2 && match.len[ 2 ] > 0 ) {
			return int( mid( arguments.speedText, match.pos[ 2 ], match.len[ 2 ] ) );
		}
		return 30;
	}

	/**
	 * Splits a monsters.vulnerabilities/resistances/immunities cell ("Poison;
	 * Exhaustion, Poisoned") into a flat array — both "," and ";" separate
	 * entries in the seeded SRD data.
	 */
	private function _parseMonsterDamageList( text ) {
		if ( isNull( arguments.text ) || !len( trim( arguments.text ) ) ) {
			return [];
		}
		var normalized = replace( arguments.text, ";", ",", "all" );
		return arrayMap( listToArray( normalized, "," ), ( p ) => trim( p ) );
	}

	/**
	 * A monsters.immunities cell packs two different lists into one string,
	 * separated by ";" — damage types before it, condition names after
	 * ("Poison, Thunder; Exhaustion, Grappled, Paralyzed, Poisoned, ...").
	 * Splitting them out lets addCondition() actually honor a monster's
	 * condition immunities instead of silently mixing them into the
	 * damage-type immunities list, where they'd never match anything.
	 */
	private function _parseMonsterImmunities( text ) {
		if ( isNull( arguments.text ) || !len( trim( arguments.text ) ) ) {
			return { "damage": [], "conditions": [] };
		}
		var parts = listToArray( arguments.text, ";" );
		return {
			"damage": _parseMonsterDamageList( parts[ 1 ] ),
			"conditions": ( parts.len() >= 2 ) ? _parseMonsterDamageList( parts[ 2 ] ) : []
		};
	}

	/**
	 * Strips the SRD's "or Small "/"(Cleric)"-style qualifiers off a
	 * monsters.creature_type cell, leaving just the bare type ("Humanoid").
	 */
	private function _cleanMonsterCreatureType( creatureType ) {
		if ( isNull( arguments.creatureType ) || !len( trim( arguments.creatureType ) ) ) {
			return "";
		}
		var cleaned = reReplace( arguments.creatureType, "^(or\s+)?(Tiny|Small|Medium|Large|Huge|Gargantuan)\s+", "", "one" );
		cleaned = reReplace( cleaned, "\s*\([^)]*\)\s*$", "", "one" );
		return trim( cleaned );
	}

	private function _hasWeaponCategory( items, category ) {
		for ( var it in arguments.items ) {
			if ( it.category == arguments.category ) {
				return true;
			}
		}
		return false;
	}

	/**
	 * Builds this app's weapon-shaped inventory items from a monster's
	 * actions_json array (see migration 008_structured_monster_data.sql) —
	 * every field (category, damageType, range, etc.) is already precomputed
	 * at import/conversion time (see resources/database/seeds/
	 * generate_monster_seed.py and convert_legacy_monsters.py), so this is a
	 * pure struct-shape read, no text parsing. Non-attack entries (category
	 * "") are naturally skipped, and only the first melee / first ranged
	 * attack found is kept — equippedWeapon() only tracks one weapon per
	 * category.
	 */
	private function _parseStructuredActions( actions ) {
		var attacks = [];
		for ( var action in arguments.actions ) {
			if ( !len( action.category ) || _hasWeaponCategory( attacks, action.category ) ) {
				continue;
			}
			var item = {
				"name": action.name,
				"category": action.category,
				"damageDice": action.damageDice,
				"damageType": action.damageType,
				"attackBonus": action.attackBonus,
				"damageBonus": action.damageBonus,
				"equipped": true
			};
			if ( action.category == "ranged" ) {
				item.normalRange = action.normalRange;
				item.longRange = action.longRange;
			}
			arrayAppend( attacks, item );
		}
		return attacks;
	}

	/**
	 * Finds a monster's first damage-dealing save action (saveDC > 0 and a
	 * precomputed damageDice, but no attackBonus) among its actions_json
	 * entries — the JSON counterpart to a monster's "**_Acid Breath (Recharge
	 * 5-6)._**" style special attack. Only ever searches `actions`, not
	 * `special_abilities` — a monster's special_abilities can include
	 * damage-dealing traits that aren't something it can proactively use on
	 * its turn (e.g. a "Death Burst"/"Death Throes" explode-on-death effect),
	 * which would be wrong to fire as an active attack.
	 */
	private function _parseStructuredSpecialAttack( actions ) {
		for ( var action in arguments.actions ) {
			if ( len( action.damageDice ) && action.attackBonus == 0 && action.saveDC > 0 ) {
				var diceParts = listToArray( action.damageDice, "d" );
				return {
					"name": action.name,
					"saveAbility": action.saveAbility,
					"saveAbilityLabel": action.saveAbilityLabel,
					"saveDC": action.saveDC,
					"rangeSquares": action.rangeSquares,
					"diceCount": int( diceParts[ 1 ] ),
					"diceSides": int( diceParts[ 2 ] ),
					"damageBonus": action.damageBonus,
					"damageType": action.damageType
				};
			}
		}
		return javaCast( "null", 0 );
	}

	/**
	 * Converts a monster's precomputed Multiattack entry (multiattackCount,
	 * see generate_monster_seed.py/convert_legacy_monsters.py) into this
	 * app's attacksPerTurn()/features-array convention (the same "Extra
	 * Attack"/"Two Extra Attacks" strings the player's Fighter features
	 * use), so monster Multiattack rides the exact same mechanism rather
	 * than a separate one.
	 */
	private function _structuredMultiattackCount( actions ) {
		for ( var action in arguments.actions ) {
			if ( action.multiattackCount > 0 ) {
				return action.multiattackCount;
			}
		}
		return 1;
	}

	private function _multiattackFeatures( count ) {
		var features = [];
		if ( arguments.count >= 2 ) {
			arrayAppend( features, "Extra Attack" );
		}
		if ( arguments.count >= 3 ) {
			arrayAppend( features, "Two Extra Attacks" );
		}
		return features;
	}

	/**
	 * Case-insensitive "does this structured actions/special_abilities array
	 * have an entry whose name contains X" check — e.g. "Spellcasting" also
	 * matches "Innate Spellcasting", "Pack Tactics" matches a suffixed
	 * "Pack Tactics (Recharge 5-6)".
	 */
	private function _hasStructuredTraitByName( entries, traitName ) {
		for ( var entry in arguments.entries ) {
			if ( findNoCase( arguments.traitName, entry.name ) > 0 ) {
				return true;
			}
		}
		return false;
	}

	/**
	 * A monster's flat per-turn heal (see _runOneOpponentTurn()) — the
	 * precomputed healAmount field on whichever special_abilities entry is
	 * named "Regeneration" (see generate_monster_seed.py/
	 * convert_legacy_monsters.py), 0 if it has none.
	 */
	private function _structuredRegenerationAmount( specialAbilities ) {
		for ( var ability in arguments.specialAbilities ) {
			if ( findNoCase( "Regeneration", ability.name ) > 0 ) {
				return ability.healAmount;
			}
		}
		return 0;
	}

	/**
	 * A monster's Parry AC bonus (see resolveAttack()) — the reactions_json
	 * entry named "Parry" doesn't precompute its AC bonus as a structured
	 * field (unlike Regeneration's healAmount), only in its `desc` text
	 * ("...adds 2 to its AC against that attack..."), so it's extracted
	 * with the same reFind()-with-subexpressions idiom already used
	 * elsewhere in this file (see _parseMonsterSpeed()). 0 if the monster
	 * has no Parry reaction, or its bonus couldn't be parsed out.
	 */
	private function _structuredParryBonus( reactions ) {
		for ( var reaction in arguments.reactions ) {
			if ( findNoCase( "Parry", reaction.name ) > 0 ) {
				var match = reFind( "adds (\d+) to its AC", reaction.desc, 1, true );
				if ( structKeyExists( match, "len" ) && match.len.len() >= 2 && match.len[ 2 ] > 0 ) {
					return int( mid( reaction.desc, match.pos[ 2 ], match.len[ 2 ] ) );
				}
			}
		}
		return 0;
	}

	/**
	 * Builds one combat-ready mob struct (same shape as the player's combat
	 * struct: abilityScores, inventory, vulnerabilities, etc.) from a row of
	 * a monsters query and its already-parsed inventory.
	 */
	private function _saveOrModifier( saveValue, abilityScore ) {
		if ( isNull( arguments.saveValue ) || !len( trim( arguments.saveValue ) ) ) {
			return abilityModifier( arguments.abilityScore );
		}
		return arguments.saveValue;
	}

	private function _buildMonsterStruct( rows, i, inventory ) {
		var immunities = _parseMonsterImmunities( rows.immunities[ arguments.i ] );
		var actionsJsonText = rows.actions_json[ arguments.i ];
		var structuredActions = JSONDeserialize( actionsJsonText );
		var abilitiesJsonText = rows.special_abilities_json[ arguments.i ];
		var structuredAbilities = ( !isNull( abilitiesJsonText ) && len( abilitiesJsonText ) )
			? JSONDeserialize( abilitiesJsonText )
			: [];
		var reactionsJsonText = rows.reactions_json[ arguments.i ];
		var structuredReactions = ( !isNull( reactionsJsonText ) && len( reactionsJsonText ) )
			? JSONDeserialize( reactionsJsonText )
			: [];
		var legendaryActionsJsonText = rows.legendary_actions_json[ arguments.i ];
		var structuredLegendaryActions = ( !isNull( legendaryActionsJsonText ) && len( legendaryActionsJsonText ) )
			? JSONDeserialize( legendaryActionsJsonText )
			: [];

		// A monster's ranged attack (if any) reads as a cast rather than a
		// mundane weapon swing when its stat block has a Spellcasting trait
		// (see resolveAttack()'s isSpell check) — flavor-only, not real spell
		// modeling (a monster's spell list is almost always non-combat
		// utility spells like Light/Thaumaturgy this engine has no mechanic
		// for anyway).
		if ( _hasStructuredTraitByName( structuredActions, "Spellcasting" ) ) {
			for ( var item in arguments.inventory ) {
				if ( item.category == "ranged" ) {
					item.isSpell = true;
				}
			}
		}

		var monster = {
			"name": rows.name[ arguments.i ],
			"creatureType": _cleanMonsterCreatureType( rows.creature_type[ arguments.i ] ),
			"xp": rows.xp[ arguments.i ],
			"armorClass": rows.armor_class[ arguments.i ],
			"hitPoints": rows.hit_points[ arguments.i ],
			"maxHitPoints": rows.hit_points[ arguments.i ],
			"speed": _parseMonsterSpeed( rows.speed[ arguments.i ] ),
			"abilityScores": {
				"str": rows.str[ arguments.i ], "dex": rows.dex[ arguments.i ], "con": rows.con[ arguments.i ],
				"int": rows.int_score[ arguments.i ], "wis": rows.wis[ arguments.i ], "cha": rows.cha[ arguments.i ]
			},
			// Pre-computed saving throw totals (ability modifier + proficiency
			// bonus already summed, straight from the SRD stat block) — see
			// rollSavingThrow()'s savingThrowBonuses check. A handful of
			// seeded rows are missing one or more of these (e.g. the Ancient
			// Red Dragon); fall back to the plain ability modifier for those.
			"savingThrowBonuses": {
				"str": _saveOrModifier( rows.str_save[ arguments.i ], rows.str[ arguments.i ] ),
				"dex": _saveOrModifier( rows.dex_save[ arguments.i ], rows.dex[ arguments.i ] ),
				"con": _saveOrModifier( rows.con_save[ arguments.i ], rows.con[ arguments.i ] ),
				"int": _saveOrModifier( rows.int_save[ arguments.i ], rows.int_score[ arguments.i ] ),
				"wis": _saveOrModifier( rows.wis_save[ arguments.i ], rows.wis[ arguments.i ] ),
				"cha": _saveOrModifier( rows.cha_save[ arguments.i ], rows.cha[ arguments.i ] )
			},
			"inventory": arguments.inventory,
			// Extra Attack/Two Extra Attacks entries derived from the stat
			// block's own precomputed Multiattack count — read by the
			// existing attacksPerTurn(), same mechanism the player's
			// Fighter features already use.
			"features": _multiattackFeatures( _structuredMultiattackCount( structuredActions ) ),
			"vulnerabilities": _parseMonsterDamageList( rows.vulnerabilities[ arguments.i ] ),
			"resistances": _parseMonsterDamageList( rows.resistances[ arguments.i ] ),
			"immunities": immunities.damage,
			"conditionImmunities": immunities.conditions,
			"hasPackTactics": _hasStructuredTraitByName( structuredAbilities, "Pack Tactics" ),
			"regenerationPerTurn": _structuredRegenerationAmount( structuredAbilities ),
			"hasMagicResistance": _hasStructuredTraitByName( structuredAbilities, "Magic Resistance" ),
			"parryBonus": _structuredParryBonus( structuredReactions ),
			"legendaryActions": structuredLegendaryActions,
			"usedSpecialAttack": false,
			"encounterIntro": "#rows.name[ arguments.i ]# blocks your path. Roll for initiative!"
		};

		var special = _parseStructuredSpecialAttack( structuredActions );
		if ( !isNull( special ) ) {
			monster.specialAttack = special;
		}

		return monster;
	}

	/**
	 * Builds a monster row's weapon-shaped inventory from its structured
	 * actions_json (see migration 008_structured_monster_data.sql — every
	 * seeded monster has this populated; see generate_monster_seed.py/
	 * convert_legacy_monsters.py).
	 */
	private function _resolveMonsterInventory( rows, i ) {
		var actionsJsonText = rows.actions_json[ arguments.i ];
		if ( isNull( actionsJsonText ) || !len( actionsJsonText ) ) {
			return [];
		}
		return _parseStructuredActions( JSONDeserialize( actionsJsonText ) );
	}

	/**
	 * Queries every seeded monster within `level`'s CR band (see
	 * _levelAppropriateCRRange()) that has at least one weapon attack — a
	 * small handful of the seeded monsters (true non-combatants like an
	 * Awakened Shrub, or a Frog/Sea Horse with no actions at all) have none
	 * and are skipped, since a mob that can never attack isn't a usable
	 * candidate.
	 */
	private function _monsterCandidatesForLevel( level ) {
		var range = _levelAppropriateCRRange( arguments.level );
		var rows = queryExecute(
			"SELECT name, creature_type, armor_class, hit_points, speed, str, dex, con, int_score, wis, cha,
			        str_save, dex_save, con_save, int_save, wis_save, cha_save,
			        vulnerabilities, resistances, immunities, cr, xp,
			        actions_json, special_abilities_json, legendary_actions_json, reactions_json
			 FROM monsters WHERE cr IS NOT NULL",
			{}, { datasource: "gameserver" }
		);
		var candidates = [];
		for ( var i = 1; i <= rows.recordCount; i++ ) {
			var crValue = _crToDecimal( rows.cr[ i ] );
			if ( crValue < range.min || crValue > range.max ) {
				continue;
			}
			var inventory = _resolveMonsterInventory( rows, i );
			if ( inventory.len() == 0 ) {
				continue;
			}
			arrayAppend( candidates, _buildMonsterStruct( rows, i, inventory ) );
		}
		return candidates;
	}

	/**
	 * Picks `count` level-appropriate monsters from the seeded SRD `monsters`
	 * table at random (independently per slot, so duplicates like two
	 * Skeletons are normal). Returns fewer than `count` mobs only if the CR
	 * band happens to have zero candidates.
	 */
	function randomMonstersForLevel( level, count ) {
		var candidates = _monsterCandidatesForLevel( arguments.level );
		var mobs = [];
		for ( var i = 1; i <= arguments.count; i++ ) {
			if ( candidates.len() == 0 ) {
				break;
			}
			arrayAppend( mobs, duplicate( candidates[ randRange( 1, candidates.len() ) ] ) );
		}
		return mobs;
	}

	/**
	 * Looks up a single named monster from the `monsters` table, for a
	 * scripted encounter (e.g. the seeded Trade Road bandit_ambush POI)
	 * rather than a random level-appropriate draw. Throws if the name
	 * doesn't match a seeded monster, or the monster has no parseable
	 * attacks — both are content bugs in whatever's calling this, not
	 * something to silently paper over.
	 */
	function monsterByName( name ) {
		var rows = queryExecute(
			"SELECT name, creature_type, armor_class, hit_points, speed, str, dex, con, int_score, wis, cha,
			        str_save, dex_save, con_save, int_save, wis_save, cha_save,
			        vulnerabilities, resistances, immunities, xp,
			        actions_json, special_abilities_json, legendary_actions_json, reactions_json
			 FROM monsters WHERE name = :name",
			{ "name": arguments.name },
			{ datasource: "gameserver" }
		);
		if ( rows.recordCount == 0 ) {
			throw( type = "MonsterNotFound", message = "No seeded monster named '#arguments.name#'." );
		}
		var inventory = _resolveMonsterInventory( rows, 1 );
		if ( inventory.len() == 0 ) {
			throw( type = "MonsterHasNoAttacks", message = "Monster '#arguments.name#' has no parseable weapon attacks." );
		}
		return _buildMonsterStruct( rows, 1, inventory );
	}

	/**
	 * Every seeded monster's name (+ CR, for display), alphabetically — for
	 * populating a "pick a specific monster" dropdown (see the Map Editor's
	 * spawn point configuration) rather than only ever drawing a random
	 * level-appropriate mob via randomMonstersForLevel().
	 */
	function listAllMonsterNames() {
		var rows = queryExecute(
			"SELECT name, cr FROM monsters ORDER BY name",
			{}, { datasource: "gameserver" }
		);
		var names = [];
		for ( var i = 1; i <= rows.recordCount; i++ ) {
			arrayAppend( names, { "name": rows.name[ i ], "cr": rows.cr[ i ] } );
		}
		return names;
	}

	/**
	 * Known consumable item effects, keyed by items.name (see
	 * armor_and_items_seed.sql) — separate from the items table itself since
	 * only a handful of seeded items actually do anything when used; the
	 * rest (Rations, Torch, Rope, Gemstone) are inert flavor/treasure.
	 */
	function consumableEffects() {
		return {
			"Potion of Healing": { "type": "heal", "diceCount": 2, "diceSides": 4, "flatBonus": 2 }
		};
	}

	/**
	 * Applies an item's effect (by items.name) to the player and persists
	 * the result, same as shortRest()/longRest(). Returns true if the name
	 * matched a known effect (and was therefore consumed), false otherwise —
	 * default.bx only debits the item from inventory on a true return, so an
	 * unrecognized consumable is left alone rather than wasted.
	 */
	function useConsumableItem( state, itemName ) {
		var effects = consumableEffects();
		if ( !effects.keyExists( arguments.itemName ) ) {
			return false;
		}
		var effect = effects[ arguments.itemName ];
		var player = arguments.state.player;

		if ( effect.type == "heal" ) {
			var amount = rollSum( effect.diceCount, effect.diceSides ) + effect.flatBonus;
			var healed = min( amount, player.maxHitPoints - player.hitPoints );
			player.hitPoints += healed;
			arguments.state.log.prepend( "#player.name# drinks a #arguments.itemName# and recovers #healed# Hit Point#( healed == 1 ? "" : "s" )# (#player.hitPoints#/#player.maxHitPoints# HP)." );
		}

		saveCharacterState( player );
		return true;
	}

	/**
	 * Resolves a character's species name (which may be a subrace, e.g. "Hill
	 * Dwarf") against the `species`/`species_traits` tables, merging in the
	 * parent race's resistances and traits when the named species is a
	 * subrace — a Hill Dwarf has both its own trait (Dwarven Toughness) and
	 * every trait Dwarf grants. Returns { resistances: [], traitNames: [] };
	 * both are empty for an unrecognized or blank species name (e.g. a
	 * character created before species was DB-backed).
	 */
	private function _resolveSpeciesMechanics( species ) {
		var result = { "resistances": [], "traitNames": [] };
		if ( !len( arguments.species ) ) {
			return result;
		}

		var speciesRows = queryExecute(
			"SELECT s.id, s.resistances, s.parent_species_id, p.resistances AS parent_resistances
			 FROM species s LEFT JOIN species p ON p.id = s.parent_species_id
			 WHERE s.name = :species",
			{ "species": arguments.species },
			{ datasource: "gameserver" }
		);
		if ( speciesRows.recordCount == 0 ) {
			return result;
		}

		var speciesIds = [ speciesRows.id[ 1 ] ];
		for ( var resistanceList in [ speciesRows.resistances[ 1 ], speciesRows.parent_resistances[ 1 ] ] ) {
			if ( !isNull( resistanceList ) && len( resistanceList ) ) {
				for ( var resistance in listToArray( resistanceList, "," ) ) {
					result.resistances.append( trim( resistance ) );
				}
			}
		}
		if ( !isNull( speciesRows.parent_species_id[ 1 ] ) ) {
			speciesIds.append( speciesRows.parent_species_id[ 1 ] );
		}

		var traitRows = queryExecute(
			"SELECT name FROM species_traits WHERE species_id IN (#arrayToList( speciesIds )#)",
			{}, { datasource: "gameserver" }
		);
		for ( var traitRow in traitRows ) {
			result.traitNames.append( traitRow.name );
		}
		return result;
	}

	/**
	 * Public entry point for resolving a character's skill proficiencies by
	 * species/background name alone (for callers, like CharacterService's
	 * character sheet, that don't already have a _resolveSpeciesMechanics()
	 * result on hand). loadCharacter() calls _skillProficienciesFromTraits()
	 * directly instead, to reuse the speciesMechanics it already computed.
	 */
	function resolveSkillProficiencies( species, background ) {
		return _skillProficienciesFromTraits( _resolveSpeciesMechanics( arguments.species ).traitNames, arguments.background );
	}

	/**
	 * Parses a `classes.skill_proficiencies` SRD string (e.g. "Choose 2:
	 * Acrobatics, Animal Handling, Athletics, ... or Survival", or Bard's
	 * "Choose any 3 skills (see Playing the Game)") into
	 * { count, options }, for the character creation wizard's skill picker.
	 * `options` is every one of the SRD's 18 skills when the class allows
	 * "any" skill rather than a specific list.
	 */
	function parseClassSkillChoice( text ) {
		var countMatch = reFindNoCase( "Choose (?:any )?(\d+)", arguments.text, 1, true );
		var count = ( structKeyExists( countMatch, "len" ) && countMatch.len.len() >= 2 && countMatch.len[ 2 ] > 0 )
			? int( mid( arguments.text, countMatch.pos[ 2 ], countMatch.len[ 2 ] ) )
			: 0;

		var options = [];
		var colonPos = find( ":", arguments.text );
		if ( colonPos == 0 ) {
			// No explicit list (e.g. "Choose any 3 skills ...") — any SRD skill qualifies.
			for ( var skill in SKILL_ABILITIES ) {
				options.append( skill );
			}
		} else {
			var listText = mid( arguments.text, colonPos + 1, len( arguments.text ) );
			listText = reReplaceNoCase( listText, "\(.*?\)", "", "all" );
			listText = reReplaceNoCase( listText, "\bor\b", ",", "all" );
			for ( var part in listToArray( listText, "," ) ) {
				var trimmed = trim( part );
				if ( len( trimmed ) ) {
					options.append( trimmed );
				}
			}
		}
		return { "count": count, "options": options };
	}

	/**
	 * Resolves a character's skill proficiencies from their background's
	 * fixed `skill_proficiencies` list (e.g. Acolyte: Insight, Religion) plus
	 * any species traits in TRAIT_SKILL_GRANTS (e.g. Elf's Keen Senses ->
	 * Perception). Doesn't cover a class's own skill choices (`classes.
	 * skill_proficiencies` is an unparsed "choose 2 of ..." SRD string, and
	 * character creation has no skill-picker step) — see WIP.md.
	 *
	 * @traitNames Species trait names, from _resolveSpeciesMechanics().traitNames.
	 * @background characters.background.
	 */
	private function _skillProficienciesFromTraits( traitNames, background ) {
		var skills = [];
		if ( len( arguments.background ) ) {
			var backgroundRows = queryExecute(
				"SELECT skill_proficiencies FROM backgrounds WHERE name = :name",
				{ "name": arguments.background },
				{ datasource: "gameserver" }
			);
			if ( backgroundRows.recordCount > 0 && len( backgroundRows.skill_proficiencies[ 1 ] ) ) {
				for ( var skill in listToArray( backgroundRows.skill_proficiencies[ 1 ], "," ) ) {
					skills.append( trim( skill ) );
				}
			}
		}
		for ( var traitName in TRAIT_SKILL_GRANTS ) {
			if ( arrayFindNoCase( arguments.traitNames, traitName ) == 0 ) {
				continue;
			}
			for ( var skill in TRAIT_SKILL_GRANTS[ traitName ] ) {
				if ( arrayFindNoCase( skills, skill ) == 0 ) {
					skills.append( skill );
				}
			}
		}
		return skills;
	}

	/**
	 * The Proficiency Bonus to add to `combatant`'s check for `skill`, or 0
	 * if they aren't proficient. Monsters carry no per-skill proficiency
	 * data (only saving throw bonuses come from their stat block), so a
	 * combatant with no `skillProficiencies` array is treated as proficient
	 * in everything — the same always-proficient behavior attemptGrapple()/
	 * attemptShove() already had for every combatant before skill
	 * proficiencies existed, preserved here so monster contests don't get
	 * silently nerfed for lack of data.
	 */
	private function _skillProficiencyBonus( combatant, skill ) {
		if ( !structKeyExists( arguments.combatant, "proficiencyBonus" ) ) {
			return 0;
		}
		if ( !structKeyExists( arguments.combatant, "skillProficiencies" ) ) {
			return arguments.combatant.proficiencyBonus;
		}
		if ( arrayFindNoCase( arguments.combatant.skillProficiencies, arguments.skill ) == 0 ) {
			return 0;
		}
		// Expertise (Rogue 1, Bard 2, Ranger 9): doubled Proficiency Bonus for
		// a player-chosen skill — see pendingExpertiseChoice()/chooseExpertise().
		var hasExpertise = (
			structKeyExists( arguments.combatant, "expertiseSkills" ) &&
			arrayFindNoCase( arguments.combatant.expertiseSkills, arguments.skill ) > 0
		);
		return arguments.combatant.proficiencyBonus * ( hasExpertise ? 2 : 1 );
	}

	/**
	 * Rolls a generic skill check: d20 + ability modifier + Proficiency Bonus
	 * (only if `combatant` is proficient in `skill` — see
	 * _skillProficiencyBonus()), vs. `dc`. Mirrors rollSavingThrow()'s
	 * shape; unlike saving throws, no species trait or condition in this
	 * app currently grants Advantage/Disadvantage on a skill check
	 * specifically, so there's no such hook here yet.
	 *
	 * @combatant The combatant making the check.
	 * @skill One of the SRD skill names (see SKILL_ABILITIES) — e.g. "Perception".
	 * @dc The Difficulty Class to meet or beat.
	 */
	function rollSkillCheck( combatant, skill, dc ) {
		var ability = SKILL_ABILITIES[ arguments.skill ];
		var abilityMod = structKeyExists( arguments.combatant, "modifiers" )
			? arguments.combatant.modifiers[ ability ]
			: abilityModifier( arguments.combatant.abilityScores[ ability ] );
		var proficiencyBonus = _skillProficiencyBonus( arguments.combatant, arguments.skill );
		var roll = randRange( 1, 20 );
		var total = roll + abilityMod + proficiencyBonus;
		return { "roll": roll, "total": total, "success": ( total >= arguments.dc ), "isProficient": proficiencyBonus > 0 };
	}

	/**
	 * Loads a saved character (gameserver.characters) and assembles the
	 * in-combat player struct from it: ability scores/modifiers, class-derived
	 * fields (saving throws, fixed HP per level), gained class features, and
	 * equipped inventory. `position` is intentionally left for the caller to
	 * set — it's transient encounter state, not part of the saved character.
	 *
	 * @characterId The characters.id to load.
	 */
	function loadCharacter( characterId ) {
		var rows = queryExecute(
			"SELECT c.*, cl.name AS className, cl.hit_die, cl.saving_throw_proficiencies
			 FROM characters c
			 JOIN classes cl ON cl.id = c.class_id
			 WHERE c.id = :characterId",
			{ "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
		if ( rows.recordCount == 0 ) {
			throw( type = "CharacterNotFound", message = "No saved character with id #arguments.characterId#." );
		}
		var row = rows;

		var modifiers = {
			"str": abilityModifier( row.str[ 1 ] ),
			"dex": abilityModifier( row.dex[ 1 ] ),
			"con": abilityModifier( row.con[ 1 ] ),
			"int": abilityModifier( row.int_score[ 1 ] ),
			"wis": abilityModifier( row.wis[ 1 ] ),
			"cha": abilityModifier( row.cha[ 1 ] )
		};

		var species = row.species[ 1 ];
		var speciesMechanics = _resolveSpeciesMechanics( species );
		var skillProficiencies = _skillProficienciesFromTraits( speciesMechanics.traitNames, row.background[ 1 ] );
		if ( len( row.chosen_skill_proficiencies[ 1 ] ) ) {
			for ( var chosenSkill in listToArray( row.chosen_skill_proficiencies[ 1 ], "," ) ) {
				if ( arrayFindNoCase( skillProficiencies, chosenSkill ) == 0 ) {
					skillProficiencies.append( chosenSkill );
				}
			}
		}

		var player = {
			"characterId": row.id[ 1 ],
			"name": row.name[ 1 ],
			"class": row.className[ 1 ],
			"species": species,
			"level": row.level[ 1 ],
			"abilityScores": {
				"str": row.str[ 1 ], "dex": row.dex[ 1 ], "con": row.con[ 1 ],
				"int": row.int_score[ 1 ], "wis": row.wis[ 1 ], "cha": row.cha[ 1 ]
			},
			"modifiers": modifiers,
			"proficiencyBonus": row.proficiency_bonus[ 1 ],
			"armorClass": row.armor_class[ 1 ],
			// Floored at 0, not 1 — every damage application already clamps to
			// 0 (never negative), and default.bx's onMount() specifically
			// checks for a true 0 here to auto-heal a character loaded after a
			// defeat (defeat no longer offers an in-encounter rest option).
			// Flooring to 1 would hide that signal and leave them stuck.
			"hitPoints": max( 0, row.hit_points[ 1 ] ),
			"maxHitPoints": row.max_hit_points[ 1 ],
			"gold": row.gold[ 1 ],
			// Die size (e.g. 8 for a d8) used when spending Hit Dice on a short rest.
			"hitDieSize": int( reReplace( row.hit_die[ 1 ], "[^0-9]*(\d+).*", "\1" ) ),
			"hitDiceMax": row.level[ 1 ],
			"hitDiceSpent": row.hit_dice_spent[ 1 ],
			"hitPointsPerLevel": _fixedHitPointsPerLevel( row.hit_die[ 1 ] ),
			// Dwarven Toughness (Hill Dwarf only): +1 Hit Point maximum per
			// level, on top of the class's normal per-level gain.
			"hpBonusPerLevel": arrayFindNoCase( speciesMechanics.traitNames, "Dwarven Toughness" ) > 0 ? 1 : 0,
			"speed": row.speed[ 1 ],
			"experiencePoints": row.experience_points[ 1 ],
			// Lifetime counters, persisted directly as they happen (see
			// _incrementCharacterStat()) rather than batched into
			// saveCharacterState() — "monstersFought" is per-encounter (every
			// opponent in the roster once combat starts), "monstersKilled" is
			// per-kill, "deaths" increments each time this character has died.
			"monstersFought": row.monsters_fought[ 1 ],
			"monstersKilled": row.monsters_killed[ 1 ],
			"deaths": row.deaths[ 1 ],
			"savingThrowProficiencies": listToArray( row.saving_throw_proficiencies[ 1 ], " and ", false, true ),
			// From background + species traits (see _skillProficienciesFromTraits())
			// — doesn't include a class's own skill choices, since there's no
			// skill-picker step in character creation yet.
			"skillProficiencies": skillProficiencies,
			// Species mechanics (resistances plus the boolean hooks below) are
			// derived from the `species`/`species_traits` tables by name, not
			// hardcoded per species — see _resolveSpeciesMechanics(). A subrace
			// (e.g. "Hill Dwarf") inherits its parent race's traits too.
			"resistances": speciesMechanics.resistances,
			// Halfling Lucky: reroll a natural 1 on the d20 and use the new roll.
			"hasLuck": arrayFindNoCase( speciesMechanics.traitNames, "Lucky" ) > 0,
			// Half-Orc Relentless Endurance: drop to 1 HP instead of 0, once per
			// Long Rest — persisted, not reset by a fresh encounter load.
			"hasRelentlessEndurance": arrayFindNoCase( speciesMechanics.traitNames, "Relentless Endurance" ) > 0,
			"usedRelentlessEndurance": row.used_relentless_endurance[ 1 ] == 1,
			// Dragonborn Breath Weapon: once per Long Rest, an area blast the
			// opponent can save against for half damage — persisted, not reset
			// by a fresh encounter load.
			"hasBreathWeapon": arrayFindNoCase( speciesMechanics.traitNames, "Breath Weapon" ) > 0,
			"usedBreathWeapon": row.used_breath_weapon[ 1 ] == 1,
			// Elf/Half-Elf Fey Ancestry: Advantage on saves vs. the Charmed
			// condition, and immune to being put to sleep by magic. No current
			// encounter content attempts to Charm or magically Sleep the
			// player, so isImmuneToMagicalSleep is tracked but has nothing to
			// interact with yet; the Advantage hook is real and exercised via
			// rollSavingThrow().
			"hasFeyAncestry": arrayFindNoCase( speciesMechanics.traitNames, "Fey Ancestry" ) > 0,
			"isImmuneToMagicalSleep": arrayFindNoCase( speciesMechanics.traitNames, "Fey Ancestry" ) > 0,
			// Gnome Cunning: Advantage on Intelligence/Wisdom/Charisma saves
			// against magic. Same caveat as Fey Ancestry above.
			"hasGnomishCunning": arrayFindNoCase( speciesMechanics.traitNames, "Gnome Cunning" ) > 0,
			// Half-Orc Savage Attacks: on a critical hit with a melee weapon,
			// roll one additional weapon damage die — distinct from the Savage
			// Attacker feat's "roll damage twice, take the higher" (both can
			// apply to the same attack). See resolveAttack()'s diceCount calc.
			"hasSavageAttacks": arrayFindNoCase( speciesMechanics.traitNames, "Savage Attacks" ) > 0,
			// Once-per-Long-Rest reroll of a missed attack — no species in the
			// current dataset grants this (it was a 2024-ruleset Human trait),
			// kept as a hook for any future species that does. Persisted, not
			// reset by a fresh encounter load.
			"hasHeroicInspiration": arrayFindNoCase( speciesMechanics.traitNames, "Heroic Inspiration" ) > 0,
			"usedHeroicInspiration": row.used_heroic_inspiration[ 1 ] == 1,
			// Second Wind (Fighter 1): a bonus action heal of 1d10 + Fighter
			// level — see useSecondWind(). Recovers on a Short or Long Rest
			// (shortRest()/longRest()), persisted across encounters.
			"usedSecondWind": row.used_second_wind[ 1 ] == 1,
			// Rage (Barbarian 1): see startRage()/endRage(). `ragesUsed` is the
			// persisted truth (like spentSpellSlots); `ragesRemaining` is
			// derived from it and the level-based max — see
			// _recomputeRagesRemaining(), called below once `level`/`features`
			// are set. One use recovers on a Short Rest, all on a Long Rest.
			"ragesUsed": row.rages_used[ 1 ],
			// The in-game clock (see startNewRound()'s +6-sec-per-round tick,
			// and shortRest()/longRest()'s hour-sized jumps), and the clock
			// value as of the last completed Long Rest — null until the first
			// one, so it never wrongly blocks that first rest on the 24-hour
			// cooldown (see longRest()).
			"gameClockSeconds": row.game_clock_seconds[ 1 ],
			"lastLongRestSeconds": isNull( row.last_long_rest_seconds[ 1 ] ) ? javaCast( "null", 0 ) : row.last_long_rest_seconds[ 1 ],
			// Magic Initiate's bonus spell recovers on a Long Rest only —
			// persisted, not reset by a fresh encounter load (see
			// _assignSpellcasting(), which no longer touches this field).
			"usedMagicInitiateSpell": row.used_magic_initiate_spell[ 1 ] == 1,
			"isRaging": false,
			"features": [],
			"feats": [],
			"inventory": [],
			// The player's known cantrips/leveled spells, if any (see
			// _assignSpellcasting()) — empty for a non-caster, or any
			// character created before this feature existed.
			"knownCantripNames": len( row.known_cantrips[ 1 ] ) ? listToArray( row.known_cantrips[ 1 ] ) : [],
			"knownSpellNames": len( row.known_spells[ 1 ] ) ? listToArray( row.known_spells[ 1 ] ) : []
		};

		// Multiclassing (see startMulticlass()/setNextLevelClass()):
		// `player.classes` always has at least one entry (the original
		// class); `player.level`/`player.hitDieSize` above stay scoped to
		// that original class specifically (used for its own hit-die rolls
		// and feature grants), while `player.totalLevel` is the sum across
		// every class — what proficiency bonus, XP thresholds, and combined
		// spell slots actually key off. A single-class character (the
		// overwhelming default) just gets a one-entry `classes` array and
		// `totalLevel == level`, unchanged from before this feature existed.
		player.classes = [ {
			"classId": row.class_id[ 1 ], "className": row.className[ 1 ],
			"subclassId": isNull( row.subclass_id[ 1 ] ) ? javaCast( "null", 0 ) : row.subclass_id[ 1 ],
			"level": row.level[ 1 ], "hitDie": row.hit_die[ 1 ]
		} ];
		player.totalLevel = row.level[ 1 ];
		var multiclassRows = queryExecute(
			"SELECT cml.class_id, cml.subclass_id, cml.level, cl.name AS className, cl.hit_die
			 FROM character_multiclass_levels cml JOIN classes cl ON cl.id = cml.class_id
			 WHERE cml.character_id = :characterId",
			{ "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
		for ( var mcRow in multiclassRows ) {
			arrayAppend( player.classes, {
				"classId": mcRow.class_id, "className": mcRow.className,
				"subclassId": isNull( mcRow.subclass_id ) ? javaCast( "null", 0 ) : mcRow.subclass_id,
				"level": mcRow.level, "hitDie": mcRow.hit_die
			} );
			player.totalLevel += mcRow.level;
		}
		// Which class the next automatic level-up applies to (see
		// _levelUp()) — defaults to the original class until the player
		// multiclasses and/or redirects it via setNextLevelClass().
		player.nextLevelClassId = isNull( row.next_level_class_id[ 1 ] ) ? row.class_id[ 1 ] : row.next_level_class_id[ 1 ];

		var featureRows = queryExecute(
			"SELECT cf.name FROM character_features chf
			 JOIN class_features cf ON cf.id = chf.class_feature_id
			 WHERE chf.character_id = :characterId
			 ORDER BY cf.level, cf.sort_order",
			{ "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
		for ( var featureRow in featureRows ) {
			arrayAppend( player.features, featureRow.name );
		}

		var featRows = queryExecute(
			"SELECT f.name FROM character_feats chf
			 JOIN feats f ON f.id = chf.feat_id
			 WHERE chf.character_id = :characterId",
			{ "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
		for ( var featRow in featRows ) {
			arrayAppend( player.feats, featRow.name );
		}
		// Savage Attacker: once per turn (satisfied automatically here, since
		// this app only allows one attack per turn), roll damage dice twice
		// and use the higher result.
		player.hasSavageAttacker = arrayFindNoCase( player.feats, "Savage Attacker" ) > 0;
		// Grappler: Advantage on attacks against a creature grappled by you.
		player.hasGrapplerFeat = arrayFindNoCase( player.feats, "Grappler" ) > 0;
		// Magic Initiate: a simple attack cantrip usable in place of a weapon attack.
		player.hasMagicInitiate = arrayFindNoCase( player.feats, "Magic Initiate" ) > 0;
		// Defense fighting style: +1 Armor Class, but only while wearing
		// Light, Medium, or Heavy body armor — not unarmored, and not from
		// a shield alone (see _recalculateArmorClass()'s own armor_type
		// != 'shield' distinction for the same body-armor-vs-shield split).
		if ( arrayFindNoCase( player.feats, "Defense" ) > 0 ) {
			var wornBodyArmor = queryExecute(
				"SELECT 1 AS found FROM character_armor ca
				 JOIN armors a ON a.id = ca.armor_id
				 WHERE ca.character_id = :characterId AND ca.equipped = 1 AND a.armor_type != 'shield'",
				{ "characterId": arguments.characterId },
				{ datasource: "gameserver" }
			);
			if ( wornBodyArmor.recordCount > 0 ) {
				player.armorClass += 1;
			}
		}

		// Rage (Barbarian 1): derives ragesRemaining from the persisted
		// ragesUsed and the level-based max — 0 for a non-Barbarian.
		_recomputeRagesRemaining( player );
		// Expertise (Rogue 1, Bard 2, Ranger 9): the player-chosen skills (from
		// among their existing proficiencies) that get doubled Proficiency
		// Bonus — see pendingExpertiseChoice()/chooseExpertise(), never
		// auto-assigned.
		player.expertiseSkills = len( row.expertise_skills[ 1 ] ) ? listToArray( row.expertise_skills[ 1 ] ) : [];

		var spentSlotsRaw = row.spent_spell_slots[ 1 ];
		player.spentSpellSlots = ( len( trim( spentSlotsRaw ) ) && trim( spentSlotsRaw ) != "{}" )
			? JSONDeserialize( spentSlotsRaw )
			: {};

		_assignSpellcasting( player );

		var inventoryRows = queryExecute(
			"SELECT ci.id, ci.weapon_id, ci.category, ci.equipped, ci.quantity, ci.attack_bonus, ci.damage_bonus,
			        w.name, w.damage_dice, w.damage_type, w.properties, w.mastery
			 FROM character_inventory ci
			 JOIN weapons w ON w.id = ci.weapon_id
			 WHERE ci.character_id = :characterId",
			{ "characterId": arguments.characterId },
			{ datasource: "gameserver" }
		);
		for ( var invRow in inventoryRows ) {
			var item = {
				// Maps this item back to its database rows.
				"id": invRow.id,
				"weaponId": invRow.weapon_id,
				"name": invRow.name,
				"category": invRow.category,
				"damageDice": invRow.damage_dice,
				"damageType": invRow.damage_type,
				// Property text is comma-space delimited ("Finesse, Light"); a
				// plain listToArray() would leave a leading space on every
				// entry but the first (" Light"), silently breaking every
				// arrayFindNoCase() property check (Two-Handed, Versatile, Light).
				"properties": arrayMap( listToArray( invRow.properties ), ( p ) => trim( p ) ),
				"attackBonus": invRow.attack_bonus,
				"damageBonus": invRow.damage_bonus,
				"equipped": invRow.equipped,
				"quantity": invRow.quantity,
				// Weapon Mastery property (Cleave/Graze/Nick/Push/Sap/Slow/Topple/
				// Vex — see resolveAttack()'s "Weapon Mastery" section), only
				// actually usable by a combatant with the Weapon Mastery class
				// feature (Barbarian/Fighter/Paladin/Ranger/Rogue at level 1).
				"mastery": isNull( invRow.mastery ) ? "" : invRow.mastery
			};
			if ( item.category == "ranged" ) {
				var range = _parseWeaponRange( invRow.properties );
				if ( !isNull( range ) ) {
					item.normalRange = range.normal;
					item.longRange = range.long;
				}
			}
			arrayAppend( player.inventory, item );
		}

		return player;
	}

	/**
	 * Standard D&D ability modifier: floor((score - 10) / 2).
	 */
	function abilityModifier( score ) {
		return int( ( arguments.score - 10 ) / 2 );
	}

	/**
	 * Extracts the fixed HP-per-level value from a class's hit_die text (e.g.
	 * "D12 per Barbarian level"), per the "Fixed Hit Points by Class" table:
	 * the average die roll rounded up, i.e. ceil(dieSize / 2) + 1.
	 */
	private function _fixedHitPointsPerLevel( hitDieText ) {
		var dieSize = int( reReplace( arguments.hitDieText, "[^0-9]*(\d+).*", "\1" ) );
		return int( ( dieSize + 1 ) / 2 ) + 1;
	}

	/**
	 * Parses a weapon's "Range NN/NNN" property text (feet) into normal/long
	 * range in 5-foot squares, e.g. "Thrown (Range 30/120)" -> {6, 24}.
	 * Returns null if the weapon has no Range property.
	 */
	private function _parseWeaponRange( propertiesText ) {
		var match = reFind( "Range\s+(\d+)\s*/\s*(\d+)", arguments.propertiesText, 1, true );
		if ( !structKeyExists( match, "len" ) || match.len.len() < 3 || match.len[ 2 ] == 0 ) {
			return javaCast( "null", 0 );
		}
		var normalFeet = int( mid( arguments.propertiesText, match.pos[ 2 ], match.len[ 2 ] ) );
		var longFeet = int( mid( arguments.propertiesText, match.pos[ 3 ], match.len[ 3 ] ) );
		return { "normal": int( normalFeet / 5 ), "long": int( longFeet / 5 ) };
	}

}
