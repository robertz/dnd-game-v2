	}

	function removeCondition( combatant, name ) {
		if ( structKeyExists( arguments.combatant, "conditions" ) ) {
			arguments.combatant.conditions.delete( arguments.name );
		}
	}

	/**
	 * True if `combatant` can't take actions or Reactions — Incapacitated
	 * itself, or any condition whose own rules text says "incapacitated"
	 * (Paralyzed, Petrified, Stunned, Unconscious). Gates the player's
	 * manual actions (default.bx), the enemy AI's turn (_runOneOpponentTurn()),
	 * and Reactions (checkOpportunityAttacks()).
	 */
