	/**
	 * Resolves one attack roll and, on a hit, one damage roll, per the core
	 * rules: d20 + attack bonus vs AC; natural 20 always hits and is a
	 * Critical Hit (roll damage dice twice); natural 1 always misses.
	 * Disadvantage rolls two d20s and keeps the lower result.
	 * Vulnerability/Resistance/Immunity to the weapon's damage type is applied.
	 * A defender with an unused Reaction and a parsed Parry trait
	 * (`defender.parryBonus`, see _structuredParryBonus()) can turn a
	 * non-critical melee hit into a miss.
	 *
	 * `state` is optional (defaults to `{}`, as every existing unit test call
	 * omits it) — it's only used for the Weapon Mastery properties that need
	 * more battlefield context than a single attacker/defender pair (Push's
	 * grid, Cleave's second target from `state.opponents`). Every real
	 * combat call site passes the full encounter state; only Weapon Mastery
	 * is gated behind it (see the "Weapon Mastery" section below), and only
	 * ever for a combatant with the "Weapon Mastery" class feature, which in
	 * this dataset is always the player.
	 *
	 * @log The encounter's combat log array — a new entry is prepended.
	 * @attacker The attacker's stat struct (has a `name`).
	 * @defender The defender's stat struct — mutated in place with the result.
	 * @weapon The weapon item being used for this attack (from inventory).
	 * @disadvantage Whether this attack roll has Disadvantage.
	 */
	function resolveAttack( log, attacker, defender, weapon, disadvantage = false, advantage = false, omitDamageBonus = false, coverBonus = 0, state = {} ) {
		// Grappler: attacks against a creature you've grappled have Advantage,
		// even if the caller didn't ask for it explicitly.
		var autoAdvantage = (
			structKeyExists( arguments.defender, "grappledBy" ) &&
			arguments.defender.grappledBy == arguments.attacker.name &&
			structKeyExists( arguments.attacker, "hasGrapplerFeat" ) &&
			arguments.attacker.hasGrapplerFeat
		);
		// Prone: melee attacks against a Prone target have Advantage, ranged
		// ones have Disadvantage. Restrained: attacks against a Restrained
		// target always have Advantage; being Restrained yourself always gives
		// Disadvantage on your own attacks, same as being Poisoned or
		// Frightened (simplified here to apply regardless of whether the
		// source of the fear is in sight, since this app doesn't track that).
		// Blinded: your own attacks have Disadvantage. Invisible: your own
		// attacks have Advantage (the mirror image of Blinded).
		var autoDisadvantage = (
			hasCondition( arguments.attacker, "Restrained" ) ||
			hasCondition( arguments.attacker, "Poisoned" ) ||
			hasCondition( arguments.attacker, "Frightened" ) ||
			hasCondition( arguments.attacker, "Blinded" )
		);
		if ( hasCondition( arguments.attacker, "Invisible" ) ) {
			autoAdvantage = true;
		}
		if ( hasCondition( arguments.defender, "Prone" ) ) {
			if ( arguments.weapon.category == "melee" ) {
				autoAdvantage = true;
			} else {
				autoDisadvantage = true;
			}
		}
		// Restrained, Blinded (can't see to defend), and Paralyzed/Petrified/
		// Stunned/Unconscious (helpless) all give attacks against the
		// defender Advantage. Invisible is the opposite: attacks against an
		// Invisible defender have Disadvantage.
		if (
			hasCondition( arguments.defender, "Restrained" ) ||
			hasCondition( arguments.defender, "Blinded" ) ||
			isHelpless( arguments.defender )
		) {
			autoAdvantage = true;
		}
		if ( hasCondition( arguments.defender, "Invisible" ) ) {
			autoDisadvantage = true;
		}
		// Weapon Mastery — Vex: a prior hit against this same target with a
		// Vex weapon grants Advantage on this attack (consumed either way).
		var usedVex = (
			structKeyExists( arguments.attacker, "vexAdvantageTarget" ) && len( arguments.attacker.vexAdvantageTarget ) &&
			arguments.attacker.vexAdvantageTarget == arguments.defender.name
		);
		if ( usedVex ) {
			autoAdvantage = true;
			arguments.attacker.vexAdvantageTarget = "";
		}
		// Weapon Mastery — Sap: a prior hit against the attacker with a Sap
		// weapon gives Disadvantage on this attack (consumed either way).
		var usedSap = structKeyExists( arguments.attacker, "sapped" ) && arguments.attacker.sapped;
		if ( usedSap ) {
			autoDisadvantage = true;
			arguments.attacker.sapped = false;
		}
		// Advantage and Disadvantage on the same roll cancel out, per the rules.
		var useAdvantage = ( arguments.advantage || autoAdvantage ) && !( arguments.disadvantage || autoDisadvantage );
		var useDisadvantage = ( arguments.disadvantage || autoDisadvantage ) && !( arguments.advantage || autoAdvantage );

		var roll = randRange( 1, 20 );
		if ( useAdvantage ) {
			roll = max( roll, randRange( 1, 20 ) );
		} else if ( useDisadvantage ) {
			roll = min( roll, randRange( 1, 20 ) );
		}
		// Halfling Luck: a natural 1 can be rerolled, and the new roll must be used.
		var usedLuck = false;
		if ( roll == 1 && structKeyExists( arguments.attacker, "hasLuck" ) && arguments.attacker.hasLuck ) {
			roll = randRange( 1, 20 );
			usedLuck = true;
		}
		// Archery fighting style: +2 to attack rolls with Ranged weapons.
		var hasArchery = structKeyExists( arguments.attacker, "feats" ) && arrayFindNoCase( arguments.attacker.feats, "Archery" ) > 0;
		var styleBonus = ( hasArchery && arguments.weapon.category == "ranged" ) ? 2 : 0;
		var effectiveAC = arguments.defender.armorClass + arguments.coverBonus;
		var total = roll + arguments.weapon.attackBonus + styleBonus;
		var isCrit = ( roll == 20 );
		var isFumble = ( roll == 1 );
		var hits = !isFumble && ( isCrit || total >= effectiveAC );

		// Human Heroic Inspiration: once per encounter, reroll a missed attack.
		var usedInspiration = false;
		if (
			!hits && structKeyExists( arguments.attacker, "hasHeroicInspiration" ) &&
			arguments.attacker.hasHeroicInspiration && !arguments.attacker.usedHeroicInspiration
		) {
			arguments.attacker.usedHeroicInspiration = true;
			usedInspiration = true;
